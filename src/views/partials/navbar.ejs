<div class="navbar">
    <div class="navbar-left">
        <h1 class="navbar-logo"
            style="margin: 0; padding-right: 20px; font-size: 1.25rem; font-weight: bold; color: #1e40af;">RTO LEDGER
        </h1>
        <button type="button" class="navbar-toggle" id="navbarToggle" aria-label="Open menu">
            <span></span>
            <span></span>
            <span></span>
        </button>

        
    </div>

    <div class="navbar-center">
        <form action="/search" method="GET" class="navbar-search">
            <input type="search" name="q" placeholder="Search customers, vehicles, receipts..." aria-label="Search"
                value="<%= typeof query !== 'undefined' ? query : '' %>">
            <button type="submit" class="active">Search</button>
        </form>
    </div>

    <div class="navbar-right">
        <div class="quick-actions">
            <a href="/customers/new" class="action-btn">+ Customer</a>
            <a href="/vehicles/new" class="action-btn">+ Vehicle</a>
            <a href="/services/new" class="action-btn">+ Service</a>
        </div>

        <button type="button" class="theme-toggle" id="themeToggle" aria-label="Toggle theme">🌙</button>

        <div class="user-menu">
            <button type="button" class="user-trigger" id="userMenuButton" aria-expanded="false" aria-haspopup="true">
                <span class="user-greet">Hi, <%= typeof userName !=='undefined' ? userName : 'User' %></span>
                <span class="user-avatar">👤</span>
            </button>
            <div class="user-dropdown" id="userDropdown">
                <a href="/logout">Logout</a>
            </div>
        </div>
    </div>
</div>
