<div id="quickAddModal" class="modal">
    <div class="modal-content" style="max-width: 900px; max-height: 90vh; overflow-y: auto;">
        <div class="modal-header">
            <h2>Quick Add Registration</h2>
            <span class="close-modal" onclick="closeQuickAddModal()">&times;</span>
        </div>

        <form id="quickAddForm" onsubmit="submitQuickAdd(event)">

            <!-- STEP 1: CUSTOMER -->
            <div id="qa-step-1" class="qa-step">
                <h3 style="border-bottom: 1px solid #eee; padding-bottom: 5px;">Step 1: Customer Details</h3>
                <div class="form-row">
                    <div class="form-group">
                        <label>Full Name *</label>
                        <input type="text" id="qa_c_name" placeholder="Enter Customer Name" required>
                    </div>
                    <div class="form-group">
                        <label>Mobile Number *</label>
                        <input type="text" id="qa_c_mobile" maxlength="10" pattern="[0-9]{10}"
                            placeholder="Enter 10 digit Mobile" required>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" id="qa_c_email" placeholder="Enter Email Address">
                    </div>
                    <div class="form-group">
                        <label>Address</label>
                        <textarea id="qa_c_address" rows="1" placeholder="Enter Address"></textarea>
                    </div>
                </div>
                <div style="text-align: right; margin-top: 20px;">
                    <button type="button" class="btn btn-primary" onclick="goToStep(2)">Next: Vehicles &rarr;</button>
                </div>
            </div>

            <!-- STEP 2: VEHICLES -->
            <div id="qa-step-2" class="qa-step" style="display: none;">
                <h3 style="border-bottom: 1px solid #eee; padding-bottom: 5px;">Step 2: Vehicle Details</h3>
                <div id="vehicleContainer"></div>
                <button type="button" class="btn btn-secondary" onclick="addVehicleRow()" style="margin-top: 10px;">+
                    Add Another Vehicle</button>

                <div style="display: flex; justify-content: space-between; margin-top: 20px;">
                    <button type="button" class="btn btn-secondary" onclick="goToStep(1)">&larr; Back</button>
                    <button type="button" class="btn btn-primary" onclick="goToStep(3)">Next: Services &rarr;</button>
                </div>
            </div>

            <!-- STEP 3: SERVICES & PAYMENT -->
            <div id="qa-step-3" class="qa-step" style="display: none;">
                <h3 style="border-bottom: 1px solid #eee; padding-bottom: 5px;">Step 3: Services & Payment</h3>
                <div id="serviceContainer"></div>
                <button type="button" class="btn btn-secondary" onclick="addServiceRow()" style="margin-top: 10px;">+
                    Add Another Service</button>

                <div
                    style="display: flex; justify-content: space-between; align-items: center; margin-top: 30px; border-top: 2px solid #eee; padding-top: 15px;">
                    <button type="button" class="btn btn-secondary" onclick="goToStep(2)">&larr; Back</button>
                    <div style="display: flex; align-items: center; gap: 15px;">
                        <label style="display:flex; align-items:center; gap: 5px; cursor:pointer;">
                            <input type="checkbox" id="qa_print_receipts" checked> <b>Print Receipts after Saving</b>
                        </label>
                        <button type="submit" class="btn btn-primary" style="padding: 10px 25px;">Save
                            Registration</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<script>
    let vIndex = 0;
    let availableServices = [];

    // Fetch services via API
    async function loadServices() {
        try {
            const res = await fetch('/services/api/active');
            const data = await res.json();
            if (data.success) availableServices = data.services;
        } catch (e) { console.error("Failed to load services"); }
    }

    async function openQuickAddModal() {
        document.getElementById('quickAddModal').classList.add('active');
        if (vIndex === 0) {
            await loadServices(); // Trigger fetch and wait
            addVehicleRow();
            addServiceRow();
        }
        goToStep(1);
    }

    function closeQuickAddModal() { document.getElementById('quickAddModal').classList.remove('active'); }

    function goToStep(step) {
        document.querySelectorAll('.qa-step').forEach(el => el.style.display = 'none');
        document.getElementById('qa-step-' + step).style.display = 'block';
    }

    function addVehicleRow() {
        const container = document.getElementById('vehicleContainer');
        const html = `
        <div class="vehicle-row" data-index="${vIndex}" style="background: #f8fafc; border: 1px solid #e2e8f0; padding: 15px; border-radius: 8px; margin-bottom: 15px;">
          <div class="form-row">
            <div class="form-group">
                <label>Vehicle Number *</label>
                <input type="text" class="v_num" name="vehicle_number" id="v_vehicle_number" placeholder="AB 12 CD 1234" required maxlength="13" pattern="^[A-Z]{2}\\s[0-9]{2}\\s[A-Z]{2}\\s[0-9]{4}$" oninput="let v = this.value.toUpperCase().replace(/[^A-Z0-9]/g, ''); if (v.length > 2) v = v.slice(0,2) + ' ' + v.slice(2); if (v.length > 5) v = v.slice(0,5) + ' ' + v.slice(5); if (v.length > 8) v = v.slice(0,8) + ' ' + v.slice(8,12); this.value = v.slice(0, 13);" onchange="updateServiceVehicleDropdowns()" style="text-transform: uppercase; width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px;">
            </div>
            <div class="form-group">
                <label>Vehicle Type *</label>
                <select class="v_type" required>
                    <option value="">Select Vehicle Type</option>
                    <option value="Motor Cycle Without Gear (MCWOG)">Motor Cycle Without Gear (MCWOG)</option>
                    <option value="Motor Cycle With Gear (MCWG)">Motor Cycle With Gear (MCWG)</option>
                    <option value="Light Motor Vehicle (LMV)">Light Motor Vehicle (LMV)</option>
                    <option value="Medium Goods Vehicle (MGV)">Medium Goods Vehicle (MGV)</option>
                    <option value="Heavy Goods Vehicle (HGV)">Heavy Goods Vehicle (HGV)</option>
                </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
                <label>Chassis No.</label>
                <input type="text" class="v_chassis" placeholder="e.g. CH4759857525" maxlength="12" minlength="12" pattern="^CH[A-Z0-9]{10}$" onfocus="if(!this.value) this.value='CH';" oninput="let v = this.value.toUpperCase().replace(/[^A-Z0-9]/g, ''); if (!v.startsWith('CH')) v = 'CH' + v.replace(/^(CH|C)?/, ''); this.value = v.slice(0, 12);" style="text-transform: uppercase;">
            </div>
            <div class="form-group">
                <label>Engine No.</label>
                <input type="text" class="v_engine" placeholder="e.g. EN4252145987" maxlength="12" minlength="12" pattern="^EN[A-Z0-9]{10}$" onfocus="if(!this.value) this.value='EN';" oninput="let v = this.value.toUpperCase().replace(/[^A-Z0-9]/g, ''); if (!v.startsWith('EN')) v = 'EN' + v.replace(/^(EN|E)?/, ''); this.value = v.slice(0, 12);" style="text-transform: uppercase;">
            </div>
            <div class="form-group">
                <label>Registration Date</label>
                <input type="date" class="v_reg_date">
            </div>
          </div>
        </div>`;
        container.insertAdjacentHTML('beforeend', html);
        updateServiceVehicleDropdowns();
        vIndex++;
    }

    function addServiceRow() {
        const container = document.getElementById('serviceContainer');

        let serviceOptions = '<option value="">Select Service</option>';
        availableServices.forEach(s => {
            serviceOptions += `<option value="${s.id}" data-fee="${s.default_fee}">${s.service_name}</option>`;
        });

        const html = `
        <div class="service-row" style="background: #f8fafc; border: 1px solid #e2e8f0; padding: 15px; border-radius: 8px; margin-bottom: 15px;">
          <div class="form-row">
            <div class="form-group">
                <label>Target Vehicle *</label>
                <select class="s_v_index" required><option value="">Select Target Vehicle</option></select>
            </div>
            <div class="form-group">
                <label>Service Name *</label>
                <select class="s_service_id" onchange="autoFillFee(this)" required>
                    ${serviceOptions}
                </select>
            </div>
            <div class="form-group">
                <label>Service Fee (Total Cost) *</label>
                <input type="number" class="s_service_fee" readonly required>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
                <label>Paid Amount *</label>
                <input type="number" class="s_paid_amount" placeholder="0" required>
            </div>
            <div class="form-group">
                <label>Payment Method *</label>
                <select class="s_payment_mode" required>
                    <option value="Cash">Cash</option>
                    <option value="UPI">UPI</option>
                    <option value="Card">Card</option>
                    <option value="Net Banking">Net Banking</option>
                </select>
            </div>
          </div>
        </div>`;
        container.insertAdjacentHTML('beforeend', html);
        updateServiceVehicleDropdowns();
    }

    function autoFillFee(selectElement) {
        const feeInput = selectElement.closest('.service-row').querySelector('.s_service_fee');
        const selectedOption = selectElement.options[selectElement.selectedIndex];
        if (selectedOption && selectedOption.dataset.fee) {
            feeInput.value = selectedOption.dataset.fee;
            // Also default the paid amount to the full fee
            selectElement.closest('.service-row').querySelector('.s_paid_amount').value = selectedOption.dataset.fee;
        } else {
            feeInput.value = '';
        }
    }

    function updateServiceVehicleDropdowns() {
        const vehicles = document.querySelectorAll('.vehicle-row');
        const selects = document.querySelectorAll('.s_v_index');
        selects.forEach(select => {
            const currentVal = select.value;
            select.innerHTML = '<option value="">Select Target Vehicle</option>';
            vehicles.forEach((v, idx) => {
                const vNum = v.querySelector('.v_num').value || `Vehicle ${idx + 1}`;
                select.insertAdjacentHTML('beforeend', `<option value="${v.dataset.index}">${vNum}</option>`);
            });
            select.value = currentVal;
        });
    }

    async function submitQuickAdd(e) {
        e.preventDefault();

        // Wait for all active inputs to properly register
        const payload = {
            customer: {
                name: document.getElementById('qa_c_name').value,
                mobile: document.getElementById('qa_c_mobile').value,
                email: document.getElementById('qa_c_email').value,
                address: document.getElementById('qa_c_address').value
            },
            vehicles: [],
            services: []
        };

        document.querySelectorAll('.vehicle-row').forEach(row => {
            payload.vehicles.push({
                index: row.dataset.index,
                vehicle_number: row.querySelector('.v_num').value,
                vehicle_type: row.querySelector('.v_type').value,
                chassis_number: row.querySelector('.v_chassis').value,
                engine_number: row.querySelector('.v_engine').value,
                registration_date: row.querySelector('.v_reg_date').value || null
            });
        });

        document.querySelectorAll('.service-row').forEach(row => {
            payload.services.push({
                vehicle_index: row.querySelector('.s_v_index').value,
                service_id: row.querySelector('.s_service_id').value,
                service_fee: row.querySelector('.s_service_fee').value,
                paid_amount: row.querySelector('.s_paid_amount').value,
                payment_mode: row.querySelector('.s_payment_mode').value
            });
        });

        const printReceipts = document.getElementById('qa_print_receipts').checked;

        try {
            const res = await fetch('/dashboard/quick-add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await res.json();

            if (data.success) {
                if (printReceipts && data.receipts && data.receipts.length > 0) {
                    // Open receipts in new tabs
                    data.receipts.forEach(id => {
                        window.open('/receipts/' + id, '_blank');
                    });
                }
                alert("Successfully created Registration!");
                window.location.href = '/receipts';
            } else {
                alert("Error: " + data.error);
            }
        } catch (err) {
            alert("Network error.");
        }
    }
</script>