<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'RTO Ledger System' %></title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f5f5f5; }
        nav { background: #1a237e; padding: 12px 24px; display: flex; align-items: center; justify-content: space-between; }
        nav .brand { color: #fff; font-size: 1.3rem; font-weight: bold; text-decoration: none; }
        nav .nav-links { display: flex; gap: 16px; align-items: center; }
        nav .nav-links a { color: #e8eaf6; text-decoration: none; font-size: 0.9rem; padding: 6px 12px; border-radius: 4px; transition: background 0.2s; }
        nav .nav-links a:hover { background: rgba(255,255,255,0.1); }
        .container { max-width: 1200px; margin: 20px auto; padding: 0 20px; }
        .flash-success { background: #c8e6c9; color: #2e7d32; padding: 10px 16px; border-radius: 4px; margin-bottom: 16px; }
        .flash-error { background: #ffcdd2; color: #c62828; padding: 10px 16px; border-radius: 4px; margin-bottom: 16px; }
    </style>
</head>
<body>
    <nav>
        <a href="/dashboard" class="brand">RTO Ledger</a>
        <div class="nav-links">
            <a href="/dashboard">Dashboard</a>
            <a href="/customers">Customers</a>
            <a href="/vehicles">Vehicles</a>
            <a href="/jobs">Jobs</a>
            <a href="/ledger">Ledger</a>
            <a href="/reports">Reports</a>
            <a href="/logout">Logout</a>
        </div>
    </nav>
    <div class="container">
        <% if (typeof messages !== 'undefined') { %>
            <% if (messages.success) { %>
                <div class="flash-success"><%= messages.success %></div>
            <% } %>
            <% if (messages.error) { %>
                <div class="flash-error"><%= messages.error %></div>
            <% } %>
        <% } %>
