<div id="sidebarOverlay" class="sidebar-overlay"></div>
<div class="sidebar" id="appSidebar">

  <ul class="menu">

    <li class="<%= activePage === 'dashboard' ? 'active' : '' %>">
      <a href="/dashboard">
        <span class="menu-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
          </svg>
        </span>
        <span class="menu-label">Dashboard</span>
      </a>
    </li>

    <% if (typeof permissions !=='undefined' && permissions.some(p=> p.startsWith('customer.'))) { %>
    <li class="<%= activePage === 'customers' ? 'active' : '' %>">
      <a href="/customers">
        <span class="menu-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </span>
        <span class="menu-label">Customers</span>
      </a>
    </li>
    <% } %>

    <% if (typeof permissions !=='undefined' && permissions.some(p=> p.startsWith('vehicle.'))) { %>
    <li class="<%= activePage === 'vehicles' ? 'active' : '' %>">
      <a href="/vehicles">
        <span class="menu-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v9a2 2 0 0 1-2 2h-2"/>
            <circle cx="7.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/>
          </svg>
        </span>
        <span class="menu-label">Vehicles</span>
      </a>
    </li>
    <% } %>

    <% if (typeof permissions !=='undefined' && permissions.some(p=> p.startsWith('service.'))) { %>
    <li class="menu-item service-menu <%= (activePage === 'services' || activePage === 'service_requests') ? 'open' : '' %>">
      <a href="#" class="menu-toggle" onclick="toggleServiceMenu(event)">
        <span class="menu-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/>
          </svg>
        </span>
        <span class="menu-label">Services</span>
        <span class="chevron">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </span>
      </a>
      <ul class="submenu">
        <li class="<%= activePage === 'services' ? 'active' : '' %>">
          <a href="/services">
            <span class="submenu-dot"></span>
            Service List
          </a>
        </li>
        <li class="<%= activePage === 'service_requests' ? 'active' : '' %>">
          <a href="/services/requests">
            <span class="submenu-dot"></span>
            Service Requests
          </a>
        </li>
      </ul>
    </li>
    <% } %>

    <% if (typeof permissions !=='undefined' && permissions.some(p=> p.startsWith('ledger.'))) { %>
    <li class="<%= activePage === 'ledger' ? 'active' : '' %>">
      <a href="/ledger">
        <span class="menu-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
        </span>
        <span class="menu-label">Ledger</span>
      </a>
    </li>
    <% } %>

    <% if (typeof permissions !=='undefined' && permissions.some(p=> p.startsWith('receipt.'))) { %>
    <li class="<%= activePage === 'receipts' ? 'active' : '' %>">
      <a href="/receipts">
        <span class="menu-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
            <rect x="6" y="14" width="12" height="8"/>
          </svg>
        </span>
        <span class="menu-label">Receipts</span>
      </a>
    </li>
    <% } %>

    <% if (typeof permissions !=='undefined' && permissions.includes('role.manage')) { %>
    <hr class="sidebar-divider">
    <li class="<%= activePage === 'roles' ? 'active' : '' %>">
      <a href="/admin/roles">
        <span class="menu-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </span>
        <span class="menu-label">Roles & Permissions</span>
      </a>
    </li>
    <% } %>

    <% if (typeof permissions !=='undefined' && permissions.includes('user.manage')) { %>
    <li class="<%= activePage === 'admin' ? 'active' : '' %>">
      <a href="/admin/users">
        <span class="menu-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="4"/>
            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
            <path d="M18 14l2 2 4-4" stroke-width="2"/>
          </svg>
        </span>
        <span class="menu-label">Users & Permissions</span>
      </a>
    </li>
    <% } %>

  </ul>

</div>

<script>
  function toggleServiceMenu(event) {
    event.preventDefault();
    const menu = event.target.closest(".service-menu");
    menu.classList.toggle("open");
  }

  // Auto-open if a sub-page is active
  document.addEventListener("DOMContentLoaded", () => {
    const serviceMenu = document.querySelector(".service-menu");
    if (serviceMenu && serviceMenu.classList.contains("open")) {
      // already handled via class in EJS
    }

    // Mobile Sidebar Toggle
    const mobileToggleBtn = document.getElementById("mobileSidebarToggle");
    const sidebar = document.getElementById("appSidebar");
    const overlay = document.getElementById("sidebarOverlay");

    function closeSidebar() {
      if(sidebar) sidebar.classList.remove("show");
      if(overlay) overlay.classList.remove("show");
    }

    if (mobileToggleBtn && sidebar && overlay) {
      mobileToggleBtn.addEventListener("click", () => {
        sidebar.classList.toggle("show");
        overlay.classList.toggle("show");
      });
      
      overlay.addEventListener("click", closeSidebar);
    }
  });
</script>
