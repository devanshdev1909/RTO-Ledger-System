<!-- Request Modal -->
<div id="requestCreateModal" class="modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; overflow-y:auto;">
  <div class="modal-content" style="background:white; max-width:600px; margin:5vh auto; padding:25px; border-radius:8px; position:relative;">
    <h2 id="requestModalTitle">Create Service Request</h2>
    <form id="requestForm" action="/portal/my-requests" method="POST">
      <!-- Hidden Customer ID (portal user) -->
      <input type="hidden" name="customer_id" value="<%= customerId %>">
      <!-- Vehicle Selection (filtered) -->
      <div class="form-group" style="margin-bottom:15px;">
        <label for="request_vehicle_id">Vehicle <span style="color:red;">*</span></label>
        <select name="vehicle_id" id="request_vehicle_id" required style="width:100%; padding:8px; border:1px solid #ccc; border-radius:4px;">
          <option value="">-- Select Vehicle --</option>
        </select>
      </div>
      <!-- Service Selection -->
      <div class="form-group" style="margin-bottom:15px;">
        <label for="request_service_id">Service <span style="color:red;">*</span></label>
        <select name="service_id" id="request_service_id" required style="width:100%; padding:8px; border:1px solid #ccc; border-radius:4px;">
          <option value="">-- Select Service --</option>
          <% services.forEach(s => { %>
            <option value="<%= s.id %>" data-fee="<%= s.default_fee %>"><%= s.service_name %></option>
          <% }) %>
        </select>
      </div>
      <!-- Amount (auto‑filled) -->
      <div class="form-group" style="margin-bottom:15px;">
        <label for="request_amount">Amount (₹) <span style="color:red;">*</span></label>
        <input type="number" name="amount" id="request_amount" readonly required style="width:100%; padding:8px; border:1px solid #ccc; border-radius:4px;" />
      </div>
      <!-- Remarks -->
      <div class="form-group" style="margin-bottom:15px;">
        <label for="request_remarks">Remarks</label>
        <textarea name="remarks" id="request_remarks" rows="2" style="width:100%; padding:8px; border:1px solid #ccc; border-radius:4px;"></textarea>
      </div>
      <div style="display:flex; justify-content:flex-end; gap:10px;">
        <button type="button" class="btn btn-secondary" onclick="closeRequestCreateModal()">Cancel</button>
        <button type="submit" class="btn btn-primary">Create Request</button>
      </div>
    </form>
    <span class="close-modal" onclick="closeRequestCreateModal()" style="position:absolute; top:10px; right:15px; cursor:pointer; font-size:20px;">&times;</span>
  </div>
</div>

<script>
  // Store all vehicles for the logged‑in customer (already filtered server‑side)
  const allVehicles = <%- JSON.stringify(vehicles) %>;

  function openRequestCreateModal() {
    document.getElementById('requestCreateModal').style.display = 'block';
    // Reset form
    document.getElementById('requestForm').reset();
    // Populate vehicle dropdown with customer's vehicles
    const vehicleSelect = document.getElementById('request_vehicle_id');
    vehicleSelect.innerHTML = '<option value="">-- Select Vehicle --</option>';
    allVehicles.forEach(v => {
      const opt = document.createElement('option');
      opt.value = v.id;
      opt.textContent = v.vehicle_number || `Vehicle ${v.id}`;
      vehicleSelect.appendChild(opt);
    });
    document.getElementById('request_amount').value = '';
  }

  function closeRequestCreateModal() {
    document.getElementById('requestCreateModal').style.display = 'none';
  }

  // No customer select needed; vehicles already filtered

  // Auto‑fill amount when a service is selected
  document.getElementById('request_service_id').addEventListener('change', function () {
    const fee = this.options[this.selectedIndex].dataset.fee || '';
    document.getElementById('request_amount').value = fee;
  });

  // Close modal when clicking outside of content
  window.addEventListener('click', function(e) {
    const modal = document.getElementById('requestCreateModal');
    if (e.target === modal) {
      closeRequestCreateModal();
    }
  });
</script>
