<% if (typeof totalPages !=="undefined" && totalPages> 1) { %>
    <div class="pagination-container"
        style="margin-top: 10px; margin-bottom: 4px; display: flex; justify-content: center; align-items: center; gap: 10px;">
        <% const buildUrl=(pageNum)=> {
            const params = new URLSearchParams(queryParams || {});
            params.set('page', pageNum);
            return queryPath + '?' + params.toString();
            }
            %>

            <% if (currentPage> 1) { %>
                <a href="<%= buildUrl(currentPage - 1) %>"
                    style="padding: 3px 14px; border-radius: 4px; text-decoration: none; font-size: 13px; color: #fff; background-color: #4f46e5;">Previous</a>
                <% } else { %>
                    <button disabled
                        style="padding: 3px 14px; border-radius: 4px; font-size: 13px; opacity: 0.6; cursor: not-allowed; color: #fff; background-color: #4f46e5; border: none;">Previous</button>
                    <% } %>

                        <span style="font-size: 14px; font-weight: 500; color: #374151;">Page <%= currentPage %> of <%=
                                    totalPages %></span>

                        <% if (currentPage < totalPages) { %>
                            <a href="<%= buildUrl(currentPage + 1) %>"
                                style="padding: 3px 14px; border-radius: 4px; text-decoration: none; font-size: 13px; color: #fff; background-color: #4f46e5;">Next</a>
                            <% } else { %>
                                <button disabled
                                    style="padding: 3px 14px; border-radius: 4px; font-size: 13px; opacity: 0.6; cursor: not-allowed; color: #fff; background-color: #4f46e5; border: none;">Next</button>
                                <% } %>
    </div>
    <% } %>