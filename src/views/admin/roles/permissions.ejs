<%- include("../../partials/header") %>

<div class="container">
  <%- include("../../partials/sidebar") %>

  <div class="main-content">
    <%- include("../../partials/navbar") %>

    <div class="content">

      <div style="
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:20px;
">
        <h1 style="margin:0;">
          Manage Permissions: <%= role.name %>
        </h1>

        <a href="/admin/roles" class="btn btn-secondary">
          ← Back to Roles
        </a>
      </div>

      <div style="
    background:white;
    max-width:800px;
    margin:0 auto;
    padding:25px;
    border-radius:8px;
    border:1px solid #e5e7eb;
">
        <form action="/admin/roles/<%= role.id %>/permissions" method="POST">

          <div style="
            display:grid;
            grid-template-columns:repeat(auto-fill,minmax(250px,1fr));
            gap:15px;
            margin-bottom:25px;
        ">
            <% allPermissions.forEach(p => { %>

            <div style="
                border:1px solid #eaeaea;
                padding:15px;
                border-radius:6px;
                display:flex;
                align-items:flex-start;
                gap:10px;
            ">
              <input type="checkbox" id="perm_<%= p.id %>" name="permissions" value="<%= p.id %>" <%= currentPermissions.includes(parseInt(p.id)) ? 'checked' : '' %> style="
                        margin-top:4px;
                        transform:scale(1.2);
                    ">

              <div>
                <label for="perm_<%= p.id %>" style="
                            font-weight:600;
                            cursor:pointer;
                            display:block;
                            margin-bottom:2px;
                        ">
                  <%= p.code %>
                </label>

                <span style="
                        font-size:0.85rem;
                        color:#666;
                    ">
                  <%= p.description || 'No description' %>
                </span>
              </div>
            </div>

            <% }) %>
          </div>

          <div style="
            display:flex;
            justify-content:flex-end;
            gap:10px;
        ">
            <a href="/admin/roles" class="btn btn-secondary">
              Cancel
            </a>

            <button type="submit" class="btn btn-primary">
              Save Permissions
            </button>
          </div>

        </form>
      </div>

    </div>
  </div>
</div>

<%- include("../../partials/footer") %>