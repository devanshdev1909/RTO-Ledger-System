<%- include("../../partials/header") %>

    <div class="container">
        <%- include("../../partials/sidebar") %>

            <div class="main-content">
                <%- include("../../partials/navbar") %>

                    <div class="content">

                        <% if (locals.error) { %>
                            <div
                                style="background-color: #ffdddd; color: #d8000c; padding: 12px 20px; margin-bottom: 20px; border-radius: 6px; font-size: 14px;">
                                <%= error %>
                            </div>
                            <% } %>

                                <div class="page-header"
                                    style="display: flex; justify-content: space-between; align-items: center;">
                                    <h1>Roles & Permissions</h1>
                                    <button onclick="document.getElementById('roleModal').style.display='block'"
                                        class="btn btn-primary">+ Add Role</button>
                                </div>

                                <div class="table-container">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th style="width: 25%; text-align: center;">Role Name</th>
                                                <th style="width: 55%; text-align: center;">Description</th>
                                                <th style="width: 20%; text-align: center;">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% roles.forEach(role=> { %>
                                                <tr>
                                                    <td style="text-align: center;"><strong>
                                                            <%= role.name %>
                                                        </strong></td>
                                                    <td style="text-align: center;">
                                                        <%= role.description || "—" %>
                                                    </td>
                                                    <td class="actions"
                                                        style="text-align: center;gap: 25px; margin-left: 25px;">
                                                        <button type="button" class="btn btn-primary"
                                                            style="font-size: 1rem;"
                                                            onclick="openPermissionsModal('<%= role.id %>', '<%= role.name %>', '<%= JSON.stringify(role.currentPermissions) %>')">
                                                            Manage Permissions
                                                        </button>

                                                        <form action="/admin/roles/<%= role.id %>/delete" method="POST"
                                                            onsubmit="return confirm('Delete this role?');"
                                                            style="margin:0;">
                                                            <button type="submit" class="btn-icon delete-icon"
                                                                title="Delete Role"
                                                                onclick="return confirm('Are you sure?')">

                                                                <svg xmlns="http://www.w3.org/2000/svg"
                                                                    viewBox="0 0 24 24" fill="none"
                                                                    stroke="currentColor" stroke-width="2"
                                                                    stroke-linecap="round" stroke-linejoin="round">

                                                                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                                                    <path d="M4 7l16 0" />
                                                                    <path d="M10 11l0 6" />
                                                                    <path d="M14 11l0 6" />
                                                                    <path
                                                                        d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" />
                                                                    <path
                                                                        d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" />

                                                                </svg>

                                                            </button>
                                                        </form>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                        </tbody>
                                    </table>
                                </div>

                    </div>
            </div>
    </div>

    <!-- Add Role Modal -->
    <div id="roleModal"
        style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000;">
        <div style="background:white; max-width:400px; margin: 100px auto; padding: 20px; border-radius: 8px;">
            <h2>Add New Role</h2>
            <form action="/admin/roles" method="POST">
                <div class="form-group" style="margin-top: 15px;">
                    <label>Role Name *</label>
                    <input type="text" name="role_name" required
                        style="width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px;">
                </div>
                <div class="form-group" style="margin-top: 15px;">
                    <label>Description</label>
                    <textarea name="description" rows="3"
                        style="width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px;"></textarea>
                </div>
                <div style="margin-top: 20px; display: flex; gap: 10px; justify-content: flex-end;">
                    <button type="button" onclick="document.getElementById('roleModal').style.display='none'"
                        class="btn btn-secondary">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Role</button>
                </div>
            </form>
        </div>
    </div>
    <!-- Manage Permissions Modal -->
    <div id="permissionsModal"
        style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; overflow-y: auto;">
        <div style="background:white; max-width:800px; margin: 10vh auto; padding: 25px; border-radius: 8px;">
            <h2 id="permModalTitle">Manage Permissions</h2>
            <form id="permForm" action="" method="POST">

                <div
                    style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 15px; margin: 20px 0;">
                    <% allPermissions.forEach(p=> { %>
                        <div
                            style="border: 1px solid #eaeaea; padding: 15px; border-radius: 6px; display: flex; align-items: flex-start; gap: 10px;">
                            <input type="checkbox" id="perm_<%= p.id %>" class="perm-checkbox" name="permissions"
                                value="<%= p.id %>" style="margin-top: 4px; transform: scale(1.2);">
                            <div>
                                <label for="perm_<%= p.id %>"
                                    style="font-weight: 600; cursor: pointer; display: block; margin-bottom: 2px;">
                                    <%= p.code %>
                                </label>
                                <span style="font-size: 0.85rem; color: #666;">
                                    <%= p.description || 'No description' %>
                                </span>
                            </div>
                        </div>
                        <% }) %>
                </div>

                <div style="display: flex; gap: 10px; justify-content: flex-end;">
                    <button type="button" onclick="document.getElementById('permissionsModal').style.display='none'"
                        class="btn btn-secondary">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Permissions</button>
                </div>

            </form>
        </div>
    </div>
    <script>
        function openPermissionsModal(roleId, roleName, currentPermsStr) {
            document.getElementById('permissionsModal').style.display = 'block';
            document.getElementById('permModalTitle').innerText = 'Manage Permissions: ' + roleName;
            document.getElementById('permForm').action = '/admin/roles/' + roleId + '/permissions';

            // Parse the stringified array back to a Javascript array
            const currentPerms = JSON.parse(currentPermsStr);

            // Loop through all checkboxes and check the ones this role has
            document.querySelectorAll('.perm-checkbox').forEach(cb => {
                cb.checked = currentPerms.includes(parseInt(cb.value, 10));
            });
        }
    </script>

    <%- include("../../partials/footer") %>