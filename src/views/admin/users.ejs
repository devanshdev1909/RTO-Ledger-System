<%- include("../partials/header") %>
<div class="container">
  <%- include("../partials/sidebar") %>
  <div class="main-content">
    <%- include("../partials/navbar") %>
    <div class="content">
      <% if (locals.error) { %>
      <div style="background-color: #ffdddd; color: #d8000c; padding: 12px 20px; margin-bottom: 20px; border-radius: 6px; font-size: 14px;">
        <% if (error==='CannotDeleteUserInUse' ) { %>
        Cannot delete this user because they are referenced in other records.
        <% } else if (error==='CannotDeleteSelf' ) { %>
        You cannot delete your own account.
        <% } else if (error==='FailedToDeleteUser' ) { %>
        Failed to delete user.
        <% } else if (error==='UsernameOrEmailExists' ) { %>
        Username or email already exists.
        <% } else if (error==='FailedToCreateUser' ) { %>
        Failed to create user.
        <% } else { %>
        <%= error %>
        <% } %>
      </div>
      <% } %>
      <div class="page-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h1>User Management (RBAC)</h1>
        <% if (permissions.includes('user.manage')) { %>
        <button onclick="document.getElementById('userModal').style.display='block'" class="btn btn-primary">+ Add User</button>
        <% } %>
      </div>
      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th style="width: 25%; text-align: center; background-color:#203051; color:white; font-size:16px;">Username</th>
              <th style="width: 25%; text-align: center; background-color:#203051; color:white; font-size:16px;">Email</th>
              <th style="width: 25%; text-align: center; background-color:#203051; color:white; font-size:16px;">Role</th>
              <th style="width: 25%; text-align: center; background-color:#203051; color:white; font-size:16px;">Status</th>
              <th style="width: 25%; text-align: center; background-color:#203051; color:white; font-size:16px;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(u=> { %>
            <tr>
              <td style="text-align: center;">
                <%= u.username %>
              </td>
              <td style="text-align: center;">
                <%= u.email %>
              </td>
              <td style="text-align: center;">
                <%= u.role_name %>
              </td>
              <td style="text-align: center;">
                <div class="status-container">
                  <span class="status-text <%= u.is_active !== false ? 'active' : 'inactive' %>">
                    <%= u.is_active !==false ? 'Active' : 'Inactive' %>
                  </span>
                  <% if (permissions.includes('user.manage')) { %>
                  <label class="switch">
                    <input type="checkbox" class="status-toggle" data-id="<%= u.id %>" <%=u.is_active !==false
                                                                    ? 'checked' : '' %>>
                    <span class="slider"></span>
                  </label>
                  <% } %>
                </div>
              </td>
              <td class="actions" style="text-align: center;gap: 25px; margin-left: 25px;">
                <% if (permissions.includes('user.manage')) { %>
                <button type="button" class="btn btn-primary" style="padding: 13px 18px; font-size: 0.85rem; display: flex; align-items: center;" onclick="openUserPermissionsModal('<%= u.id %>', '<%= u.username %>', '<%= JSON.stringify(u.currentPermissions) %>')">
                  Manage Permissions
                </button>
                <form action="/admin/users/<%= u.id %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this user? This action cannot be undone.');">
                  <button type="submit" class="btn-icon delete-icon" title="Delete User" onclick="return confirm('Are you sure?')">

                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">

                      <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                      <path d="M4 7l16 0" />
                      <path d="M10 11l0 6" />
                      <path d="M14 11l0 6" />
                      <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" />
                      <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" />

                    </svg>

                  </button>
                </form>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- Add User Modal -->
<!-- Add User Modal -->
<div id="userModal" style="
        display:none;
        position:fixed;
        top:0;
        left:0;
        width:100%;
        height:100%;
        background:rgba(0,0,0,0.5);
        z-index:1000;
        overflow-y:auto;
    ">
  <div style="
        background:white;
        width:90%;
        max-width:600px;
        margin:10vh auto;
        padding:25px;
        border-radius:8px;
        position:relative;
    ">
    <!-- Header -->
    <div style="
            display:flex;
            justify-content:space-between;
            align-items:center;
            margin-bottom:20px;
        ">
      <h2 style="margin:0;">Add New User</h2>
      <button type="button" onclick="document.getElementById('userModal').style.display='none'" style="
                    background:none;
                    border:none;
                    font-size:28px;
                    cursor:pointer;
                    color:#888;
                    line-height:1;
                ">
        ×
      </button>
    </div>
    <form action="/admin/users" method="POST">
      <div style="margin-bottom:15px;">
        <label style="display:block;margin-bottom:5px;">
          Username *
        </label>
        <input type="text" name="username" required style="
                        width:100%;
                        padding:10px;
                        border:1px solid #ccc;
                        border-radius:4px;
                        box-sizing:border-box;
                    ">
      </div>
      <div style="margin-bottom:15px;">
        <label style="display:block;margin-bottom:5px;">
          Email *
        </label>
        <input type="email" name="email" required style="
                        width:100%;
                        padding:10px;
                        border:1px solid #ccc;
                        border-radius:4px;
                        box-sizing:border-box;
                    ">
      </div>
      <div style="margin-bottom:15px; position:relative;">
        <label style="display:block;margin-bottom:5px;">
          Password *
        </label>
        <input type="password" id="modalPassword" name="password" required style="
                        width:100%;
                        padding:10px;
                        padding-right:45px;
                        border:1px solid #ccc;
                        border-radius:4px;
                        box-sizing:border-box;
                    ">
        <button type="button" onclick="togglePassword('modalPassword','modalEyeIcon')" style="
                        position:absolute;
                        right:12px;
                        top:38px;
                        border:none;
                        background:none;
                        cursor:pointer;
                        color:#6b7280;
                    ">
          <svg id="modalEyeIcon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8"></path>
            <circle cx="12" cy="12" r="3"></circle>
          </svg>
        </button>
      </div>
      <div style="margin-bottom:20px;">
        <label style="display:block;margin-bottom:5px;">
          Role *
        </label>
        <select name="role_id" required style="
                        width:100%;
                        padding:10px;
                        border:1px solid #ccc;
                        border-radius:4px;
                        box-sizing:border-box;
                    ">
          <% if (typeof roles !== 'undefined') { %>
          <% roles.forEach(r => { %>
          <option value="<%= r.id %>">
            <%= r.name %>
          </option>
          <% }) %>
          <% } %>
        </select>
      </div>
      <div style="
                display:flex;
                justify-content:flex-end;
                gap:10px;
            ">
        <button type="button" class="btn btn-secondary" onclick="document.getElementById('userModal').style.display='none'">
          Cancel
        </button>
        <button type="submit" class="btn btn-primary">
          Create User
        </button>
      </div>
    </form>
  </div>
</div>
<!-- Manage User Permissions Modal -->
<div id="userPermissionsModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; overflow-y: auto;">
  <div style="background:white; max-width:800px; margin: 10vh auto; padding: 25px; border-radius: 8px;">
    <h2 id="userPermModalTitle">Customize User Access</h2>
    <form id="userPermForm" action="" method="POST">

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 15px; margin: 20px 0;">
        <% allPermissions.forEach(p=> { %>
        <div style="border: 1px solid #eaeaea; padding: 15px; border-radius: 6px; display: flex; align-items: flex-start; gap: 10px;">
          <!-- Note: name MUST be "permission_ids" to match the user controller! -->
          <input type="checkbox" id="user_perm_<%= p.id %>" class="user-perm-checkbox" name="permission_ids" value="<%= p.id %>" style="margin-top: 4px; transform: scale(1.2);">
          <div>
            <label for="user_perm_<%= p.id %>" style="font-weight: 600; cursor: pointer; display: block; margin-bottom: 2px;">
              <%= p.code %>
            </label>
            <span style="font-size: 0.85rem; color: #666;">
              <%= p.description || 'No description' %>
            </span>
          </div>
        </div>
        <% }) %>
      </div>

      <div style="display: flex; gap: 10px; justify-content: flex-end;">
        <button type="button" onclick="document.getElementById('userPermissionsModal').style.display='none'" class="btn btn-secondary">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>

    </form>
  </div>
</div>

<script>
  function togglePassword(inputId, iconId) {
    const input = document.getElementById(inputId);
    const icon = document.getElementById(iconId);
    if (input.type === 'password') {
      input.type = 'text';
      icon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line>';
    } else {
      input.type = 'password';
      icon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>';
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".status-toggle").forEach(toggle => {
      toggle.addEventListener("change", async (e) => {
        const id = e.target.getAttribute("data-id");
        const isChecked = e.target.checked;
        const statusText = e.target.closest(".status-container").querySelector(".status-text");

        try {
          const response = await fetch(`/admin/users/${id}/toggle-status`, {
            method: "PATCH",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify({
              is_active: isChecked
            })
          });
          const result = await response.json();
          if (!result.success) {
            alert("Error updating status: " + result.error);
            e.target.checked = !isChecked;
          } else {
            // Update text and class color
            if (isChecked) {
              statusText.textContent = "Active";
              statusText.className = "status-text active";
            } else {
              statusText.textContent = "Inactive";
              statusText.className = "status-text inactive";
            }
          }
        } catch (error) {
          alert("Network error updating status.");
          e.target.checked = !isChecked;
        }
      });
    });
  });

  function openUserPermissionsModal(userId, username, currentPermsStr) {
    document.getElementById('userPermissionsModal').style.display = 'block';
    document.getElementById('userPermModalTitle').innerText = 'Manage Permissions: ' + username;
    document.getElementById('userPermForm').action = '/admin/users/' + userId + '/permissions';

    // Parse the stringified array
    const currentPerms = JSON.parse(currentPermsStr);

    // Loop through all checkboxes and check the ones this user has
    document.querySelectorAll('.user-perm-checkbox').forEach(cb => {
      cb.checked = currentPerms.includes(parseInt(cb.value, 10));
    });
  }
  window.addEventListener('click', function(e) {
    const modal = document.getElementById('userPermissionsModal');

    if (e.target === modal) {
      modal.style.display = 'none';
    }
  });
  window.addEventListener('click', function(e) {
    const modal = document.getElementById('userModal');

    if (e.target === modal) {
      modal.style.display = 'none';
    }
  });
</script>

<%- include("../partials/footer") %>