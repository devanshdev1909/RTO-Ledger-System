<%- include("../partials/header") %>
    <div class="container">
        <%- include("../partials/sidebar") %>
            <div class="main-content">
                <%- include("../partials/navbar") %>
                    <div class="content">
                        <% if (locals.error) { %>
                            <div
                                style="background-color: #ffdddd; color: #d8000c; padding: 12px 20px; margin-bottom: 20px; border-radius: 6px; font-size: 14px;">
                                <% if (error==='CannotDeleteUserInUse' ) { %>
                                    Cannot delete this user because they are referenced in other records.
                                    <% } else if (error==='CannotDeleteSelf' ) { %>
                                        You cannot delete your own account.
                                        <% } else if (error==='FailedToDeleteUser' ) { %>
                                            Failed to delete user.
                                            <% } else if (error==='UsernameOrEmailExists' ) { %>
                                                Username or email already exists.
                                                <% } else if (error==='FailedToCreateUser' ) { %>
                                                    Failed to create user.
                                                    <% } else { %>
                                                        <%= error %>
                                                            <% } %>
                            </div>
                            <% } %>
                                <div class="page-header"
                                    style="display: flex; justify-content: space-between; align-items: center;">
                                    <h1>User Management (RBAC)</h1>
                                    <button onclick="document.getElementById('userModal').style.display='block'"
                                        class="btn btn-primary">+ Add User</button>
                                </div>
                                <div class="table-container">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th style="width: 25%; text-align: center;">Username</th>
                                                <th style="width: 25%; text-align: center;">Email</th>
                                                <th style="width: 25%; text-align: center;">Role</th>
                                                <th style="width: 25%; text-align: center;">Status</th>
                                                <th style="width: 25%; text-align: center;">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% users.forEach(u=> { %>
                                                <tr>
                                                    <td style="text-align: center;">
                                                        <%= u.username %>
                                                    </td>
                                                    <td style="text-align: center;">
                                                        <%= u.email %>
                                                    </td>
                                                    <td style="text-align: center;">
                                                        <%= u.role_name %>
                                                    </td>
                                                    <td style="text-align: center;">
                                                        <div class="status-container">
                                                            <span
                                                                class="status-text <%= u.is_active !== false ? 'active' : 'inactive' %>">
                                                                <%= u.is_active !==false ? 'Active' : 'Inactive' %>
                                                            </span>
                                                            <label class="switch">
                                                                <input type="checkbox" class="status-toggle"
                                                                    data-id="<%= u.id %>" <%=u.is_active !==false
                                                                    ? 'checked' : '' %>>
                                                                <span class="slider"></span>
                                                            </label>
                                                        </div>
                                                    </td>
                                                    <td class="actions"
                                                        style="text-align: center;gap: 25px; margin-left: 25px;">
                                                        <a href="/admin/users/<%= u.id %>/permissions"
                                                            class="btn btn-primary"
                                                            style="padding: 13px 18px; font-size: 0.85rem; text-decoration: none; display: flex; align-items: center;">Manage
                                                            Permissions</a>
                                                        <form action="/admin/users/<%= u.id %>?_method=DELETE"
                                                            method="POST" style="display:inline;"
                                                            onsubmit="return confirm('Are you sure you want to delete this user? This action cannot be undone.');">
                                                            <button type="submit" class="btn-icon delete-icon"
                                                                title="Delete User"
                                                                onclick="return confirm('Are you sure?')">

                                                                <svg xmlns="http://www.w3.org/2000/svg"
                                                                    viewBox="0 0 24 24" fill="none"
                                                                    stroke="currentColor" stroke-width="2"
                                                                    stroke-linecap="round" stroke-linejoin="round">

                                                                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                                                    <path d="M4 7l16 0" />
                                                                    <path d="M10 11l0 6" />
                                                                    <path d="M14 11l0 6" />
                                                                    <path
                                                                        d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" />
                                                                    <path
                                                                        d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" />

                                                                </svg>

                                                            </button>
                                                        </form>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                    </div>
            </div>
    </div>

    <!-- Add User Modal -->
    <div id="userModal"
        style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000;">
        <div style="background:white; max-width:400px; margin: 100px auto; padding: 20px; border-radius: 8px;">
            <h2>Add New User</h2>
            <form action="/admin/users" method="POST">
                <div class="form-group" style="margin-top: 15px;">
                    <label>Username *</label>
                    <input type="text" name="username" required
                        style="width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px;">
                </div>
                <div class="form-group" style="margin-top: 15px;">
                    <label>Email *</label>
                    <input type="email" name="email" required
                        style="width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px;">
                </div>
                <div class="form-group" style="margin-top: 15px; position: relative;">
                    <label>Password *</label>
                    <input type="password" id="modalPassword" name="password" required
                        style="width: 100%; padding: 8px; padding-right: 40px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px;">
                    <button type="button" onclick="togglePassword('modalPassword', 'modalEyeIcon')"
                        style="position: absolute; right: 10px; top: 35px; background: none; border: none; cursor: pointer; color: #6b7280; padding: 0; display: flex; align-items: center; justify-content: center;">
                        <svg id="modalEyeIcon" style="margin: 10%;" xmlns="http://www.w3.org/2000/svg" width="20"
                            height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                            stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                        </svg>
                    </button>
                </div>
                <div class="form-group" style="margin-top: 15px;">
                    <label>Role *</label>
                    <select name="role_id" required
                        style="width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px;">
                        <% if (typeof roles !=='undefined' ) { %>
                            <% roles.forEach(r=> { %>
                                <option value="<%= r.id %>">
                                    <%= r.name %>
                                </option>
                                <% }) %>
                                    <% } %>
                    </select>
                </div>
                <div style="margin-top: 20px; display: flex; gap: 10px; justify-content: flex-end;">
                    <button type="button" onclick="document.getElementById('userModal').style.display='none'"
                        class="btn btn-secondary">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create User</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line>';
            } else {
                input.type = 'password';
                icon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>';
            }
        }

        document.addEventListener("DOMContentLoaded", () => {
            document.querySelectorAll(".status-toggle").forEach(toggle => {
                toggle.addEventListener("change", async (e) => {
                    const id = e.target.getAttribute("data-id");
                    const isChecked = e.target.checked;
                    const statusText = e.target.closest(".status-container").querySelector(".status-text");

                    try {
                        const response = await fetch(`/admin/users/${id}/toggle-status`, {
                            method: "PATCH",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ is_active: isChecked })
                        });
                        const result = await response.json();
                        if (!result.success) {
                            alert("Error updating status: " + result.error);
                            e.target.checked = !isChecked;
                        } else {
                            // Update text and class color
                            if (isChecked) {
                                statusText.textContent = "Active";
                                statusText.className = "status-text active";
                            } else {
                                statusText.textContent = "Inactive";
                                statusText.className = "status-text inactive";
                            }
                        }
                    } catch (error) {
                        alert("Network error updating status.");
                        e.target.checked = !isChecked;
                    }
                });
            });
        });
    </script>

    <%- include("../partials/footer") %>