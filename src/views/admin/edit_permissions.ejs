<%- include("../partials/header") %>
<div class="container">
    <%- include("../partials/sidebar") %>
    <div class="main-content">
        <%- include("../partials/navbar") %>
        <div class="content">
            <div class="page-header">
                <h1>Manage Permissions: <%= user.username %></h1>
                <a href="/admin/users" class="btn btn-secondary">← Back</a>
            </div>
            <div class="form-card" style="max-width: 700px;">
                <form action="/admin/users/<%= user.id %>/permissions" method="POST">
                    <h3 style="margin-bottom: 20px;">Customize User Access:</h3>
                    
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 30px;">
                        <% permissions.forEach(p => { %>
                        <div class="form-group" style="display: flex; align-items: center; gap: 10px; margin-bottom: 0;">
                            <input type="checkbox" name="permission_ids" value="<%= p.id %>" id="perm_<%= p.id %>"
                                style="width: auto; cursor: pointer;"
                                <%= checkedPermissionIds.includes(String(p.id)) ? 'checked' : '' %>>
                            <label for="perm_<%= p.id %>" style="display: inline; margin-bottom: 0; cursor: pointer; font-weight: normal;">
                                <strong><%= p.code %></strong><br>
                                <span style="font-size: 0.8rem; color: #6b7280;"><%= p.description %></span>
                            </label>
                        </div>
                        <% }) %>
                    </div>

                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </form>
            </div>
        </div>
    </div>
</div>
<%- include("../partials/footer") %>
