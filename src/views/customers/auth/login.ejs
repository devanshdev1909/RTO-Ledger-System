<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RTO Ledger - Login</title>
    <link rel="stylesheet" href="/css/login.css">
</head>

<body>

    <div class="background-shape shape-1"></div>
    <div class="background-shape shape-2"></div>

    <div class="login-container">

        <div class="login-card">

            <div class="logo-section">
                <div class="logo-icon">🚗</div>
                <h1>RTO Ledger</h1>
                <p>Customer, Vehicle, Service, Ledger & Receipt Management System</p>
            </div>

            <div class="tabs">
                <button class="tab-btn <%= locals.activeTab === 'customer' ? '' : 'active' %>"
                    onclick="switchTab('staff')">Staff</button>
                <button class="tab-btn <%= locals.activeTab === 'customer' ? 'active' : '' %>"
                    onclick="switchTab('customer')">Customer</button>
            </div>

            <% if (locals.error) { %>
                <div
                    style="background-color: #ffdddd; color: #d8000c; padding: 12px 35px; font-size: 14px; text-align: center; border-bottom: 1px solid #ffcccc;">
                    <%= error %>
                </div>
                <% } %>

                    <!-- STAFF LOGIN FORM -->
                    <form id="staff-form" class="form-content <%= locals.activeTab === 'customer' ? '' : 'active' %>"
                        action="/login" method="POST">
                        <div class="form-group">
                            <label>Email Address</label>
                            <input type="email" name="email" placeholder="Enter your email" required>
                        </div>
                        <div class="form-group" style="position: relative;">
                            <label>Password</label>
                            <input type="password" id="staffPassword" name="password" placeholder="Enter your password"
                                required style="padding-right: 40px;">
                            <button type="button" onclick="togglePassword('staffPassword', 'staffEyeIcon')"
                                style="position: absolute; right: 10px; top: 38px; background: none; border: none; cursor: pointer; color: #6b7280; padding: 0; display: flex; align-items: center; justify-content: center;">
                                <svg id="staffEyeIcon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                                    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                    stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                    <circle cx="12" cy="12" r="3"></circle>
                                </svg>
                            </button>
                        </div>
                        <button type="submit" class="login-btn">Login as Staff</button>
                    </form>

                    <!-- CUSTOMER LOGIN FORM -->
                    <form id="customer-form" class="form-content <%= locals.activeTab === 'customer' ? 'active' : '' %>"
                        action="/portal/login" method="POST">
                        <div class="form-group">
                            <label>Email or Mobile Number</label>
                            <input type="text" name="identifier" placeholder="Enter email or mobile" required>
                        </div>
                        <div class="form-group" style="position: relative;">
                            <label>Password</label>
                            <input type="password" id="customerPassword" name="password"
                                placeholder="Enter your password" required style="padding-right: 40px;">
                            <button type="button" onclick="togglePassword('customerPassword', 'customerEyeIcon')"
                                style="position: absolute; right: 10px; top: 38px; background: none; border: none; cursor: pointer; color: #6b7280; padding: 0; display: flex; align-items: center; justify-content: center;">
                                <svg id="customerEyeIcon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                                    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                    stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                    <circle cx="12" cy="12" r="3"></circle>
                                </svg>
                            </button>
                        </div>
                        <button type="submit" class="login-btn" style="background-color: #10b981;">Login as
                            Customer</button>

                        <div class="customer-register-link">
                            Don't have an account? <a href="/portal/register">Register here</a>
                        </div>
                    </form>

                    <div class="footer-text">
                        RTO Ledger Management System © 2026
                    </div>

        </div>

    </div>

    <script>
        function switchTab(type) {
            // Update Tab Buttons
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');

            // Update Forms
            document.querySelectorAll('.form-content').forEach(form => {
                form.classList.remove('active');
            });
            document.getElementById(type + '-form').classList.add('active');
        }

        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line>';
            } else {
                input.type = 'password';
                icon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>';
            }
        }
    </script>

</body>

</html>