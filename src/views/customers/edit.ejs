<%- include('../partials/header') %>

<h1>Edit Customer</h1>

<form action="/customers/<%= customer.id %>" method="POST" style="max-width:500px; margin-top:16px;">

    <label>Full Name *</label><br>
    <input type="text" name="fullName" value="<%= customer.full_name %>" required style="width:100%; padding:8px; margin-bottom:12px;"><br>

    <label>Mobile *</label><br>
    <input type="text" name="mobile" value="<%= customer.mobile %>" required style="width:100%; padding:8px; margin-bottom:12px;"><br>

    <label>Email</label><br>
    <input type="email" name="email" value="<%= customer.email || '' %>" style="width:100%; padding:8px; margin-bottom:12px;"><br>

    <label>Address</label><br>
    <textarea name="address" rows="3" style="width:100%; padding:8px; margin-bottom:12px;"><%= customer.address || '' %></textarea><br>

    <label>Aadhar Number</label><br>
    <input type="text" name="aadharNumber" value="<%= customer.aadhar_number || '' %>" style="width:100%; padding:8px; margin-bottom:12px;"><br>

    <button type="submit" style="padding:10px 24px; background:#1a237e; color:#fff; border:none; border-radius:4px; cursor:pointer;">
        Update Customer
    </button>
</form>

<%- include('../partials/footer') %>
