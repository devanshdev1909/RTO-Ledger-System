<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RTO Ledger - Customer Login</title>
    <link rel="stylesheet" href="/css/login.css">
</head>
<body>

    <div class="background-shape shape-1"></div>
    <div class="background-shape shape-2"></div>

    <div class="login-container">

        <div class="login-card">

            <div class="logo-section">

                <div class="logo-icon">
                    🚗
                </div>

                <h1>RTO Ledger</h1>

                <p>
                    Customer Portal — Track your Vehicles & Service Requests
                </p>

            </div>

            <% if (locals.error) { %>
                <div style="background-color: #ffdddd; color: #d8000c; padding: 12px 35px; font-size: 14px;">
                    <%= error %>
                </div>
            <% } %>

            <form action="/portal/login" method="POST">

                <div class="form-group">

                    <label>Mobile Number</label>

                    <input
                        type="text"
                        name="mobile"
                        placeholder="Enter your mobile number"
                        required
                    >

                </div>

                <div class="form-group">

                    <label>Password</label>

                    <input
                        type="password"
                        name="password"
                        placeholder="Enter your password"
                        required
                    >

                </div>

                <button type="submit" class="login-btn">
                    Login
                </button>

            </form>

            <div class="footer-text">
                Don't have an account? <a href="/portal/register" style="color: #3b82f6; font-weight: 600;">Register here</a>
                <br><br>
                RTO Ledger Management System © 2026
            </div>

        </div>

    </div>

</body>
</html>