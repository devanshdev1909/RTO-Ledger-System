<%- include("partials/header") %>
  <div class="container">

    <!-- Customer Sidebar -->
    <%- include("partials/sidebar") %>

      <div class="main-content">

        <%- include("partials/navbar") %>

          <div class="content">

            <div class="page-header">
              <h1>My Service Requests</h1>
              <button onclick="openRequestCreateModal()"
                style="background-color: #4f46e5; color: white; padding: 7px 15px; border: none; border-radius: 5px; font-weight: bold; margin-left: 10px; cursor: pointer; font-size: 18px;">+
                Request Service</button>
            </div>

            <% if (locals.success) { %>
              <div style="background-color:#d4edda; color:#155724; padding:12px 20px; margin-bottom:20px; border-radius:6px; font-size:14px;">
                ✅ Service request created successfully! Payment has been received.
              </div>
            <% } %>

                        <% if (locals.error) { %>
              <div style="background-color: #ffdddd; color: #d8000c; padding: 12px 20px; margin-bottom: 20px; border-radius: 6px; font-size: 14px;">
                <% if (error === 'DuplicateRequest') { %>
                  ⚠️ A service request for this vehicle and service already exists and is still active. Please wait for it to be completed or cancelled before submitting a new one.
                <% } else if (error === 'PaymentRequired') { %>
                  💳 Payment is required to submit a service request. Please complete the payment.
                <% } else if (error === 'PaymentVerificationFailed') { %>
                  ❌ Payment verification failed. Please try again or contact support.
                <% } else { %>
                  <%= error %>
                <% } %>
              </div>
            <% } %>


                <div class="table-container">
                  <table class="data-table">
                    <thead>
                      <tr>
                        <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">#</th>
                        <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Request No</th>
                        <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Vehicle</th>
                        <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Service Name</th>
                        <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Service Fees</th>
                        <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Status</th>
                        <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Date</th>
                        <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% if (requests.length===0) { %>
                        <tr>
                          <td colspan="8" class="empty-state">
                            No service requests found. Request your first service!
                          </td>
                        </tr>
                        <% } else { %>
                          <% requests.forEach((r, i)=> { %>
                            <tr>
                              <td style="text-align: center;">
                                <%= i + 1 %>
                              </td>
                              <td style="text-align: center;">
                                <%= r.request_no %>
                              </td>
                              <td style="text-align: center;"><strong>
                                  <%= r.vehicle_number %>
                                </strong></td>
                              <td style="text-align: center;">
                                <%= r.service_name %>
                              </td>
                              <td style="text-align: center;">₹ <%= r.amount %>
                              </td>
                              <td style="text-align: center;">
                                <% if (r.status==='Requested') { %>
                                  <span class="status-text"
                                    style="background-color: #6f42c1; color: white; padding: 3px 10px; border-radius: 4px; font-size: 0.85rem;">Requested (Wait)</span>
                                <% } else if (r.status==='Pending' ) { %>
                                  <span class="status-text"
                                    style="background-color: #ffc107; color: #000; padding: 3px 10px; border-radius: 4px; font-size: 0.85rem;">Pending</span>
                                  <% } else if (r.status==='Completed' ) { %>
                                    <span class="status-text"
                                      style="background-color: #28a745; color: white; padding: 3px 10px; border-radius: 4px; font-size: 0.85rem;">Completed</span>
                                    <% } else if (r.status==='Cancelled' ) { %>
                                      <span class="status-text"
                                        style="background-color: #dc3545; color: white; padding: 3px 10px; border-radius: 4px; font-size: 0.85rem;">Cancelled</span>
                                      <% } else { %>
                                        <span class="status-text"
                                          style="background-color: #17a2b8; color: white; padding: 3px 10px; border-radius: 4px; font-size: 0.85rem;">
                                          <%= r.status %>
                                        </span>
                                        <% } %>
                              </td>
                              <td style="text-align: center;">
                                <%= new Date(r.created_at).toLocaleDateString() %>
                              </td>

                              <td class="actions" style="text-align: center; gap: 20px; justify-content: center;">
                                <% if (r.status==='Requested' ) { %>

                                  <!-- EDIT -->
                                  <button type="button" class="btn-icon edit-icon" title="Edit Request"
                                    data-id="<%= r.id %>"
                                    data-vehicle-id="<%= r.vehicle_id %>"
                                    data-service-id="<%= r.service_id %>"
                                    data-amount="<%= r.amount %>"
                                    data-remarks="<%= r.remarks || '' %>"
                                    onclick="openRequestEditModal(this)">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                      stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                      stroke-linejoin="round">
                                      <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                      <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" />
                                      <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415" />
                                      <path d="M16 5l3 3" />
                                    </svg>
                                  </button>

                                  <!-- DELETE -->
                                  <form action="/portal/request/<%= r.id %>/delete" method="POST" class="delete-form"
                                    style="display:inline;">
                                    <button type="submit" class="btn-icon delete-icon" title="Delete Request"
                                      onclick="return confirm('Are you sure you want to delete this request?')">
                                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                        stroke-linejoin="round">
                                        <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                        <path d="M4 7l16 0" />
                                        <path d="M10 11l0 6" />
                                        <path d="M14 11l0 6" />
                                        <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" />
                                        <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" />
                                      </svg>
                                    </button>
                                  </form>

                                  <% } else { %>
                                    <span style="color: #999; font-size: 0.85rem;">-</span>
                                    <% } %>
                              </td>
                            </tr>
                            <% }) %>
                              <% } %>
                    </tbody>
                  </table>
                </div>

          </div>

      </div>
  </div>

  <%- include("partials/request_modal") %>

    <%- include("../../partials/footer") %>