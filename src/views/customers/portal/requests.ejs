<%- include("../../partials/header") %>

<div class="container">

  <!-- Customer Sidebar -->
  <%- include("partials/sidebar") %>

  <div class="main-content">

    <%- include("partials/navbar") %>

    <div class="content">

      <% if (locals.error) { %>
      <div style="background-color: #ffdddd; color: #d8000c; padding: 12px 20px; margin-bottom: 20px; border-radius: 6px; font-size: 14px;">
        <%= error %>
      </div>
      <% } %>

      <div class="page-header" style="margin-top: 10px;">
        <h1>My Service Requests</h1>
        <a href="/portal/request/create" class="btn btn-primary">+ Request Service</a>
      </div>

      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th>#</th>
              <th style="text-align: center;">Request No</th>
              <th style="text-align: center;">Vehicle</th>
              <th style="text-align: center;">Amount</th>
              <th style="text-align: center;">Status</th>
              <th style="text-align: center;">Date</th>
              <th style="text-align: center;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (requests.length === 0) { %>
            <tr>
              <td colspan="7" class="empty-state">
                No service requests found. Request your first service!
              </td>
            </tr>
            <% } else { %>
            <% requests.forEach((r, i) => { %>
            <tr>
              <td><%= i + 1 %></td>
              <td style="text-align: center;"><%= r.request_no %></td>
              <td style="text-align: center;"><%= r.vehicle_number %></td>
              <td style="text-align: center;">₹ <%= r.amount %></td>
              <td style="text-align: center;">
                <% if (r.status === 'Pending') { %>
                <span class="status-text" style="background-color: #ffc107; color: #000; padding: 3px 10px; border-radius: 4px; font-size: 0.85rem;">Pending</span>
                <% } else if (r.status === 'Completed') { %>
                <span class="status-text" style="background-color: #28a745; color: white; padding: 3px 10px; border-radius: 4px; font-size: 0.85rem;">Completed</span>
                <% } else if (r.status === 'Cancelled') { %>
                <span class="status-text" style="background-color: #dc3545; color: white; padding: 3px 10px; border-radius: 4px; font-size: 0.85rem;">Cancelled</span>
                <% } else { %>
                <span class="status-text" style="background-color: #17a2b8; color: white; padding: 3px 10px; border-radius: 4px; font-size: 0.85rem;"><%= r.status %></span>
                <% } %>
              </td>
              <td style="text-align: center;"><%= new Date(r.created_at).toLocaleDateString() %></td>
              <td >
                <% if (r.status === 'Requested') { %>
                <div style="display: flex; gap: 10px; align-items: center; justify-content: center;">

                  <!-- EDIT -->
                  <a href="/portal/request/<%= r.id %>/edit" title="Edit" style="
                    width: 32px;
                    height: 32px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    background: #e0f2fe;
                    border-radius: 6px;
                    color: #0284c7;
                    text-decoration: none;
               ">
                    <!-- EDIT ICON -->
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-edit">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                      <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" />
                      <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415" />
                      <path d="M16 5l3 3" />
                    </svg>
                  </a>

                  <!-- DELETE -->
                  <form action="/portal/request/<%= r.id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this request?');" style="margin: 0;">

                    <button type="submit" title="Delete" style="
                        width: 32px;
                        height: 32px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        background: #e0f2fe;
                        border-radius: 6px;
                        border: none;
                        cursor: pointer;
                        color: #dc2626;
                    ">

                      <!-- DELETE ICON -->
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 6h18" />
                        <path d="M8 6V4h8v2" />
                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                        <path d="M10 11v6" />
                        <path d="M14 11v6" />
                      </svg>

                    </button>
                  </form>

                </div>
                <% } else { %>
                <span style="color: #999; font-size: 0.85rem;">-</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

    </div>

  </div>
</div>

<%- include("../../partials/footer") %>