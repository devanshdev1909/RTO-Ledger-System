<!-- PROFILE MODAL -->
<div id="profileModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; overflow-y: auto;">
  <div style="background:white; max-width:600px; margin: 10vh auto; padding: 25px; border-radius: 8px; position: relative;">

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
      <h2 style="margin: 0;">My Profile</h2>
      <button type="button" onclick="closeProfileModal()" style="background: none; border: none; font-size: 24px; cursor: pointer; color: #888;">&times;</button>
    </div>

    <form action="/portal/profile" method="POST">

      <div style="display: flex; justify-content: space-between; gap: 15px;">
        <div class="form-group" style="flex: 1;">
          <label for="p_name">Full Name *</label>
          <input type="text" name="name" id="p_name" value="<%= locals.profile ? profile.name : '' %>" required style="width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px;">
        </div>

        <div class="form-group" style="flex: 1;">
          <label for="p_mobile">Mobile Number *</label>
          <input type="text" name="mobile" id="p_mobile" value="<%= locals.profile ? profile.mobile : '' %>" required style="width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px;">
        </div>
      </div>

      <div class="form-group" style="margin-top: 15px;">
        <label for="p_email">Email Address</label>
        <input type="email" name="email" id="p_email" value="<%= locals.profile && profile.email ? profile.email : '' %>" style="width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px;">
      </div>

      <div class="form-group" style="margin-top: 15px;">
        <label for="p_address">Address</label>
        <textarea name="address" id="p_address" rows="3" style="width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px;"><%= locals.profile && profile.address ? profile.address : '' %></textarea>
      </div>

      <div style="margin-top: 20px; display: flex; gap: 10px; justify-content: flex-end;">
        <button type="button" class="btn btn-secondary" onclick="closeProfileModal()">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Profile</button>
      </div>

    </form>
  </div>
</div>

<script>
  function openProfileModal() {
    document.getElementById('profileModal').style.display = 'block';
  }

  function closeProfileModal() {
    document.getElementById('profileModal').style.display = 'none';
  }

  window.addEventListener('click', function(event) {
    const modal = document.getElementById("profileModal");
    if (event.target === modal) {
      closeProfileModal();
    }
  });
</script>
