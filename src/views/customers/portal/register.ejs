<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RTO - Customer Registration</title>
    <link rel="stylesheet" href="/css/login.css">
    <link rel="stylesheet" href="/css/register.css">
</head>

<body>

    <div class="background-shape shape-1"></div>
    <div class="background-shape shape-2"></div>

    <div class="login-container">

        <div class="login-card">

            <!-- Header -->
            <div class="logo-section reg-header">
                <div class="logo-icon">🚗</div>
                <h1>RTO Ledger</h1>
                <p>Create your Customer Account</p>
            </div>

            <!-- Step Progress Bar -->
            <div class="step-progress">
                <div class="step-track">
                    <div class="step-fill" id="stepFill"></div>
                </div>
                <div class="step-labels">
                    <div class="step-dot active" id="dot1">
                        <span class="dot-circle">1</span>
                        <span class="dot-label">Your Info</span>
                    </div>
                    <div class="step-dot" id="dot2">
                        <span class="dot-circle">2</span>
                        <span class="dot-label">Security</span>
                    </div>
                </div>
            </div>

            <% if (locals.error) { %>
                <div class="error-banner"><%= error %></div>
            <% } %>

            <!-- Single form, all fields submitted together -->
            <form action="/portal/register" method="POST" id="registerForm">

                <!-- STEP 1 -->
                <div class="reg-step" id="step1">
                    <div class="form-group-sm">
                        <label>Full Name</label>
                        <div class="input-icon-wrap">
                            <span class="input-icon">👤</span>
                            <input type="text" name="name" id="inp_name" placeholder="Enter your full name" autocomplete="name">
                        </div>
                    </div>
                    <div class="form-group-sm">
                        <label>Mobile Number</label>
                        <div class="input-icon-wrap">
                            <span class="input-icon">📱</span>
                            <input type="text" name="mobile" id="inp_mobile" maxlength="10" pattern="[0-9]{10}"
                                oninput="this.value=this.value.replace(/[^0-9]/g,'').slice(0,10)"
                                placeholder="10-digit mobile number" autocomplete="tel">
                        </div>
                    </div>
                    <div class="form-group-sm">
                        <label>Email Address <span class="optional-tag">Optional</span></label>
                        <div class="input-icon-wrap">
                            <span class="input-icon">✉️</span>
                            <input type="email" name="email" id="inp_email" placeholder="Enter your email address" autocomplete="email">
                        </div>
                    </div>
                    <button type="button" class="login-btn reg-next-btn" onclick="goToStep2()">
                        Continue &rarr;
                    </button>
                </div>

                <!-- STEP 2: always in DOM for form submission, visually hidden via CSS class -->
                <div class="reg-step step-hidden" id="step2">
                    <div class="form-group-sm">
                        <label>Password</label>
                        <div class="input-icon-wrap">
                            <span class="input-icon">🔒</span>
                            <input type="password" name="password" id="inp_password" placeholder="Create a password" autocomplete="new-password">
                            <button type="button" class="toggle-pw" onclick="togglePw('inp_password', this)">👁</button>
                        </div>
                    </div>
                    <div class="form-group-sm">
                        <label>Confirm Password</label>
                        <div class="input-icon-wrap">
                            <span class="input-icon">🔒</span>
                            <input type="password" name="confirm_password" id="inp_confirm" placeholder="Re-enter your password" autocomplete="new-password">
                            <button type="button" class="toggle-pw" onclick="togglePw('inp_confirm', this)">👁</button>
                        </div>
                        <p class="pw-match-msg" id="pwMatch"></p>
                    </div>
                    <div class="reg-step2-btns">
                        <button type="button" class="btn-back" onclick="goToStep1()">&larr; Back</button>
                        <button type="submit" class="login-btn reg-submit-btn" style="background:#28a745;" id="submitBtn">
                            Create Account ✓
                        </button>
                    </div>
                </div>

            </form>

            <div class="footer-text">
                Already have an account? <a href="/portal/login" style="color:#3b82f6; font-weight:600;">Login here</a>
                <br><br>RTO Ledger Management System © 2026
            </div>

        </div>

    </div>

    <script>
        function goToStep2() {
            const name = document.getElementById('inp_name').value.trim();
            const mobile = document.getElementById('inp_mobile').value.trim();

            if (!name) { showError('inp_name', 'Please enter your full name.'); return; }
            if (!/^[0-9]{10}$/.test(mobile)) { showError('inp_mobile', 'Please enter a valid 10-digit mobile number.'); return; }

            const s1 = document.getElementById('step1');
            const s2 = document.getElementById('step2');

            s1.classList.add('slide-out-left');
            setTimeout(() => {
                s1.classList.add('step-hidden');
                s1.classList.remove('slide-out-left');
                s2.classList.remove('step-hidden');
                s2.classList.add('slide-in-right');
                setTimeout(() => s2.classList.remove('slide-in-right'), 400);
            }, 280);

            document.getElementById('stepFill').style.width = '100%';
            document.getElementById('dot2').classList.add('active');
        }

        function goToStep1() {
            const s1 = document.getElementById('step1');
            const s2 = document.getElementById('step2');

            s2.classList.add('slide-out-right');
            setTimeout(() => {
                s2.classList.add('step-hidden');
                s2.classList.remove('slide-out-right');
                s1.classList.remove('step-hidden');
                s1.classList.add('slide-in-left');
                setTimeout(() => s1.classList.remove('slide-in-left'), 400);
            }, 280);

            document.getElementById('stepFill').style.width = '0%';
            document.getElementById('dot2').classList.remove('active');
        }

        // Password match checker
        document.addEventListener('DOMContentLoaded', function() {
            const pw = document.getElementById('inp_password');
            const cf = document.getElementById('inp_confirm');
            const msg = document.getElementById('pwMatch');
            const btn = document.getElementById('submitBtn');

            function checkMatch() {
                if (!cf.value) { msg.textContent = ''; return; }
                if (pw.value === cf.value) {
                    msg.textContent = '✓ Passwords match';
                    msg.className = 'pw-match-msg match';
                    btn.disabled = false;
                } else {
                    msg.textContent = '✗ Passwords do not match';
                    msg.className = 'pw-match-msg no-match';
                    btn.disabled = true;
                }
            }
            pw.addEventListener('input', checkMatch);
            cf.addEventListener('input', checkMatch);
        });

        function togglePw(id, btn) {
            const inp = document.getElementById(id);
            if (inp.type === 'password') { inp.type = 'text'; btn.textContent = '🙈'; }
            else { inp.type = 'password'; btn.textContent = '👁'; }
        }

        function showError(id, msg) {
            const el = document.getElementById(id);
            el.style.borderColor = '#e74c3c';
            el.focus();
            el.placeholder = msg;
            setTimeout(() => { el.style.borderColor = ''; el.placeholder = el.getAttribute('placeholder') || ''; }, 2500);
        }
    </script>

</body>

</html>