<%- include("../../partials/header") %>

<div class="container">
  <%- include("partials/sidebar") %>

  <div class="main-content">
    <%- include("partials/navbar") %>

    <div class="content">

      <div class="page-header">
        <h1>My Vehicles</h1>
        <button class="btn btn-primary" onclick="openVehicleCreateModal()">+ Add Vehicle</button>
      </div>

      <% if (locals.error) { %>
      <div style="background-color: #ffdddd; color: #d8000c; padding: 12px 20px; margin-bottom: 20px; border-radius: 6px; font-size: 14px;">
        <%= error %>
      </div>
      <% } %>

      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th style="text-align: center;">#</th>
              <th style="text-align: center;">Vehicle Number</th>
              <th style="text-align: center;">Type</th>
              <th style="text-align: center;">Chassis No.</th>
              <th style="text-align: center;">Engine No.</th>
              <th style="text-align: center;">Added On</th>
              <th style="text-align: center;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (vehicles.length === 0) { %>
            <tr>
              <td colspan="7" class="empty-state">
                No vehicles found. Add your first vehicle!
              </td>
            </tr>
            <% } else { %>
            <% vehicles.forEach((v, i) => { %>
            <tr>
              <td style="text-align: center;"><%= i + 1 %></td>
              <td style="text-align: center;"><strong><%= v.vehicle_number %></strong></td>
              <td style="text-align: center;"><%= v.vehicle_type || 'N/A' %></td>
              <td style="text-align: center;"><%= v.chassis_number || 'N/A' %></td>
              <td style="text-align: center;"><%= v.engine_number || 'N/A' %></td>
              <td style="text-align: center;"><%= new Date(v.created_at).toLocaleDateString() %></td>
              
              <td class="actions" style="text-align: center; gap: 20px; justify-content: center;">

                <button type="button" class="btn-icon edit-icon" title="Edit Vehicle" onclick="openVehicleEditModal('<%= v.id %>', '<%= v.vehicle_number %>', '<%= v.vehicle_type %>', '<%= v.chassis_number %>', '<%= v.engine_number %>')">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                    <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" />
                    <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415" />
                    <path d="M16 5l3 3" />
                  </svg>
                </button>

                <form action="/portal/vehicle/<%= v.id %>/delete" method="POST" class="delete-form" style="display:inline;">
                  <button type="submit" class="btn-icon delete-icon" title="Delete Vehicle" onclick="return confirm('Are you sure you want to delete this vehicle?')">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                      <path d="M4 7l16 0" />
                      <path d="M10 11l0 6" />
                      <path d="M14 11l0 6" />
                      <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" />
                      <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" />
                    </svg>
                  </button>
                </form>

              </td>
            </tr>
            <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

    </div>
  </div>
</div>

<%- include("partials/vehicle_modal") %>



<%- include("../../partials/footer") %>