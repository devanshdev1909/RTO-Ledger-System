<style>
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
  }

  .modal-box {
    background: #fff;
    width: 500px;
    padding: 20px;
    border-radius: 10px;
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .close-btn {
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
  }
</style>

<%- include("../../partials/header") %>

<div class="container">

  <!-- Customer Sidebar -->
  <%- include("partials/sidebar") %>

  <div class="main-content">

    <%- include("partials/navbar") %>

    <div class="content">

      <% if (locals.error) { %>
      <div style="background-color: #ffdddd; color: #d8000c; padding: 12px 20px; margin-bottom: 20px; border-radius: 6px; font-size: 14px;">
        <%= error %>
      </div>
      <% } %>

      <div class="page-header" style="margin-top: 10px;">
        <h1>My Vehicles</h1>
        <button class="btn btn-primary" onclick="openVehicleModal()">+ Add Vehicle</button>
      </div>

      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th style="text-align: center;">#</th>
              <th style="text-align: center;">Vehicle Number</th>
              <th style="text-align: center;">Type</th>
              <th style="text-align: center;">Chassis No.</th>
              <th style="text-align: center;">Engine No.</th>
              <th style="text-align: center;">Added On</th>
              <th style="text-align: center;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (vehicles.length === 0) { %>
            <tr>
              <td colspan="7" class="empty-state">
                No vehicles found. Add your first vehicle!
              </td>
            </tr>
            <% } else { %>
            <% vehicles.forEach((v, i) => { %>
            <tr>
              <td style="text-align: center;"><%= i + 1 %></td>
              <td style="text-align: center;"><strong><%= v.vehicle_number %></strong></td>
              <td style="text-align: center;"><%= v.vehicle_type || 'N/A' %></td>
              <td style="text-align: center;"><%= v.chassis_number || 'N/A' %></td>
              <td style="text-align: center;"><%= v.engine_number || 'N/A' %></td>
              <td style="text-align: center;"><%= new Date(v.created_at).toLocaleDateString() %></td>
              <td style="text-align: center;">
                <div style="display: flex; gap: 10px; align-items: center; justify-content: center;">

                  <!-- EDIT -->
                  <a href="/portal/vehicle/<%= v.id %>/edit" title="Edit" style="
                width: 32px;
                height: 32px;
                display: flex;
                align-items: center;
                justify-content: center;
                background: #e0f2fe;
                border-radius: 6px;
                color: #0284c7;
                text-decoration: none;
           ">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-edit">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                      <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" />
                      <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415" />
                      <path d="M16 5l3 3" />
                    </svg>
                  </a>

                  <!-- DELETE -->
                  <form action="/portal/vehicle/<%= v.id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this vehicle?');" style="margin: 0;">

                    <button type="submit" title="Delete" style="
                    width: 32px;
                    height: 32px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    background: #e0f2fe;
                    border-radius: 6px;
                    border: none;
                    cursor: pointer;
                    color: #dc2626;
                ">

                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 6h18" />
                        <path d="M8 6V4h8v2" />
                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                        <path d="M10 11v6" />
                        <path d="M14 11v6" />
                      </svg>

                    </button>
                  </form>

                </div>
              </td>
            </tr>
            <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

    </div>

  </div>
</div>


<!-- VEHICLE MODAL -->
<div id="vehicleModal" class="modal-overlay" style="display:none;">
  <div class="modal-box">

    <div class="modal-header">
      <h2>Add New Vehicle</h2>
      <button class="close-btn" onclick="closeVehicleModal()">×</button>
    </div>

    <form action="/portal/vehicle/add" method="POST">

      <div class="form-group">
        <label>Vehicle Number</label>
        <input type="text" name="vehicle_number" required>
      </div>

      <div class="form-group">
        <label>Vehicle Type</label>
        <select name="vehicle_type" required>
          <option value="">Select</option>
          <option value="MCWOG">MCWOG</option>
          <option value="MCWG">MCWG</option>
          <option value="LMV">LMV</option>
          <option value="MGV">MGV</option>
          <option value="HGV">HGV</option>
        </select>
      </div>

      <div class="form-group">
        <label>Chassis Number</label>
        <input type="text" name="chassis_number" required>
      </div>

      <div class="form-group">
        <label>Engine Number</label>
        <input type="text" name="engine_number" required>
      </div>

      <button type="submit" class="btn btn-primary">Save Vehicle</button>

    </form>

  </div>
</div>


<script>
function openVehicleModal() {
  document.getElementById("vehicleModal").style.display = "flex";
}

function closeVehicleModal() {
  document.getElementById("vehicleModal").style.display = "none";
}

// close when clicking outside modal
window.onclick = function(event) {
  const modal = document.getElementById("vehicleModal");
  if (event.target === modal) {
    modal.style.display = "none";
  }
}
</script>

<%- include("../../partials/footer") %>