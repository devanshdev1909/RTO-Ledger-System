<%- include("../../partials/header") %>

    <div class="container">

        <!-- Customer Sidebar -->
        <%- include("partials/sidebar") %>

            <div class="main-content">

                <%- include("partials/navbar") %>

                    <div class="content">

                        <% if (locals.error) { %>
                            <div
                                style="background-color: #ffdddd; color: #d8000c; padding: 12px 20px; margin-bottom: 20px; border-radius: 6px; font-size: 14px;">
                                <%= error %>
                            </div>
                            <% } %>

                                <div class="page-header" style="margin-top: 10px;">
                                    <h1>My Profile</h1>
                                </div>

                                <div class="form-card">
                                    <form action="/portal/profile" method="POST">

                                        <div style="display: flex; justify-content: space-between;">
                                            <div class="form-group">
                                                <label for="name">Full Name *</label>
                                                <input type="text" name="name" id="name" value="<%= profile.name %>"
                                                    required style="width: 500px;display: flex;">
                                            </div>

                                            <div class="form-group">
                                                <label for="mobile">Mobile Number *</label>
                                                <input type="text" name="mobile" id="mobile"
                                                    value="<%= profile.mobile %>" required
                                                    style="width: 500px;display: flex;">
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label for="email">Email Address</label>
                                            <input type="email" name="email" id="email"
                                                value="<%= profile.email || '' %>" style="width: 500px;display: flex;">
                                        </div>

                                        <div class="form-group">
                                            <label for="address">Address</label>
                                            <textarea name="address" id="address" rows="3"
                                                style="width: 500px;display: flex;"><%= profile.address || '' %></textarea>
                                        </div>

                                        <div class="form-actions">
                                            <button type="submit" class="btn btn-primary">Save Profile</button>
                                        </div>

                                    </form>
                                </div>

                    </div>

            </div>
    </div>

    <%- include("../../partials/footer") %>