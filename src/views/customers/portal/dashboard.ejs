<%- include("partials/header") %>

    <div class="container">

        <!-- Customer Sidebar -->
        <%- include("partials/sidebar") %>

            <div class="main-content">

                <%- include("partials/navbar") %>

                    <div class="content">

                        <% if (locals.error) { %>
                            <div
                                style="background-color: #ffdddd; color: #d8000c; padding: 12px 20px; margin-bottom: 20px; border-radius: 6px; font-size: 14px;">
                                <%= error %>
                            </div>
                            <% } %>

                                <!-- Dashboard Cards -->
                                <div class="dashboard-content">
                                    <div
                                        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                                        <div>
                                            <h1>Dashboard</h1>
                                            <h3>Welcome <%= customerName %>
                                            </h3>
                                        </div>
                                        <div class="quick-actions">
                                            <button onclick="openVehicleCreateModal()"
                                                style="background-color: #28a745; color: white; padding: 7px 15px; border: none; border-radius: 5px; font-weight: bold; margin-left: 10px; cursor: pointer; font-size: 18px;">+
                                                Add Vehicle</button>
                                            <button onclick="openRequestCreateModal()"
                                                style="background-color: #4f46e5; color: white; padding: 7px 15px; border: none; border-radius: 5px; font-weight: bold; margin-left: 10px; cursor: pointer; font-size: 18px;">+
                                                Request
                                                Service</button>
                                        </div>
                                    </div>

                                    <div class="dashboard-cards four-cols">
                                        <div class="card" style="--theme-bg: #fff5e6; --theme-dark: #e65100;">
                                            <h4>My Vehicles</h4>
                                            <span class="menu-icon">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                                    stroke-linejoin="round">
                                                    <path
                                                        d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v9a2 2 0 0 1-2 2h-2" />
                                                    <circle cx="7.5" cy="17.5" r="2.5" />
                                                    <circle cx="17.5" cy="17.5" r="2.5" />
                                                </svg>
                                            </span>
                                            <p>
                                                <%= vehiclesCount %>
                                            </p>
                                        </div>
                                        <div class="card" style="--theme-bg: #e0f8f5; --theme-dark: #00796b;">
                                            <h4>Total Requests</h4>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                stroke-linecap="round" stroke-linejoin="round"
                                                class="icon icon-tabler icons-tabler-outline icon-tabler-git-pull-request-conflict">
                                                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                                <path d="M16 18a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" />
                                                <path d="M11 6h5a2 2 0 0 1 2 2v8" />
                                                <path d="M4 18a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" />
                                                <path d="M6 11v5" />
                                                <path d="M4 4l4 4" />
                                                <path d="M8 4l-4 4" />
                                            </svg>
                                            <p>
                                                <%= totalRequests %>
                                            </p>
                                        </div>
                                        <div class="card" style="--theme-bg: #e3f2fd; --theme-dark: #1565c0;">
                                            <h4>Pending Requests</h4>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                stroke-linecap="round" stroke-linejoin="round"
                                                class="icon icon-tabler icons-tabler-outline icon-tabler-sort-descending-2">
                                                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                                <path
                                                    d="M5 5.5a.5 .5 0 0 1 .5 -.5h4a.5 .5 0 0 1 .5 .5v4a.5 .5 0 0 1 -.5 .5h-4a.5 .5 0 0 1 -.5 -.5l0 -4" />
                                                <path
                                                    d="M5 14.5a.5 .5 0 0 1 .5 -.5h4a.5 .5 0 0 1 .5 .5v4a.5 .5 0 0 1 -.5 .5h-4a.5 .5 0 0 1 -.5 -.5l0 -4" />
                                                <path d="M14 15l3 3l3 -3" />
                                                <path d="M17 18v-12" />
                                            </svg>
                                            <p>
                                                <%= pendingRequests %>
                                            </p>
                                        </div>
                                        <div class="card" style="--theme-bg: #f3e5f5; --theme-dark: #6a1b9a;">
                                            <h4>Completed Requests</h4>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                stroke-linecap="round" stroke-linejoin="round"
                                                class="icon icon-tabler icons-tabler-outline icon-tabler-progress-check">
                                                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                                <path d="M10 20.777a8.942 8.942 0 0 1 -2.48 -.969" />
                                                <path d="M14 3.223a9.003 9.003 0 0 1 0 17.554" />
                                                <path d="M4.579 17.093a8.961 8.961 0 0 1 -1.227 -2.592" />
                                                <path d="M3.124 10.5c.16 -.95 .468 -1.85 .9 -2.675l.169 -.305" />
                                                <path d="M6.907 4.579a8.954 8.954 0 0 1 3.093 -1.356" />
                                                <path d="M9 12l2 2l4 -4" />
                                            </svg>
                                            <p>
                                                <%= completedRequests %>
                                            </p>
                                        </div>
                                    </div>
                                </div>

                    </div>

            </div>
    </div>

    <%- include("partials/vehicle_modal") %>
        <%- include("partials/request_modal") %>
            <%- include("../../partials/footer") %>