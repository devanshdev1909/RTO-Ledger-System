<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RTO - Activate Account</title>
    <link rel="stylesheet" href="/css/login.css">
    <link rel="stylesheet" href="/css/register.css">
</head>

<body>

    <div class="background-shape shape-1"></div>
    <div class="background-shape shape-2"></div>

    <div class="login-container">

        <div class="login-card">

            <!-- Header -->
            <div class="logo-section reg-header">
                <div class="logo-icon">🚗</div>
                <h1>RTO Ledger</h1>
                <p>Activate your Customer Account</p>
            </div>

            <% if (locals.error) { %>
                <div class="error-banner">
                    <%= error %>
                </div>
                <% } %>

                    <form action="/portal/activate" method="POST" id="activateForm">

                        <div class="reg-step" id="step1" style="display:block; opacity:1;">
                            <div class="form-group-sm">
                                <label>Mobile Number</label>
                                <div class="input-icon-wrap">
                                    <span class="input-icon">📱</span>
                                    <input type="text" name="mobile" id="inp_mobile" maxlength="10" pattern="[0-9]{10}"
                                        oninput="this.value=this.value.replace(/[^0-9]/g,'').slice(0,10)"
                                        placeholder="10-digit mobile number" autocomplete="tel" required>
                                </div>
                            </div>

                            <div class="form-group-sm">
                                <label>Create Password</label>
                                <div class="input-icon-wrap">
                                    <span class="input-icon">🔒</span>
                                    <input type="password" name="password" id="inp_password"
                                        placeholder="Create a password" autocomplete="new-password" required>
                                    <button type="button" class="toggle-pw"
                                        onclick="togglePw('inp_password', this)">👁</button>
                                </div>
                            </div>

                            <div class="form-group-sm">
                                <label>Confirm Password</label>
                                <div class="input-icon-wrap">
                                    <span class="input-icon">🔒</span>
                                    <input type="password" name="confirm_password" id="inp_confirm"
                                        placeholder="Re-enter your password" autocomplete="new-password" required>
                                    <button type="button" class="toggle-pw"
                                        onclick="togglePw('inp_confirm', this)">👁</button>
                                </div>
                                <p class="pw-match-msg" id="pwMatch"></p>
                            </div>

                            <div style="margin-top: 20px;">
                                <button type="submit" class="login-btn reg-next-btn"
                                    style="background:#3b82f6; width: 100%; margin-top:0;" id="submitBtn">
                                    Activate Account & Login &rarr;
                                </button>
                            </div>
                        </div>

                    </form>

                    <div class="footer-text" style="margin-top: 25px;">
                        Already activated? <a href="/login" style="color:#3b82f6; font-weight:600;">Login here</a>
                        <br><br>RTO Ledger Management System © 2026
                    </div>

        </div>

    </div>

    <script>
        // Password match checker
        document.addEventListener('DOMContentLoaded', function () {
            const pw = document.getElementById('inp_password');
            const cf = document.getElementById('inp_confirm');
            const msg = document.getElementById('pwMatch');
            const btn = document.getElementById('submitBtn');

            function checkMatch() {
                if (!cf.value) { msg.textContent = ''; return; }
                if (pw.value === cf.value) {
                    msg.textContent = '✓ Passwords match';
                    msg.className = 'pw-match-msg match';
                    btn.disabled = false;
                } else {
                    msg.textContent = '✗ Passwords do not match';
                    msg.className = 'pw-match-msg no-match';
                    btn.disabled = true;
                }
            }
            pw.addEventListener('input', checkMatch);
            cf.addEventListener('input', checkMatch);
        });

        function togglePw(id, btn) {
            const inp = document.getElementById(id);
            if (inp.type === 'password') { inp.type = 'text'; btn.textContent = '🙈'; }
            else { inp.type = 'password'; btn.textContent = '👁'; }
        }
    </script>

</body>

</html>