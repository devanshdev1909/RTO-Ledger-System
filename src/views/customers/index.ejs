<%- include("../partials/header") %>

    <div class="container">
        <%- include("../partials/sidebar") %>

            <div class="main-content">
                <%- include("../partials/navbar") %>

                    <div class="content">

                        <div class="page-header">
                            <h1>Customers</h1>

                            <% if (permissions.includes('customer.create')) { %>
                                <button id="openCustomerModal" class="btn btn-primary">+ Add Customer</button>
                                <% } %>
                        </div>

                        <div class="table-container">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Customer Code</th>
                                        <th>Name</th>
                                        <th>Mobile</th>
                                        <th>Email</th>
                                        <th>Address</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <% if (typeof customers !=="undefined" && customers.length> 0) { %>
                                        <% customers.forEach((customer, i)=> { %>
                                            <tr>

                                                <td>
                                                    <%= i + 1 %>
                                                </td>

                                                <td><strong>
                                                        <%= customer.customer_code || "N/A" %>
                                                    </strong></td>

                                                <td>
                                                    <%= customer.name %>
                                                </td>

                                                <td>
                                                    <%= customer.mobile %>
                                                </td>

                                                <td>
                                                    <%= customer.email %>
                                                </td>

                                                <td>
                                                    <%= customer.address %>
                                                </td>

                                                <td>
                                                    <div class="status-container">
                                                        <span
                                                            class="status-text <%= customer.is_active !== false ? 'active' : 'inactive' %>">
                                                            <%= customer.is_active !==false ? 'Active' : 'Inactive' %>
                                                        </span>
                                                        <label class="switch">
                                                            <input type="checkbox" class="status-toggle"
                                                                data-id="<%= customer.id %>" <%=customer.is_active
                                                                !==false ? 'checked' : '' %>>
                                                            <span class="slider"></span>
                                                        </label>
                                                    </div>
                                                </td>

                                                <!-- ACTIONS -->
                                                <td class="actions">

                                                    <% if (permissions.includes('customer.edit')) { %>

                                                        <!-- EDIT -->
                                                        <a href="/customers/<%= customer.id %>/edit"
                                                            class="btn-icon edit-icon" title="Edit Customer">

                                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                                fill="none" stroke="currentColor" stroke-width="2"
                                                                stroke-linecap="round" stroke-linejoin="round">

                                                                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                                                <path
                                                                    d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" />
                                                                <path
                                                                    d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415" />
                                                                <path d="M16 5l3 3" />
                                                            </svg>

                                                        </a>

                                                        <!-- DELETE -->
                                                        <form action="/customers/<%= customer.id %>?_method=DELETE"
                                                            method="POST" class="delete-form">

                                                            <button type="submit" class="btn-icon delete-icon"
                                                                title="Delete Customer"
                                                                onclick="return confirm('Are you sure?')">

                                                                <svg xmlns="http://www.w3.org/2000/svg"
                                                                    viewBox="0 0 24 24" fill="none"
                                                                    stroke="currentColor" stroke-width="2"
                                                                    stroke-linecap="round" stroke-linejoin="round">

                                                                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                                                    <path d="M4 7l16 0" />
                                                                    <path d="M10 11l0 6" />
                                                                    <path d="M14 11l0 6" />
                                                                    <path
                                                                        d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" />
                                                                    <path
                                                                        d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" />
                                                                </svg>

                                                            </button>

                                                        </form>

                                                        <% } %>

                                                </td>

                                            </tr>
                                            <% }) %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="8" class="empty-state">
                                                            No customers found. Add your first customer!
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                    </div>
            </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            document.querySelectorAll(".status-toggle").forEach(toggle => {
                toggle.addEventListener("change", async (e) => {
                    const id = e.target.getAttribute("data-id");
                    const isChecked = e.target.checked;
                    const statusText = e.target.closest(".status-container").querySelector(".status-text");

                    try {
                        const response = await fetch(`/customers/${id}/toggle-status`, {
                            method: "PATCH",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ is_active: isChecked })
                        });
                        const result = await response.json();
                        if (!result.success) {
                            alert("Error updating status: " + result.error);
                            e.target.checked = !isChecked;
                        } else {
                            // Update text and class color
                            if (isChecked) {
                                statusText.textContent = "Active";
                                statusText.className = "status-text active";
                            } else {
                                statusText.textContent = "Inactive";
                                statusText.className = "status-text inactive";
                            }
                        }
                    } catch (error) {
                        alert("Network error updating status.");
                        e.target.checked = !isChecked;
                    }
                });
            });
        });
    </script>


    <div id="customerModal" class="modal">
    <div class="modal-content">

        <div class="modal-header">
            <h2>Add New Customer</h2>
            <span class="close-modal">&times;</span>
        </div>

        <form action="/customers" method="POST">

            <div class="form-row">
                <div class="form-group">
                    <label>Customer Code</label>
                    <input type="text" placeholder="CUST-001" name="customer_code" id="customer_code" value="<%= nextCustomerCode %>" readonly required>
                </div>

                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" placeholder="Enter Customer Name" name="name" required>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Mobile Number</label>
                    <input type="text" placeholder="Enter Mobile Number" maxlength="10" minlength="10"
                        name="mobile" pattern="[0-9]{10}" oninput="this.value=this.value.replace(/[^0-9]/g,'').slice(0,10)" required>
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <input type="email" placeholder="Enter Email" name="email">
                </div>
            </div>

            <div class="form-group">
                <label>Address</label>
                <textarea name="address" placeholder="Enter Address" ></textarea>
            </div>

            <button type="submit" class="btn btn-primary">
                Save Customer
            </button>

        </form>

    </div>
</div>


<script>
const modal = document.getElementById("customerModal");

document.getElementById("openCustomerModal")
.addEventListener("click", () => {
    modal.classList.add("active");
});

document.querySelector(".close-modal")
.addEventListener("click", () => {
    modal.classList.remove("active");
});

window.addEventListener("click", (e) => {
    if(e.target === modal){
        modal.classList.remove("active");
    }
});
</script>

    <%- include("../partials/footer") %>