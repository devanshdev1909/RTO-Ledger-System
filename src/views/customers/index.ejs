<%- include("../partials/header") %>

<div class="container">
    <%- include("../partials/sidebar") %>

    <div class="main-content">
        <%- include("../partials/navbar") %>

        <div class="content">

            <div class="page-header">
                <h1>Customers</h1>

                <% if (permissions.includes('customer.create')) { %>
                    <a href="/customers/new" class="btn btn-primary">+ Add Customer</a>
                <% } %>
            </div>

            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Customer Code</th>
                            <th>Name</th>
                            <th>Mobile</th>
                            <th>Email</th>
                            <th>Address</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% if (typeof customers !== "undefined" && customers.length > 0) { %>
                            <% customers.forEach(customer => { %>
                                <tr>

                                    <td><%= customer.id %></td>

                                    <td><strong><%= customer.customer_code || "N/A" %></strong></td>

                                    <td><%= customer.name %></td>

                                    <td><%= customer.mobile %></td>

                                    <td><%= customer.email %></td>

                                    <td><%= customer.address %></td>

                                    <td>
                                        <span class="status-badge">
                                            <%= customer.status || "Active" %>
                                        </span>
                                    </td>

                                    <!-- ACTIONS -->
                                    <td class="actions">

                                        <% if (permissions.includes('customer.edit')) { %>

                                            <!-- EDIT -->
                                            <a href="/customers/<%= customer.id %>/edit"
                                               class="btn-icon edit-icon"
                                               title="Edit Customer">

                                                <svg xmlns="http://www.w3.org/2000/svg"
                                                     viewBox="0 0 24 24"
                                                     fill="none"
                                                     stroke="currentColor"
                                                     stroke-width="2"
                                                     stroke-linecap="round"
                                                     stroke-linejoin="round">

                                                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                                    <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/>
                                                    <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415"/>
                                                    <path d="M16 5l3 3"/>
                                                </svg>

                                            </a>

                                            <!-- DELETE -->
                                            <form action="/customers/<%= customer.id %>?_method=DELETE"
                                                  method="POST"
                                                  class="delete-form">

                                                <button type="submit"
                                                        class="btn-icon delete-icon"
                                                        title="Delete Customer"
                                                        onclick="return confirm('Are you sure?')">

                                                    <svg xmlns="http://www.w3.org/2000/svg"
                                                         viewBox="0 0 24 24"
                                                         fill="none"
                                                         stroke="currentColor"
                                                         stroke-width="2"
                                                         stroke-linecap="round"
                                                         stroke-linejoin="round">

                                                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                                        <path d="M4 7l16 0"/>
                                                        <path d="M10 11l0 6"/>
                                                        <path d="M14 11l0 6"/>
                                                        <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12"/>
                                                        <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3"/>
                                                    </svg>

                                                </button>

                                            </form>

                                        <% } %>

                                    </td>

                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="8" class="empty-state">
                                    No customers found. Add your first customer!
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<%- include("../partials/footer") %>