<%- include('../partials/header') %>

<h1>Customers</h1>
<a href="/customers/add">+ Add Customer</a>

<table border="1" cellpadding="8" cellspacing="0" style="width:100%; margin-top:16px;">
    <thead>
        <tr>
            <th>#</th>
            <th>Name</th>
            <th>Mobile</th>
            <th>Email</th>
            <th>Aadhar</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <% customers.forEach((c, i) => { %>
        <tr>
            <td><%= i + 1 %></td>
            <td><%= c.full_name %></td>
            <td><%= c.mobile %></td>
            <td><%= c.email || '-' %></td>
            <td><%= c.aadhar_number || '-' %></td>
            <td>
                <a href="/customers/<%= c.id %>">View</a> |
                <a href="/customers/<%= c.id %>/edit">Edit</a>
            </td>
        </tr>
        <% }) %>
    </tbody>
</table>

<%- include('../partials/footer') %>
