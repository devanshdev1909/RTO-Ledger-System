<%- include("../partials/header") %>

    <div class="container">
        <%- include("../partials/sidebar") %>

            <div class="main-content">
                <%- include("../partials/navbar") %>

                    <div class="content">

                        <div class="page-header">
                            <h1>Customers</h1>
                            <a href="/customers/new" class="btn btn-primary">+ Add Customer</a>
                        </div>

                        <div class="table-container">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Customer Code</th>
                                        <th>Name</th>
                                        <th>Mobile</th>
                                        <th>Email</th>
                                        <th>Address</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (typeof customers !=="undefined" && customers.length> 0) { %>
                                        <% customers.forEach(customer=> { %>
                                            <tr>
                                                <td>
                                                    <%= customer.id %>
                                                </td>
                                                <td><strong>
                                                        <%= customer.customer_code || "N/A" %>
                                                    </strong></td>
                                                <td>
                                                    <%= customer.name %>
                                                </td>
                                                <td>
                                                    <%= customer.mobile %>
                                                </td>
                                                <td>
                                                    <%= customer.email %>
                                                </td>
                                                <td>
                                                    <%= customer.address %>
                                                </td>
                                                <td>
                                                    <span
                                                        style="background:#d1fae5; color:#065f46; padding:4px 8px; border-radius:12px; font-size:0.85rem; font-weight:500;">
                                                        <%= customer.status || "Active" %>
                                                    </span>
                                                </td>
                                                <td class="actions">
                                                    <a href="/customers/<%= customer.id %>/edit"
                                                        class="btn btn-edit">Edit</a>
                                                    <form action="/customers/<%= customer.id %>?_method=DELETE"
                                                        method="POST" style="display:inline;">
                                                        <button type="submit" class="btn btn-delete"
                                                            onclick="return confirm('Are you sure you want to delete this customer?')">Delete</button>
                                                    </form>
                                                </td>
                                            </tr>
                                            <% }) %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="8" class="empty-state">
                                                            No customers found. Add your first customer!
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                    </div>
            </div>
    </div>

    <%- include("../partials/footer") %>