<%- include("partials/header") %>

    <div class="container">
        <%- include("partials/sidebar") %>

            <div class="main-content">
                <%- include("partials/navbar") %>

                    <div class="content">
                        <div class="page-header">
                            <h1>Search Results</h1>
                        </div>

                        <div style="margin-bottom: 20px; color: #475569;">
                            <% if (query) { %>
                                Showing results for "<strong><%= query %></strong>"
                            <% } else { %>
                                Enter a search term and press Search to find customers, vehicles, or receipts.
                            <% } %>
                        </div>

                        <% if (!query) { %>
                            <div class="table-container">
                                <p style="padding: 20px; color: #64748b;">No search query provided yet.</p>
                            </div>
                        <% } else if (results.customers.length === 0 && results.vehicles.length === 0 && results.receipts.length === 0) { %>
                            <div class="table-container">
                                <p style="padding: 20px; color: #64748b;">No results found for "<%= query %>".</p>
                            </div>
                        <% } else { %>
                            <% if (results.customers.length > 0) { %>
                                <div class="page-header" style="margin-bottom: 12px; padding: 12px 0;">
                                    <h2>Customers</h2>
                                </div>
                                <div class="table-container" style="margin-bottom: 24px;">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th>ID</th>
                                                <th>Customer Code</th>
                                                <th>Name</th>
                                                <th>Mobile</th>
                                                <th>Email</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% results.customers.forEach((customer) => { %>
                                                <tr>
                                                    <td><%= customer.id %></td>
                                                    <td><%= customer.customer_code %></td>
                                                    <td><%= customer.name %></td>
                                                    <td><%= customer.mobile %></td>
                                                    <td><%= customer.email %></td>
                                                </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } %>

                            <% if (results.vehicles.length > 0) { %>
                                <div class="page-header" style="margin-bottom: 12px; padding: 12px 0;">
                                    <h2>Vehicles</h2>
                                </div>
                                <div class="table-container" style="margin-bottom: 24px;">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th>ID</th>
                                                <th>Vehicle No</th>
                                                <th>Type</th>
                                                <th>Customer</th>
                                                <th>Chassis</th>
                                                <th>Engine</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% results.vehicles.forEach((vehicle) => { %>
                                                <tr>
                                                    <td><%= vehicle.id %></td>
                                                    <td><%= vehicle.vehicle_number %></td>
                                                    <td><%= vehicle.vehicle_type %></td>
                                                    <td><%= vehicle.customer_name || 'N/A' %></td>
                                                    <td><%= vehicle.chassis_number %></td>
                                                    <td><%= vehicle.engine_number %></td>
                                                </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } %>

                            <% if (results.receipts.length > 0) { %>
                                <div class="page-header" style="margin-bottom: 12px; padding: 12px 0;">
                                    <h2>Receipts</h2>
                                </div>
                                <div class="table-container" style="margin-bottom: 24px;">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th>ID</th>
                                                <th>Receipt No</th>
                                                <th>Customer</th>
                                                <th>Service</th>
                                                <th>Amount</th>
                                                <th>Payment Mode</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% results.receipts.forEach((receipt) => { %>
                                                <tr>
                                                    <td><%= receipt.id %></td>
                                                    <td><%= receipt.receipt_no %></td>
                                                    <td><%= receipt.customer_name %></td>
                                                    <td><%= receipt.service_name %></td>
                                                    <td>₹<%= parseFloat(receipt.amount_received).toFixed(2) %></td>
                                                    <td><%= receipt.payment_mode %></td>
                                                </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } %>
                        <% } %>
                    </div>
            </div>
    </div>

    <%- include("partials/footer") %>