<%- include('../partials/header') %>

<h1>Monthly Revenue Report</h1>

<form action="/reports/monthly" method="GET" style="margin-top:16px; display:flex; gap:8px; align-items:center;">
    <select name="month" style="padding:8px;">
        <% for (let m = 1; m <= 12; m++) { %>
        <option value="<%= m %>" <%= parseInt(month) === m ? 'selected' : '' %>><%= new Date(2000, m-1).toLocaleString('en', {month: 'long'}) %></option>
        <% } %>
    </select>
    <input type="number" name="year" value="<%= year %>" min="2020" style="padding:8px; width:100px;">
    <button type="submit" style="padding:8px 16px; background:#1a237e; color:#fff; border:none; border-radius:4px; cursor:pointer;">View</button>
</form>

<table border="1" cellpadding="8" cellspacing="0" style="width:100%; margin-top:16px;">
    <thead>
        <tr>
            <th>Date</th>
            <th>Credit</th>
            <th>Debit</th>
            <th>Transactions</th>
        </tr>
    </thead>
    <tbody>
        <% data.forEach(d => { %>
        <tr>
            <td><%= new Date(d.date).toLocaleDateString('en-IN') %></td>
            <td style="color:#2e7d32">₹<%= d.total_credit %></td>
            <td style="color:#c62828">₹<%= d.total_debit %></td>
            <td><%= d.total_transactions %></td>
        </tr>
        <% }) %>
        <% if (data.length === 0) { %>
        <tr><td colspan="4" style="text-align:center;">No data for this month</td></tr>
        <% } %>
    </tbody>
</table>

<%- include('../partials/footer') %>
