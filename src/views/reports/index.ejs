<%- include('../partials/header') %>

<h1>Reports</h1>

<div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(250px, 1fr)); gap:16px; margin-top:16px;">

    <div style="background:#fff; padding:20px; border-radius:8px; text-align:center;">
        <h3><%= stats.total_customers %></h3>
        <p>Total Customers</p>
    </div>

    <div style="background:#fff; padding:20px; border-radius:8px; text-align:center;">
        <h3><%= stats.total_vehicles %></h3>
        <p>Total Vehicles</p>
    </div>

    <div style="background:#fff; padding:20px; border-radius:8px; text-align:center;">
        <h3><%= stats.total_jobs %></h3>
        <p>Total Jobs</p>
    </div>

    <div style="background:#fff3e0; padding:20px; border-radius:8px; text-align:center;">
        <h3><%= stats.pending_jobs %></h3>
        <p>Pending Jobs</p>
    </div>

    <div style="background:#e8f5e9; padding:20px; border-radius:8px; text-align:center;">
        <h3>₹<%= stats.total_collected %></h3>
        <p>Total Collected</p>
    </div>

    <div style="background:#ffebee; padding:20px; border-radius:8px; text-align:center;">
        <h3>₹<%= stats.total_outstanding %></h3>
        <p>Outstanding</p>
    </div>

</div>

<div style="margin-top:24px; display:flex; gap:16px; flex-wrap:wrap;">
    <a href="/reports/daily" style="padding:10px 20px; background:#1a237e; color:#fff; text-decoration:none; border-radius:4px;">Daily Collection</a>
    <a href="/reports/monthly" style="padding:10px 20px; background:#1a237e; color:#fff; text-decoration:none; border-radius:4px;">Monthly Revenue</a>
    <a href="/reports/outstanding" style="padding:10px 20px; background:#1a237e; color:#fff; text-decoration:none; border-radius:4px;">Outstanding Dues</a>
    <a href="/reports/service-wise" style="padding:10px 20px; background:#1a237e; color:#fff; text-decoration:none; border-radius:4px;">Service-Wise</a>
    <a href="/reports/operator" style="padding:10px 20px; background:#1a237e; color:#fff; text-decoration:none; border-radius:4px;">Operator Performance</a>
</div>

<%- include('../partials/footer') %>
