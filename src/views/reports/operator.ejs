<%- include('../partials/header') %>

<h1>Operator Performance</h1>

<form action="/reports/operator" method="GET" style="margin-top:16px; display:flex; gap:8px; align-items:center;">
    <label>From:</label>
    <input type="date" name="startDate" value="<%= startDate %>" style="padding:8px;">
    <label>To:</label>
    <input type="date" name="endDate" value="<%= endDate %>" style="padding:8px;">
    <button type="submit" style="padding:8px 16px; background:#1a237e; color:#fff; border:none; border-radius:4px; cursor:pointer;">View</button>
</form>

<table border="1" cellpadding="8" cellspacing="0" style="width:100%; margin-top:16px;">
    <thead>
        <tr>
            <th>#</th>
            <th>Operator</th>
            <th>Total Jobs</th>
            <th>Total Billed</th>
            <th>Total Collected</th>
        </tr>
    </thead>
    <tbody>
        <% data.forEach((d, i) => { %>
        <tr>
            <td><%= i + 1 %></td>
            <td><%= d.operator_name %></td>
            <td><%= d.total_jobs %></td>
            <td>₹<%= d.total_billed %></td>
            <td>₹<%= d.total_collected %></td>
        </tr>
        <% }) %>
        <% if (data.length === 0) { %>
        <tr><td colspan="5" style="text-align:center;">No data for this period</td></tr>
        <% } %>
    </tbody>
</table>

<%- include('../partials/footer') %>
