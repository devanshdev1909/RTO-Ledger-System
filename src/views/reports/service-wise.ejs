<%- include('../partials/header') %>

<h1>Service-Wise Summary</h1>

<form action="/reports/service-wise" method="GET" style="margin-top:16px; display:flex; gap:8px; align-items:center;">
    <label>From:</label>
    <input type="date" name="startDate" value="<%= startDate %>" style="padding:8px;">
    <label>To:</label>
    <input type="date" name="endDate" value="<%= endDate %>" style="padding:8px;">
    <button type="submit" style="padding:8px 16px; background:#1a237e; color:#fff; border:none; border-radius:4px; cursor:pointer;">View</button>
</form>

<table border="1" cellpadding="8" cellspacing="0" style="width:100%; margin-top:16px;">
    <thead>
        <tr>
            <th>Service Type</th>
            <th>Total Jobs</th>
            <th>Revenue</th>
            <th>Collected</th>
            <th>Pending</th>
        </tr>
    </thead>
    <tbody>
        <% data.forEach(d => { %>
        <tr>
            <td><%= d.service_type %></td>
            <td><%= d.total_jobs %></td>
            <td>₹<%= d.total_revenue %></td>
            <td style="color:#2e7d32">₹<%= d.total_collected %></td>
            <td style="color:#c62828">₹<%= d.total_pending %></td>
        </tr>
        <% }) %>
        <% if (data.length === 0) { %>
        <tr><td colspan="5" style="text-align:center;">No data for this period</td></tr>
        <% } %>
    </tbody>
</table>

<%- include('../partials/footer') %>
