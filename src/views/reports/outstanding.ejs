<%- include('../partials/header') %>

<h1>Outstanding Dues</h1>

<table border="1" cellpadding="8" cellspacing="0" style="width:100%; margin-top:16px;">
    <thead>
        <tr>
            <th>#</th>
            <th>Customer</th>
            <th>Mobile</th>
            <th>Total Jobs</th>
            <th>Billed</th>
            <th>Paid</th>
            <th>Outstanding</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <% data.forEach((d, i) => { %>
        <tr>
            <td><%= i + 1 %></td>
            <td><%= d.full_name %></td>
            <td><%= d.mobile %></td>
            <td><%= d.total_jobs %></td>
            <td>₹<%= d.total_billed %></td>
            <td>₹<%= d.total_paid %></td>
            <td style="color:#c62828; font-weight:bold;">₹<%= d.outstanding %></td>
            <td>
                <a href="/ledger/customer/<%= d.customer_id %>">View Ledger</a>
            </td>
        </tr>
        <% }) %>
        <% if (data.length === 0) { %>
        <tr><td colspan="8" style="text-align:center;">No outstanding dues</td></tr>
        <% } %>
    </tbody>
</table>

<%- include('../partials/footer') %>
