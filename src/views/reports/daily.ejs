<%- include('../partials/header') %>

<h1>Daily Collection Report</h1>

<form action="/reports/daily" method="GET" style="margin-top:16px; display:flex; gap:8px; align-items:center;">
    <input type="date" name="date" value="<%= date %>" style="padding:8px;">
    <button type="submit" style="padding:8px 16px; background:#1a237e; color:#fff; border:none; border-radius:4px; cursor:pointer;">View</button>
</form>

<table border="1" cellpadding="8" cellspacing="0" style="width:100%; margin-top:16px;">
    <thead>
        <tr>
            <th>Payment Mode</th>
            <th>Type</th>
            <th>Transactions</th>
            <th>Amount</th>
        </tr>
    </thead>
    <tbody>
        <% data.forEach(d => { %>
        <tr>
            <td><%= d.payment_mode %></td>
            <td><%= d.transaction_type %></td>
            <td><%= d.total_transactions %></td>
            <td>₹<%= d.total_amount %></td>
        </tr>
        <% }) %>
        <% if (data.length === 0) { %>
        <tr><td colspan="4" style="text-align:center;">No data for this date</td></tr>
        <% } %>
    </tbody>
</table>

<%- include('../partials/footer') %>
