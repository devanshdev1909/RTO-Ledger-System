<%- include("../partials/header") %>

    <div class="container">
        <%- include("../partials/sidebar") %>

            <div class="main-content">
                <%- include("../partials/navbar") %>

                    <div class="content">

                        <div class="page-header">
                            <h1>Edit Service Request</h1>
                            <a href="/services/requests" class="btn btn-secondary">
                                Back
                            </a>
                        </div>

                        <div class="form-container">
                            <form action="/services/requests/<%= request.id %>?_method=PUT" method="POST">

                                <div class="form-group">
                                    <label>Customer *</label>
                                    <select name="customer_id" required>
                                        <option value="">Select Customer</option>
                                        <% customers.forEach(customer=> { %>
                                            <option value="<%= customer.id %>" <%=customer.id===request.customer_id
                                                ? 'selected' : '' %>>
                                                <%= customer.name %>
                                            </option>
                                            <% }) %>
                                    </select>
                                </div>

                                <div class="form-group">
                                    <label>Vehicle *</label>
                                    <select name="vehicle_id" required>
                                        <option value="">Select Vehicle</option>
                                        <% vehicles.forEach(vehicle=> { %>
                                            <option value="<%= vehicle.id %>"
                                                data-customer-id="<%= vehicle.customer_id %>"
                                                <%=vehicle.id===request.vehicle_id ? 'selected' : '' %>>
                                                <%= vehicle.vehicle_number %>
                                            </option>
                                            <% }) %>
                                    </select>
                                </div>

                                <div class="form-group">
                                    <label>Service *</label>
                                    <select id="serviceSelect" name="service_id" required>
                                        <option value="" data-fee="">Select Service</option>
                                        <% services.forEach(service=> { %>
                                            <option value="<%= service.id %>" data-fee="<%= service.default_fee %>"
                                                <%=service.id===request.service_id ? 'selected' : '' %>>
                                                <%= service.service_name %> (₹<%= service.default_fee %>)
                                            </option>
                                            <% }) %>
                                    </select>
                                </div>

                                <div class="form-group">
                                    <label>Amount *</label>
                                    <input type="number" id="amountInput" name="amount" min="0" required>
                                </div>

                                <div class="form-group">
                                    <label>Status *</label>
                                    <select name="status" required>
                                        <option value="Requested" <%=request.status==='Requested' ? 'selected' : '' %>
                                            >Requested (Wait)</option>
                                        <option value="Pending" <%=request.status==='Pending' ? 'selected' : '' %>
                                            >Pending (Started)</option>
                                        <option value="Completed" <%=request.status==='Completed' ? 'selected' : '' %>
                                            >Completed</option>
                                        <option value="Cancelled" <%=request.status==='Cancelled' ? 'selected' : '' %>
                                            >Cancelled</option>
                                    </select>
                                </div>

                                <div class="form-group">
                                    <label>Remarks</label>
                                    <textarea name="remarks" rows="4"
                                        placeholder="Enter remarks..."><%= request.remarks %></textarea>
                                </div>

                                <div class="form-actions">
                                    <button type="submit" class="btn btn-primary">Update Request</button>
                                    <a href="/services/requests" class="btn btn-secondary">Cancel</a>
                                </div>

                            </form>
                        </div>

                    </div>
            </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const customerSelect = document.querySelector("select[name='customer_id']");
            const vehicleSelect = document.querySelector("select[name='vehicle_id']");
            const serviceSelect = document.getElementById("serviceSelect");
            const amountInput = document.getElementById("amountInput");

            // --- Service Fee Handler ---
            if (serviceSelect && amountInput) {
                serviceSelect.addEventListener("change", function () {
                    const selectedOption = serviceSelect.options[serviceSelect.selectedIndex];
                    const fee = selectedOption.getAttribute("data-fee");

                    if (fee) {
                        amountInput.value = fee;
                    } else {
                        amountInput.value = "";
                    }
                });
            }

            // --- Dynamic Vehicle Filter Handler ---
            if (customerSelect && vehicleSelect) {
                // Keep a master copy of all vehicle options loaded on the page
                const allVehicleOptions = Array.from(vehicleSelect.options);

                // Get the currently selected vehicle ID (pre-saved on the edit request)
                const initialVehicleId = vehicleSelect.value;

                function filterVehicles(selectedCustomerId, preserveSelection = false) {
                    // Clear current options
                    vehicleSelect.innerHTML = "";

                    // Repopulate matching options
                    allVehicleOptions.forEach(option => {
                        const customerId = option.getAttribute("data-customer-id");
                        if (option.value === "" || customerId === selectedCustomerId) {
                            vehicleSelect.appendChild(option.cloneNode(true));
                        }
                    });

                    // Restore selected vehicle if we are preserving selection and it matches the filter
                    if (preserveSelection) {
                        vehicleSelect.value = initialVehicleId;
                    } else {
                        vehicleSelect.value = "";
                    }
                }

                // On page load, filter vehicles based on initial customer selection
                if (customerSelect.value) {
                    filterVehicles(customerSelect.value, true);
                }

                // Watch for customer changes
                customerSelect.addEventListener("change", function () {
                    filterVehicles(this.value, false);
                });
            }
        });
    </script>


    <%- include("../partials/footer") %>