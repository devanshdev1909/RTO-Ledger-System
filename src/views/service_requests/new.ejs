<%- include("../partials/header") %>

    <div class="container">
        <%- include("../partials/sidebar") %>

            <div class="main-content">
                <%- include("../partials/navbar") %>

                    <div class="content">

                        <div class="page-header">
                            <h1>New Service Request</h1>
                            <a href="/services/requests" class="btn btn-secondary">
                                Back
                            </a>
                        </div>

                        <div class="form-container">

                            <form action="/services/requests" method="POST">

                                <div class="form-group">
                                    <label>Customer *</label>
                                    <select name="customer_id" required>
                                        <option value="">Select Customer</option>

                                        <% customers.forEach(customer=> { %>
                                            <option value="<%= customer.id %>">
                                                <%= customer.name %>
                                            </option>
                                            <% }) %>

                                    </select>
                                </div>

                                <div class="form-group">
                                    <label>Vehicle *</label>
                                    <select name="vehicle_id" required>
                                        <option value="">Select Vehicle</option>

                                        <% vehicles.forEach(vehicle=> { %>
                                            <option value="<%= vehicle.id %>"
                                                data-customer-id="<%= vehicle.customer_id %>">
                                                <%= vehicle.vehicle_number %>
                                            </option>
                                            <% }) %>

                                    </select>
                                </div>

                                <div class="form-group">
                                    <label>Service *</label>
                                    <select id="serviceSelect" name="service_id" required>
                                        <option value="" data-fee="">Select Service</option>

                                        <% services.forEach(service=> { %>
                                            <option value="<%= service.id %>" data-fee="<%= service.default_fee %>">
                                                <%= service.service_name %> (₹<%= service.default_fee %>)
                                            </option>
                                            <% }) %>

                                    </select>
                                </div>

                                <div class="form-group">
                                    <label>Amount *</label>
                                    <input type="number" id="amountInput" name="amount"
                                        placeholder="Enter Service Amount" required>
                                </div>

                                <div class="form-group">
                                    <label>Remarks</label>
                                    <textarea name="remarks" rows="4" placeholder="Enter remarks..."></textarea>
                                </div>

                                <div class="form-actions">
                                    <button type="submit" class="btn btn-primary">
                                        Save Request
                                    </button>

                                    <a href="/services/requests" class="btn btn-secondary">
                                        Cancel
                                    </a>
                                </div>

                            </form>

                        </div>

                    </div>
            </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const customerSelect = document.querySelector("select[name='customer_id']");
            const vehicleSelect = document.querySelector("select[name='vehicle_id']");
            const serviceSelect = document.getElementById("serviceSelect");
            const amountInput = document.getElementById("amountInput");

            // --- Service Fee Handler ---
            if (serviceSelect && amountInput) {
                serviceSelect.addEventListener("change", function () {
                    const selectedOption = serviceSelect.options[serviceSelect.selectedIndex];
                    const fee = selectedOption.getAttribute("data-fee");

                    if (fee) {
                        amountInput.value = fee;
                    } else {
                        amountInput.value = "";
                    }
                });
            }

            // --- Dynamic Vehicle Filter Handler ---
            if (customerSelect && vehicleSelect) {
                // Keep a master copy of all vehicle options loaded on the page
                const allVehicleOptions = Array.from(vehicleSelect.options);

                customerSelect.addEventListener("change", function () {
                    const selectedCustomerId = this.value;

                    // Clear current options
                    vehicleSelect.innerHTML = "";

                    // Repopulate with only the placeholder option or options matching selected customer
                    allVehicleOptions.forEach(option => {
                        const customerId = option.getAttribute("data-customer-id");
                        if (option.value === "" || customerId === selectedCustomerId) {
                            vehicleSelect.appendChild(option.cloneNode(true));
                        }
                    });

                    // Reset selected vehicle to placeholder
                    vehicleSelect.value = "";
                });
            }
        });
    </script>


    <%- include("../partials/footer") %>