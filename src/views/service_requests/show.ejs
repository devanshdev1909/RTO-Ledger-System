<%- include("../partials/header") %>

<div class="container">
    <%- include("../partials/sidebar") %>

    <div class="main-content">
        <%- include("../partials/navbar") %>

        <div class="content">

            <div class="page-header">
                <h1>Service Request Details</h1>
                <a href="/services/requests" class="btn btn-secondary">
                    Back
                </a>
            </div>

            <div class="form-container">
                <div class="form-group">
                    <label>Request No</label>
                    <p><strong><%= request.request_no %></strong></p>
                </div>

                <div class="form-group">
                    <label>Customer</label>
                    <p><%= request.customer_name %></p>
                </div>

                <div class="form-group">
                    <label>Vehicle</label>
                    <p><%= request.vehicle_number %></p>
                </div>

                <div class="form-group">
                    <label>Service</label>
                    <p><%= request.service_name %></p>
                </div>

                <div class="form-group">
                    <label>Amount</label>
                    <p>₹ <%= request.amount %></p>
                </div>

                <div class="form-group">
                    <label>Status</label>
                    <p><span class="<%= request.status === 'Requested' ? 'status-requested' : request.status === 'Pending' ? 'status-pending' : request.status === 'Completed' ? 'status-completed' : request.status === 'Cancelled' ? 'status-cancelled' : '' %>"><%= request.status %></span></p>
                </div>

                <div class="form-group">
                    <label>Remarks</label>
                    <p><%= request.remarks || '—' %></p>
                </div>

            </div>

        </div>
    </div>
</div>

<%- include("../partials/footer") %>