<%- include("../partials/header") %>

<div class="container">

    <%- include("../partials/sidebar") %>

    <div class="main-content">

        <%- include("../partials/navbar") %>

        <div class="content">

            <!-- HEADER -->
            <div class="page-header">
                <h1>Service Requests</h1>

                <% if (permissions.includes('service.create')) { %>
                    <a href="/services/requests/new" class="btn btn-primary">
                        + New Request
                    </a>
                <% } %>
            </div>

            <!-- TABLE -->
            <div class="table-container">

                <table class="data-table">

                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Request No</th>
                            <th>Customer</th>
                            <th>Vehicle</th>
                            <th>Service</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% if (!requests || requests.length === 0) { %>
                            <tr>
                                <td colspan="8" class="empty-state">
                                    No Service Requests Found
                                </td>
                            </tr>
                        <% } else { %>

                            <% requests.forEach((r, i) => { %>
                                <tr>

                                    <td><%= i + 1 %></td>
                                    <td><%= r.request_no %></td>
                                    <td><%= r.customer_name %></td>
                                    <td><%= r.vehicle_number %></td>
                                    <td><%= r.service_name %></td>
                                    <td>₹ <%= r.amount %></td>

                                    <td>
                                        <select class="status-select <%= r.status === 'Requested' ? 'requested' : r.status === 'Pending' ? 'pending' : r.status === 'Completed' ? 'completed' : r.status === 'Cancelled' ? 'cancelled' : '' %>" data-id="<%= r.id %>">
                                            <option value="Requested" <%= r.status === 'Requested' ? 'selected' : '' %>>Requested (Wait)</option>
                                            <option value="Pending" <%= r.status === 'Pending' ? 'selected' : '' %>>Pending (Started)</option>
                                            <option value="Completed" <%= r.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                                            <option value="Cancelled" <%= r.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                                        </select>
                                    </td>

                                    <!-- ACTIONS -->
                                    <td class="actions">

                                        <!-- VIEW -->
                                        <a href="/services/requests/<%= r.id %>"
                                           class="btn-icon view-icon"
                                           title="View">
                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                 viewBox="0 0 24 24"
                                                 fill="none"
                                                 stroke="currentColor"
                                                 stroke-width="2"
                                                 stroke-linecap="round"
                                                 stroke-linejoin="round">
                                                <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"/>
                                                <circle cx="12" cy="12" r="3"/>
                                            </svg>
                                        </a>

                                        <% if (permissions.includes('service.create')) { %>

                                            <!-- EDIT -->
                                            <a href="/services/requests/<%= r.id %>/edit"
                                               class="btn-icon edit-icon"
                                               title="Edit">
                                                <svg xmlns="http://www.w3.org/2000/svg"
                                                     viewBox="0 0 24 24"
                                                     fill="none"
                                                     stroke="currentColor"
                                                     stroke-width="2"
                                                     stroke-linecap="round"
                                                     stroke-linejoin="round">
                                                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                                    <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/>
                                                    <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415"/>
                                                    <path d="M16 5l3 3"/>
                                                </svg>
                                            </a>

                                            <!-- DELETE -->
                                            <form action="/services/requests/<%= r.id %>?_method=DELETE"
                                                  method="POST"
                                                  class="delete-form">
                                                <button type="submit"
                                                        class="btn-icon delete-icon"
                                                        title="Delete"
                                                        onclick="return confirm('Are you sure?')">
                                                    <svg xmlns="http://www.w3.org/2000/svg"
                                                         viewBox="0 0 24 24"
                                                         fill="none"
                                                         stroke="currentColor"
                                                         stroke-width="2"
                                                         stroke-linecap="round"
                                                         stroke-linejoin="round">
                                                        <path d="M4 7h16"/>
                                                        <path d="M10 11v6"/>
                                                        <path d="M14 11v6"/>
                                                        <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2l1-12"/>
                                                        <path d="M9 7V4h6v3"/>
                                                    </svg>
                                                </button>
                                            </form>

                                        <% } %>

                                    </td>

                                </tr>
                            <% }) %>

                        <% } %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const statusSelects = document.querySelectorAll(".status-select");

            // Color updating helper
            function updateSelectColor(selectElement, status) {
                selectElement.classList.remove("requested", "pending", "completed", "cancelled");
                if (status === "Requested") selectElement.classList.add("requested");
                else if (status === "Pending") selectElement.classList.add("pending");
                else if (status === "Completed") selectElement.classList.add("completed");
                else if (status === "Cancelled") selectElement.classList.add("cancelled");
            }

            statusSelects.forEach(select => {
                select.addEventListener("change", async (e) => {
                    const id = e.target.getAttribute("data-id");
                    const newStatus = e.target.value;
                    const previousStatus = e.target.getAttribute("data-prev") || newStatus;

                    try {
                        const response = await fetch(`/services/requests/${id}/status`, {
                            method: "PATCH",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ status: newStatus })
                        });

                        const result = await response.json();
                        if (!result.success) {
                            alert("Error updating status: " + result.error);
                            e.target.value = previousStatus;
                            updateSelectColor(e.target, previousStatus);
                        } else {
                            // Keep track of the current status
                            e.target.setAttribute("data-prev", newStatus);
                            updateSelectColor(e.target, newStatus);
                        }
                    } catch (error) {
                        alert("Network error updating status.");
                        e.target.value = previousStatus;
                        updateSelectColor(e.target, previousStatus);
                    }
                });

                // Initialize the previous status tracking
                select.setAttribute("data-prev", select.value);
            });
        });
    </script>

</div>

<%- include("../partials/footer") %>