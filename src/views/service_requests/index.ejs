<%- include("../partials/header") %>

    <div class="container">

        <%- include("../partials/sidebar") %>

            <div class="main-content">

                <%- include("../partials/navbar") %>

                    <div class="content">

                        <div class="page-header">

                            <h1>Service Requests</h1>

                            <% if (permissions.includes('service.create')) { %>
                                <a href="/services/requests/new" class="btn btn-primary">
                                    + New Request
                                </a>
                                <% } %>

                        </div>

                        <div class="table-container">

                            <table class="data-table">

                                <thead>

                                    <tr>
                                        <th>#</th>
                                        <th>Request No</th>
                                        <th>Customer</th>
                                        <th>Vehicle</th>
                                        <th>Service</th>
                                        <th>Amount</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>

                                </thead>

                                <tbody>

                                    <% if (!requests || requests.length===0) { %>

                                        <tr>
                                            <td colspan="8">
                                                No Service Requests Found
                                            </td>
                                        </tr>

                                        <% } else { %>

                                            <% requests.forEach((r,i)=> { %>

                                                <tr>

                                                    <td>
                                                        <%= i + 1 %>
                                                    </td>

                                                    <td>
                                                        <%= r.request_no %>
                                                    </td>

                                                    <td>
                                                        <%= r.customer_name %>
                                                    </td>

                                                    <td>
                                                        <%= r.vehicle_number %>
                                                    </td>

                                                    <td>
                                                        <%= r.service_name %>
                                                    </td>

                                                    <td>₹ <%= r.amount %>
                                                    </td>
                                                    <td>
                                                        <select
                                                            class="status-select <%= r.status === 'Pending' ? 'pending' : r.status === 'Completed' ? 'completed' : r.status === 'Cancelled' ? 'cancelled' : '' %>"
                                                            data-id="<%= r.id %>">
                                                            <option value="Pending" <%=r.status==='Pending' ? 'selected'
                                                                : '' %>>Pending</option>
                                                            <option value="Completed" <%=r.status==='Completed'
                                                                ? 'selected' : '' %>>Completed</option>
                                                            <option value="Cancelled" <%=r.status==='Cancelled'
                                                                ? 'selected' : '' %>>Cancelled</option>
                                                        </select>
                                                    </td>
                                                    <td class="actions">
                                                        <a href="/services/requests/<%= r.id %>"
                                                            class="btn btn-view">View</a>
                                                        <% if (permissions.includes('service.create')) { %>
                                                            <a href="/services/requests/<%= r.id %>/edit"
                                                                class="btn btn-edit">Edit</a>
                                                            <% } %>
                                                                <% if (permissions.includes('service.create')) { %>
                                                                    <form
                                                                        action="/services/requests/<%= r.id %>?_method=DELETE"
                                                                        method="POST" style="display:inline;">
                                                                        <button type="submit" class="btn btn-delete"
                                                                            onclick="return confirm('Are you sure you want to delete this request?')">Delete</button>
                                                                    </form>
                                                                    <% } %>
                                                    </td>

                                                </tr>

                                                <% }) %>

                                                    <% } %>

                                </tbody>

                            </table>

                        </div>

                    </div>

            </div>

    </div>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const statusSelects = document.querySelectorAll(".status-select");

            // Color updating helper
            function updateSelectColor(selectElement, status) {
                selectElement.classList.remove("pending", "completed", "cancelled");
                if (status === "Pending") selectElement.classList.add("pending");
                else if (status === "Completed") selectElement.classList.add("completed");
                else if (status === "Cancelled") selectElement.classList.add("cancelled");
            }

            statusSelects.forEach(select => {
                select.addEventListener("change", async (e) => {
                    const id = e.target.getAttribute("data-id");
                    const newStatus = e.target.value;
                    const previousStatus = e.target.getAttribute("data-prev") || newStatus;

                    try {
                        const response = await fetch(`/services/requests/${id}/status`, {
                            method: "PATCH",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ status: newStatus })
                        });

                        const result = await response.json();
                        if (!result.success) {
                            alert("Error updating status: " + result.error);
                            e.target.value = previousStatus;
                            updateSelectColor(e.target, previousStatus);
                        } else {
                            // Keep track of the current status
                            e.target.setAttribute("data-prev", newStatus);
                            updateSelectColor(e.target, newStatus);
                        }
                    } catch (error) {
                        alert("Network error updating status.");
                        e.target.value = previousStatus;
                        updateSelectColor(e.target, previousStatus);
                    }
                });

                // Initialize the previous status tracking
                select.setAttribute("data-prev", select.value);
            });
        });
    </script>


    <%- include("../partials/footer") %>