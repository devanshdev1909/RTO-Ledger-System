<%- include("../partials/header") %>

    <div class="container">

        <%- include("../partials/sidebar") %>

            <div class="main-content">

                <%- include("../partials/navbar") %>

                    <div class="content">

                        <div class="page-header">

                            <h1>Service Requests</h1>

                            <% if (permissions.includes('service.create')) { %>
                                <a href="/services/requests/new" class="btn btn-primary">
                                    + New Request
                                </a>
                                <% } %>

                        </div>

                        <div class="table-container">

                            <table class="data-table">

                                <thead>

                                    <tr>
                                        <th>#</th>
                                        <th>Request No</th>
                                        <th>Customer</th>
                                        <th>Vehicle</th>
                                        <th>Service</th>
                                        <th>Amount</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>

                                </thead>

                                <tbody>

                                    <% if (!requests || requests.length===0) { %>

                                        <tr>
                                            <td colspan="8">
                                                No Service Requests Found
                                            </td>
                                        </tr>

                                        <% } else { %>

                                            <% requests.forEach((r,i)=> { %>

                                                <tr>

                                                    <td>
                                                        <%= i + 1 %>
                                                    </td>

                                                    <td>
                                                        <%= r.request_no %>
                                                    </td>

                                                    <td>
                                                        <%= r.customer_name %>
                                                    </td>

                                                    <td>
                                                        <%= r.vehicle_number %>
                                                    </td>

                                                    <td>
                                                        <%= r.service_name %>
                                                    </td>

                                                    <td>₹ <%= r.amount %>
                                                    </td>

                                                    <td>
                                                        <span
                                                            class="<%= r.status === 'Pending' ? 'status-pending' : r.status === 'Completed' ? 'status-completed' : r.status === 'Cancelled' ? 'status-cancelled' : '' %>">
                                                            <%= r.status %>
                                                        </span>
                                                    </td>

                                                    <td class="actions">
                                                        <a href="/services/requests/<%= r.id %>"
                                                            class="btn btn-view">View</a>
                                                        <% if (permissions.includes('service.create')) { %>
                                                            <a href="/services/requests/<%= r.id %>/edit"
                                                                class="btn btn-edit">Edit</a>
                                                            <% } %>
                                                                <% if (permissions.includes('service.create')) { %>
                                                                    <form
                                                                        action="/services/requests/<%= r.id %>?_method=DELETE"
                                                                        method="POST" style="display:inline;">
                                                                        <button type="submit" class="btn btn-delete"
                                                                            onclick="return confirm('Are you sure you want to delete this request?')">Delete</button>
                                                                    </form>
                                                                    <% } %>
                                                    </td>

                                                </tr>

                                                <% }) %>

                                                    <% } %>

                                </tbody>

                            </table>

                        </div>

                    </div>

            </div>

    </div>

    <%- include("../partials/footer") %>