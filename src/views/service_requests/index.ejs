<%- include("../partials/header") %>

<div class="container">

  <%- include("../partials/sidebar") %>

  <div class="main-content">

    <%- include("../partials/navbar") %>

    <div class="content">

      <!-- HEADER -->
      <div class="page-header">
        <h1>Service Requests</h1>

        <% if (permissions.includes('service.create')) { %>
        <button type="button" onclick="openAddReqModal()" class="btn btn-primary">+ New
          Request</button>
        <% } %>
      </div>

      <!-- TABLE -->
      <div class="table-container">

        <table class="data-table">

          <thead>
            <tr>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">#</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Request No</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Customer</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Vehicle</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Service</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Amount</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Status</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Actions</th>
            </tr>
          </thead>

          <tbody>

            <% if (!requests || requests.length===0) { %>
            <tr>
              <td colspan="8" class="empty-state">
                No Service Requests Found
              </td>
            </tr>
            <% } else { %>

            <% requests.forEach(function(r, i) { %>
            <tr>

              <td style="text-align: center;">
                <%= (currentPage - 1) * 10 + i + 1 %>
              </td>
              <td style="text-align: center;">
                <%= r.request_no %>
              </td>
              <td style="text-align: center;">
                <%= r.customer_name %>
              </td>
              <td style="text-align: center;">
                <%= r.vehicle_number %>
              </td>
              <td style="text-align: center;">
                <%= r.service_name %>
              </td>
              <td style="text-align: center;">₹ <%= r.amount %>
              </td>

              <td style="text-align: center;">
                <% if (permissions.includes('service.create')) { %>
                <select class="status-select <%= r.status === 'Requested' ? 'requested' : r.status === 'Pending' ? 'pending' : r.status === 'Completed' ? 'completed' : r.status === 'Cancelled' ? 'cancelled' : '' %>" data-id="<%= r.id %>">
                  <option value="Requested" <%= r.status === 'Requested' ? 'selected' : '' %>>Requested (Wait)</option>
                  <option value="Pending" <%= r.status === 'Pending' ? 'selected' : '' %>>Pending (Started)</option>
                  <option value="Completed" <%= r.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                  <option value="Cancelled" <%= r.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                </select>
                <% } else { %>
                <span class="status-select <%= r.status === 'Requested' ? 'requested' : r.status === 'Pending' ? 'pending' : r.status === 'Completed' ? 'completed' : r.status === 'Cancelled' ? 'cancelled' : '' %>" style="pointer-events:none;">
                  <%= r.status %>
                </span>
                <% } %>
              </td>

              <!-- ACTIONS -->
              <td class="actions" style="text-align: center;">
                <div class="actions-wrapper">

                <!-- VIEW -->
                <a href="/services/requests/<%= r.id %>" class="btn-icon view-icon" title="View">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z" />
                    <circle cx="12" cy="12" r="3" />
                  </svg>
                </a>

                <% if (permissions.includes('service.create')) { %>

                <!-- EDIT -->
                <button type="button" onclick="openEditReqModal('<%= r.id %>', '<%= r.customer_id %>', '<%= r.vehicle_id || '' %>', '<%= r.service_id %>', '<%= r.amount %>', '<%= r.status %>', `<%= r.remarks || '' %>`)" class="btn-icon edit-icon" title="Edit" >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                    <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" />
                    <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415" />
                    <path d="M16 5l3 3" />
                  </svg>
                </button>

                <!-- DELETE -->
                <form action="/services/requests/<%= r.id %>?_method=DELETE" method="POST" class="delete-form">
                  <button type="submit" class="btn-icon delete-icon" title="Delete" onclick="return confirm('Are you sure?')">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M4 7h16" />
                      <path d="M10 11v6" />
                      <path d="M14 11v6" />
                      <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2l1-12" />
                      <path d="M9 7V4h6v3" />
                    </svg>
                  </button>
                </form>

                <% } %>

                </div>
              </td>

            </tr>
            <% }) %>

            <% } %>

          </tbody>

        </table>

      </div>
      
      <%- include("../partials/pagination") %>

    </div>

  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const statusSelects = document.querySelectorAll(".status-select");

      // Color updating helper
      function updateSelectColor(selectElement, status) {
        selectElement.classList.remove("requested", "pending", "completed", "cancelled");
        if (status === "Requested") selectElement.classList.add("requested");
        else if (status === "Pending") selectElement.classList.add("pending");
        else if (status === "Completed") selectElement.classList.add("completed");
        else if (status === "Cancelled") selectElement.classList.add("cancelled");
      }

      statusSelects.forEach(select => {
        select.addEventListener("change", async (e) => {
          const id = e.target.getAttribute("data-id");
          const newStatus = e.target.value;
          const previousStatus = e.target.getAttribute("data-prev") || newStatus;

          try {
            const response = await fetch(`/services/requests/${id}/status`, {
              method: "PATCH",
              headers: {
                "Content-Type": "application/json"
              },
              body: JSON.stringify({
                status: newStatus
              })
            });

            const result = await response.json();
            if (!result.success) {
              if (typeof showToast === 'function') showToast("Error updating status: " + result.error, "error");
              else alert("Error updating status: " + result.error);
              e.target.value = previousStatus;
              updateSelectColor(e.target, previousStatus);
            } else {
              // Keep track of the current status
              e.target.setAttribute("data-prev", newStatus);
              updateSelectColor(e.target, newStatus);
              
              if (typeof showToast === 'function') {
                  showToast("Status updated and email notification sent!", "success");
              }
            }
          } catch (error) {
            if (typeof showToast === 'function') showToast("Network error updating status.", "error");
            else alert("Network error updating status.");
            e.target.value = previousStatus;
            updateSelectColor(e.target, previousStatus);
          }
        });

        // Initialize the previous status tracking
        select.setAttribute("data-prev", select.value);
      });
    });
  </script>

</div>
<!-- Service Request Modal -->
<div id="requestModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
    <h2 id="reqModalTitle">New Service Request</h2>

    <span class="close-modal-edit"
        onclick="document.getElementById('requestModal').classList.remove('active')">
        &times;
    </span>
</div>
    <form id="reqForm" action="/services/requests" method="POST">
      <input type="hidden" id="reqMethodOverride" name="_method" value="PUT" disabled>

      <div class="form-row">
      <div class="form-group">
        <label>Customer *</label>
        <select id="req_customer" name="customer_id" required>
          <option value="">Select Customer</option>
          <% customers.forEach(function(c) { %>
          <option value="<%= c.id %>">
            <%= c.name %>
          </option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label>Vehicle *</label>
        <select id="req_vehicle" name="vehicle_id" required>
          <option value="">-- Select Customer First --</option>
        </select>
      </div>
      </div>

      <div class="form-row">
      <div class="form-group">
        <label>Service *</label>
        <select id="req_service" name="service_id" required>
          <option value="">Select Service</option>
          <% services.forEach(function(s) { %>
          <option value="<%= s.id %>">
            <%= s.service_name %>
          </option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label>Amount (₹) *</label>
        <input type="number" id="req_amount" name="amount" required>
      </div>
      </div>

      <div class="form-group" style="margin-top: 15px;">
        <label>Status</label>
        <select id="req_status" name="status">
          <option value="Requested">Requested (Wait)</option>
          <option value="Pending">Pending (Started)</option>
          <option value="Completed">Completed</option>
          <option value="Cancelled">Cancelled</option>
        </select>
      </div>

      <div class="form-group">
        <label>Remarks</label>
        <textarea id="req_remarks" name="remarks" rows="3"></textarea>
      </div>

      <div class="modal-footer">
        <button type="button" onclick="document.getElementById('requestModal').classList.remove('active')" class="btn btn-secondary">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Request</button>
      </div>
    </form>
  </div>
</div>

<script>
  function openAddReqModal() {
    document.getElementById('requestModal').classList.add('active');
    document.getElementById('reqModalTitle').innerText = 'New Service Request';
    document.getElementById('reqForm').action = '/services/requests';
    document.getElementById('reqMethodOverride').disabled = true;
    document.getElementById('reqForm').reset();
  }

function openEditReqModal(id, customerId, vehicleId, serviceId, amount, status, remarks) {
    document.getElementById('requestModal').classList.add('active');

    document.getElementById('reqModalTitle').innerText = 'Edit Service Request';
    document.getElementById('reqForm').action = '/services/requests/' + id + '?_method=PUT';

    document.getElementById('req_customer').value = customerId;
    populateVehicles(customerId, vehicleId);
    document.getElementById('req_service').value = serviceId;
    document.getElementById('req_amount').value = amount;
    document.getElementById('req_status').value = status;
    document.getElementById('req_remarks').value = remarks || '';
}

const allVehicles = JSON.parse('<%- JSON.stringify((typeof vehicles !== "undefined" ? vehicles : [])) %>');
const serviceFees = JSON.parse('<%- JSON.stringify((typeof services !== "undefined" ? services : []).reduce(function(acc, s) { acc[s.id] = Number(s.default_fee) || 0; return acc; }, {})) %>');

function populateVehicles(customerId, selectedVehicleId) {
    var vehicleSelect = document.getElementById('req_vehicle');
    vehicleSelect.innerHTML = '<option value="">-- Select Vehicle --</option>';
    if (!customerId) {
        vehicleSelect.innerHTML = '<option value="">-- Select Customer First --</option>';
        return;
    }
    var filtered = allVehicles.filter(function(v) {
        return String(v.customer_id) === String(customerId);
    });
    if (filtered.length === 0) {
        vehicleSelect.innerHTML += '<option value="" disabled>No vehicles found for this customer</option>';
    } else {
        filtered.forEach(function(v) {
            var opt = document.createElement('option');
            opt.value = v.id;
            opt.textContent = v.vehicle_number;
            if (selectedVehicleId && String(v.id) === String(selectedVehicleId)) {
                opt.selected = true;
            }
            vehicleSelect.appendChild(opt);
        });
    }
}

document.addEventListener("DOMContentLoaded", function () {

    const customerSelect = document.getElementById('req_customer');
    if (customerSelect) {
        customerSelect.addEventListener('change', function() {
            populateVehicles(this.value, null);
        });
    }

    const serviceSelect = document.getElementById("req_service");
    const amountInput = document.getElementById("req_amount");

    if (serviceSelect) {
        serviceSelect.addEventListener("change", function () {

            const fee = serviceFees[this.value];

            if (fee !== undefined) {
                amountInput.value = fee;
            } else {
                amountInput.value = "";
            }

        });
    }

});

window.addEventListener('click', function(e) {
    const modal = document.getElementById('requestModal');

    if (e.target === modal) {
      modal.style.display = 'none';
    }
  });

</script>

<%- include("../partials/footer") %>