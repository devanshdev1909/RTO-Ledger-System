<%- include("partials/header") %>

    <div class="container">

        <%- include("partials/sidebar") %>

            <div class="main-content">

                <%- include("partials/navbar") %>

                    <div class="dashboard-content">

                        <h1>Dashboard</h1>

                        <h3>
                            Welcome <%= userName %>
                        </h3>

                        <div class="dashboard-cards">

                            <div class="card" style="--theme-bg: #fff5e6; --theme-dark: #e65100;">
                                <h4>Total Customers</h4>
                                <span class="menu-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                        stroke-linejoin="round">
                                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                                        <circle cx="9" cy="7" r="4" />
                                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                                    </svg>
                                </span>
                                <p>
                                    <%= stats.customers %>
                                </p>
                            </div>

                            <div class="card" style="--theme-bg: #e0f8f5; --theme-dark: #00796b;">
                                <h4>Total Vehicles</h4>
                                <span class="menu-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                        stroke-linejoin="round">
                                        <path d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v9a2 2 0 0 1-2 2h-2" />
                                        <circle cx="7.5" cy="17.5" r="2.5" />
                                        <circle cx="17.5" cy="17.5" r="2.5" />
                                    </svg>
                                </span>
                                <p>
                                    <%= stats.vehicles %>
                                </p>
                            </div>

                            <div class="card" style="--theme-bg: #e8f5e9; --theme-dark: #2e7d32;">
                                <h4>Total Services</h4>
                                <span class="menu-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                        stroke-linejoin="round">
                                        <circle cx="12" cy="12" r="3" />
                                        <path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14" />
                                    </svg>
                                </span>
                                <p>
                                    <%= stats.services %>
                                </p>
                            </div>

                            <div class="card" style="--theme-bg: #ffebee; --theme-dark: #c2185b;">
                                <h4>Total Requests</h4>
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="icon icon-tabler icons-tabler-outline icon-tabler-git-pull-request-conflict">
                                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                    <path d="M16 18a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" />
                                    <path d="M11 6h5a2 2 0 0 1 2 2v8" />
                                    <path d="M4 18a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" />
                                    <path d="M6 11v5" />
                                    <path d="M4 4l4 4" />
                                    <path d="M8 4l-4 4" />
                                </svg>
                                <p>
                                    <%= stats.requests %>
                                </p>
                            </div>

                            <div class="card" style="--theme-bg: #e3f2fd; --theme-dark: #1565c0;">
                                <h4>Pending Jobs</h4>
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="icon icon-tabler icons-tabler-outline icon-tabler-sort-descending-2">
                                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                    <path
                                        d="M5 5.5a.5 .5 0 0 1 .5 -.5h4a.5 .5 0 0 1 .5 .5v4a.5 .5 0 0 1 -.5 .5h-4a.5 .5 0 0 1 -.5 -.5l0 -4" />
                                    <path
                                        d="M5 14.5a.5 .5 0 0 1 .5 -.5h4a.5 .5 0 0 1 .5 .5v4a.5 .5 0 0 1 -.5 .5h-4a.5 .5 0 0 1 -.5 -.5l0 -4" />
                                    <path d="M14 15l3 3l3 -3" />
                                    <path d="M17 18v-12" />
                                </svg>
                                <p>
                                    <%= stats.pendingJobs %>
                                </p>
                            </div>

                            <div class="card" style="--theme-bg: #f3e5f5; --theme-dark: #6a1b9a;">
                                <h4>Completed Jobs</h4>
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="icon icon-tabler icons-tabler-outline icon-tabler-progress-check">
                                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                    <path d="M10 20.777a8.942 8.942 0 0 1 -2.48 -.969" />
                                    <path d="M14 3.223a9.003 9.003 0 0 1 0 17.554" />
                                    <path d="M4.579 17.093a8.961 8.961 0 0 1 -1.227 -2.592" />
                                    <path d="M3.124 10.5c.16 -.95 .468 -1.85 .9 -2.675l.169 -.305" />
                                    <path d="M6.907 4.579a8.954 8.954 0 0 1 3.093 -1.356" />
                                    <path d="M9 12l2 2l4 -4" />
                                </svg>
                                <p>
                                    <%= stats.completedJobs %>
                                </p>
                            </div>

                            <div class="card" style="--theme-bg: #fffde7; --theme-dark: #f57f17;">
                                <h4>Today's Requests</h4>
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="icon icon-tabler icons-tabler-outline icon-tabler-git-pull-request-conflict">
                                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                    <path d="M16 18a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" />
                                    <path d="M11 6h5a2 2 0 0 1 2 2v8" />
                                    <path d="M4 18a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" />
                                    <path d="M6 11v5" />
                                    <path d="M4 4l4 4" />
                                    <path d="M8 4l-4 4" />
                                </svg>
                                <p>
                                    <%= stats.todayRequests %>
                                </p>
                            </div>

                            <div class="card" style="--theme-bg: #e0f7fa; --theme-dark: #00838f;">
                                <h4>Total Revenue</h4>
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="lucide lucide-circle-arrow-down h-8 w-8 text-emerald-700 opacity-80">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <path d="M12 8v8"></path>
                                    <path d="m8 12 4 4 4-4"></path>
                                </svg>
                                <p>₹<%= Number(stats.revenue).toLocaleString("en-IN") %>
                                </p>
                            </div>

                            <div class="card" style="--theme-bg: #fce4ec; --theme-dark: #d32f2f;">
                                <h4>Total Due Amount</h4>
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="lucide lucide-circle-arrow-up h-8 w-8 text-rose-700 opacity-80">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <path d="m16 12-4-4-4 4"></path>
                                    <path d="M12 16V8"></path>
                                </svg>
                                <p>₹<%= Number(stats.dueAmount).toLocaleString("en-IN") %>
                                </p>
                            </div>

                        </div>

                        <!-- Charts Section -->
                        <div class="charts-container"
                            style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; margin-top: 32px;">
                            <!-- Job status pie chart -->
                            <div class="card chart-card" style="min-height:300px; display: flex; flex-direction: column; align-items: center; justify-content: center; border:2px solid rgb(208, 207, 207);">
                                <h4 style="margin-bottom: 20px; color: var(--text-primary); text-align: center;">Job Status Overview</h4>
                                <div style="width: 100%; max-width: 280px; flex-grow: 1; display: flex; align-items: center; justify-content: center;">
                                    <canvas id="jobStatusChart"></canvas>
                                </div>
                            </div>  

                            <!-- Financial Overview Doughnut Chart -->
                            <div class="card chart-card" style="min-height:300px; display: flex; flex-direction: column; align-items: center; justify-content: center; border:2px solid rgb(208, 207, 207);">
                                <h4 style="margin-bottom: 20px; text-align: center; color: var(--text-primary);">Financial Overview</h4>
                                <div style="width: 100%; max-width: 280px; flex-grow: 1; display: flex; align-items: center; justify-content: center;">
                                    <canvas id="financeChart"></canvas>
                                </div>
                            </div>
                        </div>

                    </div>

            </div>

    </div>

    <!-- Ye line internet se Chart.js library fetch karegi, isliye npm install ki zaroorat nahi hai -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Backend se EJS ke through aapka data le rahe hain
            const chartPending = Number("<%= stats.pendingJobs || 0 %>");
            const chartCompleted = Number("<%= stats.completedJobs || 0 %>");
            const chartRevenue = Number("<%= stats.revenue || 0 %>");
            const chartDue = Number("<%= stats.dueAmount || 0 %>");

            // 1. Job Status ka Pie Chart draw karna
            const ctxJob = document.getElementById('jobStatusChart').getContext('2d');
            new Chart(ctxJob, {
                type: 'doughnut',
                data: {
                    labels: ['Pending', 'Completed'], // Shortened to fit in one line
                    datasets: [{
                        data: [chartPending, chartCompleted],
                        backgroundColor: ['#1565c0', '#6a1b9a'], // Blue & Purple colors
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { 
                        legend: { 
                            position: 'bottom',
                            labels: { boxWidth: 15 } // Smaller color box
                        } 
                    }
                }
            });

            // 2. Financial Overview ka Doughnut Chart draw karna
            const ctxFinance = document.getElementById('financeChart').getContext('2d');
            new Chart(ctxFinance, {
                type: 'doughnut',
                data: {
                    labels: ['Total Revenue', 'Due Amount'],
                    datasets: [{
                        data: [chartRevenue, chartDue],
                        backgroundColor: ['#00838f', '#d32f2f'], // Teal & Red colors
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { 
                        legend: { 
                            position: 'bottom',
                            labels: { boxWidth: 15 } // Smaller color box
                        } 
                    }
                }
            });
        });
    </script>


    <%- include("partials/footer") %>