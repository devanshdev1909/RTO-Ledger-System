<h1>Signup</h1>

<form action="/signup" method="POST">

    <input
        type="text"
        name="fullName"
        placeholder="Full Name"
        required
    >

    <br><br>

    <input
        type="email"
        name="email"
        placeholder="Email"
        required
    >

    <br><br>

    <input
        type="text"
        name="mobile"
        placeholder="Mobile"
        required
    >

    <br><br>

    <input
        type="password"
        name="password"
        placeholder="Password"
        required
    >

    <br><br>

    <button type="submit">
        Signup
    </button>

</form>