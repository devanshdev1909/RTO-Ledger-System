<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RTO Ledger - Login</title>
    <link rel="stylesheet" href="/css/login.css">
    <link rel="stylesheet" href="/css/register.css">
</head>

<body>

    <div class="background-shape shape-1"></div>
    <div class="background-shape shape-2"></div>

    <div class="login-container">

        <div class="login-card">

            <div class="logo-section reg-header">
                <div class="logo-icon">🚗</div>
                <h1>RTO Ledger</h1>
                <p>Welcome back, please log in below</p>
            </div>

            <div class="tabs">
                <button class="tab-btn <%= locals.activeTab === 'customer' ? 'active' : '' %>"
                    onclick="switchTab('customer')">Customer</button>
                <button class="tab-btn <%= locals.activeTab === 'customer' ? '' : 'active' %>"
                    onclick="switchTab('staff')">Staff</button>
            </div>

            <% if (locals.error) { %>
                <div
                    style="background-color: #ffdddd; color: #d8000c; padding: 12px 35px; font-size: 14px; text-align: center; border-bottom: 1px solid #ffcccc;">
                    <%= error %>
                </div>
                <% } %>

                    <!-- CUSTOMER LOGIN FORM -->
                    <form id="customer-form" class="form-content <%= locals.activeTab === 'customer' ? 'active' : '' %>"
                        action="/portal/login" method="POST">
                        <div class="form-group-sm">
                            <label>Email or Mobile Number</label>
                            <div class="input-icon-wrap">
                                <span class="input-icon">📱</span>
                                <input type="text" name="identifier" placeholder="Enter email or mobile" required>
                            </div>
                        </div>
                        <div class="form-group-sm">
                            <label>Password</label>
                            <div class="input-icon-wrap">
                                <span class="input-icon">🔒</span>
                                <input type="password" id="customerPassword" name="password"
                                    placeholder="Enter your password" required>
                                <button type="button" class="toggle-pw"
                                    onclick="togglePw('customerPassword', this)">👁</button>
                            </div>
                        </div>
                        <button type="submit" class="login-btn reg-next-btn"
                            style="background:#10b981; width:100%; margin-top:10px;">Login as Customer &rarr;</button>

                        <div class="customer-register-link"
                            style="margin-top: 15px; display: flex; flex-direction: column; gap: 8px;">
                            <div>Staff created your account? <a href="/portal/activate">Activate it here</a></div>
                            <div>Don't have an account at all? <a href="/portal/register">Register here</a></div>
                        </div>
                    </form>

                    <!-- STAFF LOGIN FORM -->
                    <form id="staff-form" class="form-content <%= locals.activeTab === 'customer' ? '' : 'active' %>"
                        action="/login" method="POST">
                        <div class="form-group-sm">
                            <label>Email Address</label>
                            <div class="input-icon-wrap">
                                <span class="input-icon">✉️</span>
                                <input type="email" name="email" placeholder="Enter your email" required>
                            </div>
                        </div>
                        <div class="form-group-sm">
                            <label>Password</label>
                            <div class="input-icon-wrap">
                                <span class="input-icon">🔒</span>
                                <input type="password" id="staffPassword" name="password"
                                    placeholder="Enter your password" required>
                                <button type="button" class="toggle-pw"
                                    onclick="togglePw('staffPassword', this)">👁</button>
                            </div>
                        </div>
                        <button type="submit" class="login-btn reg-next-btn"
                            style="background:#3b82f6; width:100%; margin-top:10px;">Login as Staff &rarr;</button>
                    </form>

                    <div class="footer-text">
                        RTO Management System © 2026
                    </div>

        </div>

    </div>

    <script>
        function switchTab(type) {
            // Update Tab Buttons
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');

            // Update Forms
            document.querySelectorAll('.form-content').forEach(form => {
                form.classList.remove('active');
            });
            document.getElementById(type + '-form').classList.add('active');
        }

        function togglePw(id, btn) {
            const inp = document.getElementById(id);
            if (inp.type === 'password') { inp.type = 'text'; btn.textContent = '🙈'; }
            else { inp.type = 'password'; btn.textContent = '👁'; }
        }
    </script>

</body>

</html>