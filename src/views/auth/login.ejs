<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RTO Ledger - Login</title>
    <link rel="stylesheet" href="/css/login.css">
</head>
<body>

    <div class="background-shape shape-1"></div>
    <div class="background-shape shape-2"></div>

    <div class="login-container">

        <div class="login-card">

            <div class="logo-section">
                <div class="logo-icon">🚗</div>
                <h1>RTO Ledger</h1>
                <p>Customer, Vehicle, Service, Ledger & Receipt Management System</p>
            </div>

            <div class="tabs">
                <button class="tab-btn <%= locals.activeTab === 'customer' ? '' : 'active' %>" onclick="switchTab('staff')">Staff</button>
                <button class="tab-btn <%= locals.activeTab === 'customer' ? 'active' : '' %>" onclick="switchTab('customer')">Customer</button>
            </div>

            <% if (locals.error) { %>
                <div style="background-color: #ffdddd; color: #d8000c; padding: 12px 35px; font-size: 14px; text-align: center; border-bottom: 1px solid #ffcccc;">
                    <%= error %>
                </div>
            <% } %>

            <!-- STAFF LOGIN FORM -->
            <form id="staff-form" class="form-content <%= locals.activeTab === 'customer' ? '' : 'active' %>" action="/login" method="POST">
                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" name="email" placeholder="Enter your email" required>
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" name="password" placeholder="Enter your password" required>
                </div>
                <button type="submit" class="login-btn">Login as Staff</button>
            </form>

            <!-- CUSTOMER LOGIN FORM -->
            <form id="customer-form" class="form-content <%= locals.activeTab === 'customer' ? 'active' : '' %>" action="/portal/login" method="POST">
                <div class="form-group">
                    <label>Email or Mobile Number</label>
                    <input type="text" name="identifier" placeholder="Enter email or mobile" required>
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" name="password" placeholder="Enter your password" required>
                </div>
                <button type="submit" class="login-btn" style="background-color: #10b981;">Login as Customer</button>
                
                <div class="customer-register-link">
                    Don't have an account? <a href="/portal/register">Register here</a>
                </div>
            </form>

            <div class="footer-text">
                RTO Ledger Management System © 2026
            </div>

        </div>

    </div>

    <script>
        function switchTab(type) {
            // Update Tab Buttons
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');

            // Update Forms
            document.querySelectorAll('.form-content').forEach(form => {
                form.classList.remove('active');
            });
            document.getElementById(type + '-form').classList.add('active');
        }
    </script>

</body>
</html>