<%- include("../partials/header") %>

    <div class="container">
        <%- include("../partials/sidebar") %>

            <div class="main-content">
                <%- include("../partials/navbar") %>

                    <div class="content">
                        <div class="page-header">
                            <h1>Receipts</h1>
                        </div>

                        <div class="table-container">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Receipt No</th>
                                        <th>Customer</th>
                                        <th>Service</th>
                                        <th>Amount Received</th>
                                        <th>Payment Mode</th>
                                        <th>Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (!receipts || receipts.length===0) { %>
                                        <tr>
                                            <td colspan="8" style="text-align: center;">No Receipts Found</td>
                                        </tr>
                                        <% } else { %>
                                            <% receipts.forEach((r, i)=> { %>
                                                <tr>
                                                    <td>
                                                        <%= i + 1 %>
                                                    </td>
                                                    <td><strong>
                                                            <%= r.receipt_no %>
                                                        </strong></td>
                                                    <td>
                                                        <%= r.customer_name %>
                                                    </td>
                                                    <td>
                                                        <%= r.service_name %>
                                                    </td>
                                                    <td>₹<%= parseFloat(r.amount_received).toFixed(2) %>
                                                    </td>
                                                    <td>
                                                        <span class="badge"
                                                            style="background:#e0f2fe; color:#0369a1; padding: 4px 8px; border-radius: 4px; font-weight: bold;">
                                                            <%= r.payment_mode %>
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <%= new Date(r.received_at).toLocaleString('en-IN', {
                                                            timeZone: 'Asia/Kolkata' , dateStyle: 'short' ,
                                                            timeStyle: 'short' }) %>
                                                    </td>
                                                    <td class="actions">
                                                        <a href="/receipts/<%= r.id %>" class="btn btn-view">View &
                                                            Print</a>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
            </div>
    </div>

    <%- include("../partials/footer") %>