<%- include("../partials/header") %>

<div class="container">
  <%- include("../partials/sidebar") %>

  <div class="main-content">
    <%- include("../partials/navbar") %>

    <div class="content">
      <div class="page-header">
        <h1>Receipts</h1>
      </div>

      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th style="text-align: center;">#</th>
              <th style="text-align: center;">Receipt No</th>
              <th style="text-align: center;">Customer</th>
              <th style="text-align: center;">Service</th>
              <th style="text-align: center;">Amount Received</th>
              <th style="text-align: center;">Payment Mode</th>
              <th style="text-align: center;">Date</th>
              <th style="text-align: center;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!receipts || receipts.length===0) { %>
            <tr>
              <td colspan="8" style="text-align: center;">No Receipts Found</td>
            </tr>
            <% } else { %>
            <% receipts.forEach((r, i)=> { %>
            <tr>
              <td style="text-align: center;">
                <%= i + 1 %>
              </td>
              <td style="text-align: center;"><strong>
                  <%= r.receipt_no %>
                </strong></td>
              <td style="text-align: center;">
                <%= r.customer_name %>
              </td>
              <td style="text-align: center;">
                <%= r.service_name %>
              </td>
              <td style="text-align: center;">₹<%= parseFloat(r.amount_received).toFixed(2) %>
              </td>
              <td style="text-align: center;">
                <span class="badge" style="background:#e0f2fe; color:#0369a1; padding: 4px 8px; border-radius: 4px; font-weight: bold;">
                  <%= r.payment_mode %>
                </span>
              </td>
              <td style="text-align: center;">
                <%= new Date(r.received_at).toLocaleString('en-IN', {
                                                            timeZone: 'Asia/Kolkata' , dateStyle: 'short' ,
                                                            timeStyle: 'short' }) %>
              </td>
              <td class="actions" style="text-align: center;">

                <!-- VIEW / PRINT ICON -->
                <a href="/receipts/<%= r.id %>" class="btn-icon view-icon" title="View & Print">

                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">

                    <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z" />
                    <circle cx="12" cy="12" r="3" />
                  </svg>

                </a>

              </td>
            </tr>
            <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include("../partials/footer") %>