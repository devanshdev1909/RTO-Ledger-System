<%- include("../partials/header") %>

    <div class="container no-print-layout">
        <%- include("../partials/sidebar") %>

            <div class="main-content">
                <%- include("../partials/navbar") %>

                    <div class="content">
                        <div class="page-header">
                            <h1>View Receipt</h1>
                            <div>
                                <a href="/receipts" class="btn btn-secondary">← Back</a>
                                <button onclick="window.print()" class="btn btn-primary">Print Receipt</button>
                            </div>
                        </div>

                        <div class="receipt-card-container">
                            <div class="receipt-docket">
                                <div class="docket-header">
                                    <h2>RTO Ledger Receipt</h2>
                                    <p class="subtitle">Official Payment Receipt</p>
                                </div>

                                <div class="docket-divider"></div>

                                <div class="docket-row">
                                    <span class="docket-label">Receipt No</span>
                                    <span class="docket-value highlight">
                                        <%= receipt.receipt_no %>
                                    </span>
                                </div>

                                <div class="docket-divider"></div>

                                <div class="docket-row">
                                    <span class="docket-label">Customer</span>
                                    <span class="docket-value">
                                        <%= receipt.customer_name %>
                                    </span>
                                </div>
                                <div class="docket-row">
                                    <span class="docket-label">Mobile</span>
                                    <span class="docket-value">
                                        <%= receipt.customer_mobile %>
                                    </span>
                                </div>

                                <div class="docket-divider"></div>

                                <div class="docket-row">
                                    <span class="docket-label">Vehicle No</span>
                                    <span class="docket-value">
                                        <%= receipt.vehicle_number || 'No Vehicle' %>
                                    </span>
                                </div>
                                <div class="docket-row">
                                    <span class="docket-label">Chassis No</span>
                                    <span class="docket-value">
                                        <%= receipt.chassis_number || 'N/A' %>
                                    </span>
                                </div>
                                <div class="docket-row">
                                    <span class="docket-label">Engine No</span>
                                    <span class="docket-value">
                                        <%= receipt.engine_number || 'N/A' %>
                                    </span>
                                </div>

                                <div class="docket-divider"></div>

                                <div class="docket-row">
                                    <span class="docket-label">Request No</span>
                                    <span class="docket-value">
                                        <%= receipt.request_no %>
                                    </span>
                                </div>
                                <div class="docket-row">
                                    <span class="docket-label">Service</span>
                                    <span class="docket-value">
                                        <%= receipt.service_name %>
                                    </span>
                                </div>
                                <div class="docket-row">
                                    <span class="docket-label">Requested At</span>
                                    <span class="docket-value">
                                        <%= new Date(receipt.requested_at).toLocaleString('en-IN', {
                                            timeZone: 'Asia/Kolkata' , dateStyle: 'short' , timeStyle: 'short' }) %>
                                    </span>
                                </div>

                                <div class="docket-divider"></div>

                                <div class="docket-row">
                                    <span class="docket-label">Service Fee</span>
                                    <span class="docket-value">₹<%= parseFloat(receipt.service_fee).toFixed(0) %></span>
                                </div>
                                <div class="docket-row">
                                    <span class="docket-label">Paid Amount</span>
                                    <span class="docket-value">₹<%= parseFloat(receipt.amount_paid).toFixed(0) %></span>
                                </div>
                                <div class="docket-row">
                                    <span class="docket-label">Due Amount</span>
                                    <span class="docket-value font-bold text-red">₹<%=
                                            parseFloat(receipt.due_amount).toFixed(0) %></span>
                                </div>

                                <div class="docket-divider"></div>

                                <div class="docket-row">
                                    <span class="docket-label">Payment Mode</span>
                                    <span class="docket-value highlight-mode">
                                        <%= receipt.payment_mode %>
                                    </span>
                                </div>

                                <div class="docket-row">
                                    <span class="docket-label">Receipt Date</span>
                                    <span class="docket-value">
                                        <%= new Date(receipt.received_at).toLocaleString('en-IN', {
                                            timeZone: 'Asia/Kolkata' , dateStyle: 'short' , timeStyle: 'short' }) %>
                                    </span>
                                </div>

                                <div class="docket-divider"></div>

                                <div class="docket-footer">
                                    <p>Thank you for your business!</p>
                                </div>
                            </div>
                        </div>
                    </div>
            </div>
    </div>

    <style>
        .receipt-card-container {
            display: flex;
            justify-content: center;
            padding: 20px 0;
        }

        .receipt-docket {
            background: #ffffff;
            width: 100%;
            max-width: 450px;
            padding: 30px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            font-family: 'Courier New', Courier, monospace;
            color: #1a202c;
        }

        .docket-header {
            text-align: center;
            margin-bottom: 15px;
        }

        .docket-header h2 {
            margin: 0;
            font-size: 20px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .docket-header .subtitle {
            margin: 5px 0 0 0;
            font-size: 12px;
            color: #718096;
        }

        .docket-divider {
            border-top: 1px dashed #cbd5e1;
            margin: 15px 0;
        }

        .docket-row {
            display: flex;
            justify-content: space-between;
            margin: 8px 0;
            font-size: 14px;
            line-height: 1.4;
        }

        .docket-label {
            color: #4a5568;
            font-weight: bold;
        }

        .docket-value {
            text-align: right;
        }

        .docket-value.highlight {
            font-weight: bold;
            color: #2b6cb0;
        }

        .docket-value.highlight-mode {
            font-weight: bold;
            color: #2f855a;
        }

        .font-bold {
            font-weight: bold;
        }

        .text-red {
            color: #c53030;
        }

        .docket-footer {
            text-align: center;
            font-size: 12px;
            color: #718096;
            margin-top: 20px;
        }

        @media print {

            /* Hide all layout elements of the website */
            body * {
                visibility: hidden;
            }

            /* Only display the receipt docket */
            .receipt-docket,
            .receipt-docket * {
                visibility: visible;
            }

            .receipt-card-container {
                position: absolute;
                left: 0;
                top: 0;
                width: 100%;
                padding: 0;
                margin: 0;
            }

            .receipt-docket {
                border: none;
                box-shadow: none;
                max-width: 100%;
                width: 100%;
                padding: 0;
                margin: 0;
            }
        }
    </style>

    <%- include("../partials/footer") %>