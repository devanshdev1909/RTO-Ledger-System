<%- include("../partials/header") %>

    <div class="container">
        <%- include("../partials/sidebar") %>

            <div class="main-content">
                <%- include("../partials/navbar") %>

                    <div class="content">

                        <div class="page-header">
                            <h1>Vehicles</h1>
                            <a href="/vehicles/new" class="btn btn-primary">+ Add Vehicle</a>
                        </div>

                        <div class="table-container">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Vehicle Number</th>
                                        <th>Type</th>
                                        <th>Customer</th>
                                        <th>Chassis No.</th>
                                        <th>Engine No.</th>
                                        <th>Reg. Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (vehicles.length===0) { %>
                                        <tr>
                                            <td colspan="8" class="empty-state">
                                                No vehicles found. Add your first vehicle!
                                            </td>
                                        </tr>
                                        <% } else { %>
                                            <% vehicles.forEach((v, i)=> { %>
                                                <tr>
                                                    <td>
                                                        <%= i + 1 %>
                                                    </td>
                                                    <td><strong>
                                                            <%= v.vehicle_number %>
                                                        </strong></td>
                                                    <td>
                                                        <%= v.vehicle_type %>
                                                    </td>
                                                    <td>
                                                        <%= v.customer_name || "N/A" %>
                                                    </td>
                                                    <td>
                                                        <%= v.chassis_number %>
                                                    </td>
                                                    <td>
                                                        <%= v.engine_number %>
                                                    </td>
                                                    <td>
                                                        <%= v.registration_date ? new
                                                            Date(v.registration_date).toLocaleDateString("en-IN")
                                                            : "N/A" %>
                                                    </td>
                                                    <td class="actions">
                                                        <a href="/vehicles/<%= v.id %>/edit"
                                                            class="btn btn-edit">Edit</a>
                                                        <form action="/vehicles/<%= v.id %>?_method=DELETE"
                                                            method="POST" style="display:inline;">
                                                            <button type="submit" class="btn btn-delete"
                                                                onclick="return confirm('Are you sure?')">Delete</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                    </div>
            </div>
    </div>

    <%- include("../partials/footer") %>