<%- include("../partials/header") %>

<div class="container">
  <%- include("../partials/sidebar") %>

  <div class="main-content">
    <%- include("../partials/navbar") %>

    <div class="content">

      <div class="page-header">
        <h1>Vehicles</h1>
        <% if (permissions.includes('vehicle.create')) { %>
        <button id="openVehicleModal" class="btn btn-primary" onclick="openCreateModal()">+ Add Vehicle</button>
        <% } %>
      </div>

      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">#</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Vehicle Number</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Type</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Customer</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Chassis No.</th>
              <th style="text-align: center; background-color:#203051 ; color:white; font-size:16px;">Engine No.</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Reg. Date</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Status</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (vehicles.length===0) { %>
            <tr>
              <td colspan="9" class="empty-state">
                No vehicles found. Add your first vehicle!
              </td>
            </tr>
            <% } else { %>
            <% vehicles.forEach((v, i)=> { %>
            <tr>
              <td style="text-align: center;">
                <%= i + 1 %>
              </td>
              <td style="text-align: center;"><strong>
                  <%= v.vehicle_number %>
                </strong></td>
              <td style="text-align: center;">
                <%= v.vehicle_type %>
              </td>
              <td style="text-align: center;">
                <%= v.customer_name || "N/A" %>
              </td>
              <td style="text-align: center;">
                <%= v.chassis_number %>
              </td>
              <td style="text-align: center;">
                <%= v.engine_number %>
              </td>
              <td style="text-align: center;">
                <%= v.registration_date ? new Date(v.registration_date).toLocaleDateString("en-IN") : "N/A" %>
              </td>
              <td style="text-align: center;">
                <div class="status-container">
                  <span class="status-text <%= v.is_active !== false ? 'active' : 'inactive' %>">
                    <%= v.is_active !==false ? 'Active' : 'Inactive' %>
                  </span>
                  <label class="switch">
                    <input type="checkbox" class="status-toggle" data-id="<%= v.id %>" <%=v.is_active !==false ? 'checked' : '' %>>
                    <span class="slider"></span>
                  </label>
                </div>
              </td>

              <td class="actions" style="text-align: center;">

                <% if (permissions.includes('vehicle.create')) { %>
                <button type="button" class="btn-icon edit-icon" title="Edit Vehicle" onclick="openEditModal('<%= v.id %>', '<%= v.customer_id %>', '<%= v.vehicle_number %>', '<%= v.vehicle_type %>', '<%= v.chassis_number %>', '<%= v.engine_number %>', '<%= v.registration_date ? new Date(v.registration_date).toISOString().split('T')[0] : '' %>')">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                    <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" />
                    <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415" />
                    <path d="M16 5l3 3" />
                  </svg>
                </button>
                <% } %>

                <% if (permissions.includes('vehicle.create')) { %>
                <form action="/vehicles/<%= v.id %>?_method=DELETE" method="POST" class="delete-form" style="display:inline;">
                  <button type="submit" class="btn-icon delete-icon" title="Delete Vehicle" onclick="return confirm('Are you sure?')">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                      <path d="M4 7l16 0" />
                      <path d="M10 11l0 6" />
                      <path d="M14 11l0 6" />
                      <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" />
                      <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" />
                    </svg>
                  </button>
                </form>
                <% } %>

              </td>
            </tr>
            <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

    </div>
  </div>
</div>

<!-- VEHICLE MODAL -->
<div id="vehicleModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; overflow-y: auto;">
  <div style="background:white; max-width:600px; margin: 10vh auto; padding: 25px; border-radius: 8px; position: relative;">

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
      <h2 id="modalTitle" style="margin: 0;">Add New Vehicle</h2>
      <button type="button" onclick="closeModal()" style="background: none; border: none; font-size: 24px; cursor: pointer; color: #888;">&times;</button>
    </div>

    <form id="vehicleForm" action="/vehicles" method="POST">
      <input type="hidden" id="methodOverride" name="_method" value="PUT" disabled>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
        <div class="form-group">
          <label for="v_customer_id">Customer *</label>
          <select name="customer_id" id="v_customer_id" required style="width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px;">
            <option value="">Select Customer</option>
            <% customers.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label for="v_vehicle_number">Vehicle Number *</label>
          <input type="text" name="vehicle_number" id="v_vehicle_number" placeholder="AB 12 CD 1234" required maxlength="13" pattern="^[A-Z]{2}\s[0-9]{2}\s[A-Z]{2}\s[0-9]{4}$" oninput="let v = this.value.toUpperCase().replace(/[^A-Z0-9]/g, ''); if (v.length > 2) v = v.slice(0,2) + ' ' + v.slice(2); if (v.length > 5) v = v.slice(0,5) + ' ' + v.slice(5); if (v.length > 8) v = v.slice(0,8) + ' ' + v.slice(8,12); this.value = v.slice(0, 13);" style="text-transform: uppercase; width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px;">
        </div>

        <div class="form-group">
          <label for="v_vehicle_type">Vehicle Type *</label>
          <select name="vehicle_type" id="v_vehicle_type" required style="width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px;">
            <option value="">Select Vehicle Type</option>
            <option value="Motor Cycle Without Gear(MCWOG)">Motor Cycle Without Gear (MCWOG)</option>
            <option value="Motor Cycle With Gear(MCWG)">Motor Cycle With Gear (MCWG)</option>
            <option value="Light Motor Vehicle(LMV)">Light Motor Vehicle (LMV)</option>
            <option value="Medium Goods Vehicle(MGV)">Medium Goods Vehicle (MGV)</option>
            <option value="Heavy Goods Vehicle(HGV)">Heavy Goods Vehicle (HGV)</option>
          </select>
        </div>

        <div class="form-group">
          <label for="v_chassis_number">Chassis Number *</label>
          <input type="text" name="chassis_number" id="v_chassis_number" placeholder="CH1234567890" maxlength="12" minlength="12" pattern="^CH[A-Z0-9]{10}$" oninput="if(!this.value.toUpperCase().startsWith('CH')) { this.value = 'CH' + this.value.toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 10); } else { this.value = 'CH' + this.value.substring(2).toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 10); }" style="text-transform: uppercase; width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px;" required>
        </div>

        <div class="form-group">
          <label for="v_engine_number">Engine Number *</label>
          <input type="text" name="engine_number" id="v_engine_number" placeholder="EN1234567890" maxlength="12" minlength="12" pattern="^EN[A-Z0-9]{10}$" oninput="if(!this.value.toUpperCase().startsWith('EN')) { this.value = 'EN' + this.value.toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 10); } else { this.value = 'EN' + this.value.substring(2).toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 10); }" style="text-transform: uppercase; width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px;" required>
        </div>

        <div class="form-group">
          <label for="v_registration_date">Registration Date</label>
          <input type="date" name="registration_date" id="v_registration_date" style="width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px;">
        </div>
      </div>

      <div style="margin-top: 20px; display: flex; gap: 10px; justify-content: flex-end;">
        <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>

    </form>
  </div>
</div>

<script>
  function openCreateModal() {
    document.getElementById('modalTitle').textContent = "Add Vehicle";
    document.getElementById('vehicleForm').action = "/vehicles";
    document.getElementById('methodOverride').disabled = true;

    // Clear fields
    document.getElementById('v_customer_id').value = "";
    document.getElementById('v_vehicle_number').value = "";
    document.getElementById('v_vehicle_type').value = "";
    document.getElementById('v_chassis_number').value = "CH";
    document.getElementById('v_engine_number').value = "EN";
    document.getElementById('v_registration_date').value = "";

    document.getElementById('vehicleModal').style.display = 'block';
  }

  function openEditModal(id, customer_id, vehicle_number, vehicle_type, chassis_number, engine_number, registration_date) {
    document.getElementById('modalTitle').textContent = "Edit Vehicle";
    document.getElementById('vehicleForm').action = "/vehicles/" + id;
    document.getElementById('methodOverride').disabled = false;

    // Pre-fill fields
    document.getElementById('v_customer_id').value = customer_id;
    document.getElementById('v_vehicle_number').value = vehicle_number;
    document.getElementById('v_vehicle_type').value = vehicle_type || "";
    document.getElementById('v_chassis_number').value = chassis_number || "CH";
    document.getElementById('v_engine_number').value = engine_number || "EN";
    document.getElementById('v_registration_date').value = registration_date || "";

    document.getElementById('vehicleModal').style.display = 'block';
  }

  function closeModal() {
    document.getElementById('vehicleModal').style.display = 'none';
  }

  document.addEventListener("DOMContentLoaded", function() {
    document.querySelectorAll(".status-toggle").forEach(checkbox => {
      checkbox.addEventListener("change", async (e) => {
        const vehicleId = e.target.getAttribute("data-id");
        const isActive = e.target.checked;
        const statusText = e.target.closest(".status-container").querySelector(".status-text");

        try {
          const response = await fetch(`/vehicles/${vehicleId}/toggle-status`, {
            method: "PATCH",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify({
              is_active: isActive
            })
          });

          if (!response.ok) {
            throw new Error("Failed to update status");
          }

          const data = await response.json();

          // Update text and class color
          if (isActive) {
            statusText.textContent = "Active";
            statusText.className = "status-text active";
          } else {
            statusText.textContent = "Inactive";
            statusText.className = "status-text inactive";
          }
        } catch (err) {
          console.error("Error toggling status:", err);
          alert("Error updating status: " + err.message);
          e.target.checked = !isActive;
        }
      });
    });
  });

  window.addEventListener('click', function(e) {
    const modal = document.getElementById('vehicleModal');

    if (e.target === modal) {
      modal.style.display = 'none';
    }
  });
</script>

<%- include("../partials/footer") %>