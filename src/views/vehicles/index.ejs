<%- include("../partials/header") %>

    <div class="container">
        <%- include("../partials/sidebar") %>

            <div class="main-content">
                <%- include("../partials/navbar") %>

                    <div class="content">

                        <div class="page-header">
                            <h1>Vehicles</h1>
                            <% if (permissions.includes('vehicle.create')) { %>
                                <a href="/vehicles/new" class="btn btn-primary">+ Add Vehicle</a>
                                <% } %>
                        </div>

                        <div class="table-container">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Vehicle Number</th>
                                        <th>Type</th>
                                        <th>Customer</th>
                                        <th>Chassis No.</th>
                                        <th>Engine No.</th>
                                        <th>Reg. Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (vehicles.length===0) { %>
                                        <tr>
                                            <td colspan="8" class="empty-state">
                                                No vehicles found. Add your first vehicle!
                                            </td>
                                        </tr>
                                        <% } else { %>
                                            <% vehicles.forEach((v, i)=> { %>
                                                <tr>
                                                    <td>
                                                        <%= i + 1 %>
                                                    </td>
                                                    <td><strong>
                                                            <%= v.vehicle_number %>
                                                        </strong></td>
                                                    <td>
                                                        <%= v.vehicle_type %>
                                                    </td>
                                                    <td>
                                                        <%= v.customer_name || "N/A" %>
                                                    </td>
                                                    <td>
                                                        <%= v.chassis_number %>
                                                    </td>
                                                    <td>
                                                        <%= v.engine_number %>
                                                    </td>
                                                    <td>
                                                        <%= v.registration_date ? new
                                                            Date(v.registration_date).toLocaleDateString("en-IN")
                                                            : "N/A" %>
                                                    </td>
                                                    <td class="actions">

    <% if (permissions.includes('vehicle.create')) { %>
        <a href="/vehicles/<%= v.id %>/edit"
           class="btn-icon edit-icon"
           title="Edit Vehicle">

            <svg xmlns="http://www.w3.org/2000/svg"
                 viewBox="0 0 24 24"
                 fill="none"
                 stroke="currentColor"
                 stroke-width="2"
                 stroke-linecap="round"
                 stroke-linejoin="round">

                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" />
                <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415" />
                <path d="M16 5l3 3" />
            </svg>

        </a>
    <% } %>

    <% if (permissions.includes('vehicle.create')) { %>
        <form action="/vehicles/<%= v.id %>?_method=DELETE"
              method="POST"
              class="delete-form">

            <button type="submit"
                    class="btn-icon delete-icon"
                    title="Delete Vehicle"
                    onclick="return confirm('Are you sure?')">

                <svg xmlns="http://www.w3.org/2000/svg"
                     viewBox="0 0 24 24"
                     fill="none"
                     stroke="currentColor"
                     stroke-width="2"
                     stroke-linecap="round"
                     stroke-linejoin="round">

                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                    <path d="M4 7l16 0" />
                    <path d="M10 11l0 6" />
                    <path d="M14 11l0 6" />
                    <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" />
                    <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" />

                </svg>

            </button>

        </form>
    <% } %>

</td>
                                                </tr>
                                                <% }) %>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                    </div>
            </div>
    </div>

    <%- include("../partials/footer") %>