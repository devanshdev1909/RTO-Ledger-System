<%- include('../partials/header') %>

<h1>Add Vehicle</h1>

<form action="/vehicles" method="POST" style="max-width:500px; margin-top:16px;">

    <label>Customer *</label><br>
    <select name="customerId" required style="width:100%; padding:8px; margin-bottom:12px;">
        <option value="">Select Customer</option>
        <% customers.forEach(c => { %>
        <option value="<%= c.id %>"><%= c.full_name %> (<%= c.mobile %>)</option>
        <% }) %>
    </select><br>

    <label>Vehicle Number *</label><br>
    <input type="text" name="vehicleNumber" placeholder="e.g. MH12AB1234" required style="width:100%; padding:8px; margin-bottom:12px;"><br>

    <label>Vehicle Type</label><br>
    <select name="vehicleType" style="width:100%; padding:8px; margin-bottom:12px;">
        <option value="">Select Type</option>
        <option value="two-wheeler">Two Wheeler</option>
        <option value="four-wheeler">Four Wheeler</option>
        <option value="commercial">Commercial</option>
        <option value="other">Other</option>
    </select><br>

    <label>Make *</label><br>
    <input type="text" name="make" required style="width:100%; padding:8px; margin-bottom:12px;"><br>

    <label>Model *</label><br>
    <input type="text" name="model" required style="width:100%; padding:8px; margin-bottom:12px;"><br>

    <label>Year</label><br>
    <input type="number" name="year" style="width:100%; padding:8px; margin-bottom:12px;"><br>

    <label>Chassis Number</label><br>
    <input type="text" name="chassisNumber" style="width:100%; padding:8px; margin-bottom:12px;"><br>

    <label>Engine Number</label><br>
    <input type="text" name="engineNumber" style="width:100%; padding:8px; margin-bottom:12px;"><br>

    <button type="submit" style="padding:10px 24px; background:#1a237e; color:#fff; border:none; border-radius:4px; cursor:pointer;">
        Add Vehicle
    </button>
</form>

<%- include('../partials/footer') %>
