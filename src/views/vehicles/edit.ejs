<%- include("../partials/header") %>

    <div class="container">
        <%- include("../partials/sidebar") %>

            <div class="main-content">
                <%- include("../partials/navbar") %>

                    <div class="content">

                        <div class="page-header">
                            <h1>Edit Vehicle</h1>
                            <a href="/vehicles" class="btn btn-secondary">← Back</a>
                        </div>

                        <div class="form-card">
                            <form action="/vehicles/<%= vehicle.id %>?_method=PUT" method="POST">

                                <div class="form-group">
                                    <label for="customer_id">Customer</label>
                                    <select name="customer_id" id="customer_id" required>
                                        <option value="">Select Customer</option>
                                        <% customers.forEach(c=> { %>
                                            <option value="<%= c.id %>" <%=c.id==vehicle.customer_id ? 'selected' : ''
                                                %>><%= c.name %>
                                            </option>
                                            <% }) %>
                                    </select>
                                </div>

                                <div class="form-group">
                                    <label for="vehicle_number">Vehicle Number</label>
                                    <input type="text" name="vehicle_number" id="vehicle_number"
                                        placeholder="AB 12 CD 1234"
                                        value="<%= typeof vehicle !== 'undefined' ? vehicle.vehicle_number : '' %>"
                                        required maxlength="13" pattern="^[A-Z]{2}\s[0-9]{2}\s[A-Z]{2}\s[0-9]{4}$"
                                        oninput="let v = this.value.toUpperCase().replace(/[^A-Z0-9]/g, ''); if (v.length > 2) v = v.slice(0,2) + ' ' + v.slice(2); if (v.length > 5) v = v.slice(0,5) + ' ' + v.slice(5); if (v.length > 8) v = v.slice(0,8) + ' ' + v.slice(8,12); this.value = v.slice(0, 13);"
                                        style="text-transform: uppercase;">
                                </div>


                                <div class="form-group">
                                    <label for="vehicle_type">Vehicle Type</label>
                                    <select name="vehicle_type" id="vehicle_type" required>
                                        <option value="">Select Vehicle Type</option>
                                        <option value="Motor Cycle Without Gear(MCWOG)"
                                            <%=vehicle.vehicle_type==='Motor Cycle Without Gear(MCWOG)' ? 'selected'
                                            : '' %>>Motor Cycle Without Gear (MCWOG)</option>
                                        <option value="Motor Cycle With Gear(MCWG)"
                                            <%=vehicle.vehicle_type==='Motor Cycle With Gear(MCWG)' ? 'selected' : '' %>
                                            >Motor Cycle With Gear (MCWG)</option>
                                        <option value="Light Motor Vehicle(LMV)"
                                            <%=vehicle.vehicle_type==='Light Motor Vehicle(LMV)' ? 'selected' : '' %>
                                            >Light Motor Vehicle (LMV)</option>
                                        <option value="Medium Goods Vehicle(MGV)"
                                            <%=vehicle.vehicle_type==='Medium Goods Vehicle(MGV)' ? 'selected' : '' %>
                                            >Medium Goods Vehicle (MGV)</option>
                                        <option value="Heavy Goods Vehicle(HGV)"
                                            <%=vehicle.vehicle_type==='Heavy Goods Vehicle(HGV)' ? 'selected' : '' %>
                                            >Heavy Goods Vehicle (HGV)</option>
                                    </select>
                                </div>


                                <div class="form-group">
                                    <label for="chassis_number">Chassis Number</label>
                                    <input type="text" name="chassis_number" id="chassis_number"
                                        placeholder="CH1234567890"
                                        value="<%= typeof vehicle !== 'undefined' ? (vehicle.chassis_number ? vehicle.chassis_number : 'CH') : 'CH' %>"
                                        maxlength="12" pattern="^CH[A-Z0-9]{10}$"
                                        oninput="if(!this.value.toUpperCase().startsWith('CH')) { this.value = 'CH' + this.value.toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 10); } else { this.value = 'CH' + this.value.substring(2).toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 10); }"
                                        style="text-transform: uppercase;" required>
                                </div>



                                <div class="form-group">
                                    <label for="engine_number">Engine Number</label>
                                    <input type="text" name="engine_number" id="engine_number"
                                        placeholder="EN1234567890"
                                        value="<%= typeof vehicle !== 'undefined' ? (vehicle.engine_number ? vehicle.engine_number : 'EN') : 'EN' %>"
                                        maxlength="12" pattern="^EN[A-Z0-9]{10}$"
                                        oninput="if(!this.value.toUpperCase().startsWith('EN')) { this.value = 'EN' + this.value.toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 10); } else { this.value = 'EN' + this.value.substring(2).toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 10); }"
                                        style="text-transform: uppercase;" required>
                                </div>



                                <div class="form-group">
                                    <label for="registration_date">Registration Date</label>
                                    <input type="date" name="registration_date" id="registration_date"
                                        value="<%= vehicle.registration_date ? new Date(vehicle.registration_date).toISOString().split('T')[0] : '' %>">
                                </div>

                                <button type="submit" class="btn btn-primary">Update Vehicle</button>

                            </form>
                        </div>

                    </div>
            </div>
    </div>

    <%- include("../partials/footer") %>