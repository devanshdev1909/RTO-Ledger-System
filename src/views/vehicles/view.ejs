<%- include('../partials/header') %>

<h1>Vehicle Details</h1>

<div style="margin-top:16px; background:#fff; padding:20px; border-radius:8px;">
    <p><strong>Vehicle No:</strong> <%= vehicle.vehicle_number %></p>
    <p><strong>Type:</strong> <%= vehicle.vehicle_type || '-' %></p>
    <p><strong>Make:</strong> <%= vehicle.make %></p>
    <p><strong>Model:</strong> <%= vehicle.model %></p>
    <p><strong>Year:</strong> <%= vehicle.year || '-' %></p>
    <p><strong>Chassis No:</strong> <%= vehicle.chassis_number || '-' %></p>
    <p><strong>Engine No:</strong> <%= vehicle.engine_number || '-' %></p>
    <p><strong>Customer:</strong> <%= vehicle.customer_name %></p>
</div>

<div style="margin-top:16px;">
    <a href="/vehicles/<%= vehicle.id %>/edit">Edit</a> |
    <form action="/vehicles/<%= vehicle.id %>/delete" method="POST" style="display:inline;">
        <button type="submit" onclick="return confirm('Are you sure?')" style="background:#c62828; color:#fff; border:none; padding:6px 12px; border-radius:4px; cursor:pointer;">
            Delete
        </button>
    </form>
</div>

<%- include('../partials/footer') %>
