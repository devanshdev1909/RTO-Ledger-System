<%- include("../partials/header") %>

    <div class="container">
        <%- include("../partials/sidebar") %>

            <div class="main-content">
                <%- include("../partials/navbar") %>

                    <div class="content">

                        <div class="page-header">
                            <h1>Services</h1>

                            <button onclick="openAddServiceModal()" class="btn btn-primary">+ Add Service</button>

                        </div>

                        <div class="table-container">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Service Name</th>
                                        <th>Default Fee</th>
                                        <th>Description</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <% if (!services || services.length===0) { %>
                                        <tr>
                                            <td colspan="6" class="empty-state">
                                                No services found.
                                            </td>
                                        </tr>
                                        <% } else { %>
                                            <% services.forEach((service, i)=> { %>
                                                <tr>
                                                    <td>
                                                        <%= i + 1 %>
                                                    </td>

                                                    <td>
                                                        <strong>
                                                            <%= service.service_name %>
                                                        </strong>
                                                    </td>

                                                    <td>₹ <%= service.default_fee %>
                                                    </td>

                                                    <td>
                                                        <%= service.description || "N/A" %>
                                                    </td>

                                                    <td>
                                                        <div class="status-container">
                                                            <span
                                                                class="status-text <%= service.is_active ? 'active' : 'inactive' %>">
                                                                <%= service.is_active ? 'Active' : 'Inactive' %>
                                                            </span>
                                                            <label class="switch">
                                                                <input type="checkbox" class="status-toggle"
                                                                    data-id="<%= service.id %>" <%=service.is_active
                                                                    ? 'checked' : '' %>>
                                                                <span class="slider"></span>
                                                            </label>
                                                        </div>
                                                    </td>

                                                    <td class="actions">
                                                        <!-- EDIT ICON -->
                                                        <button type="button"
                                                            onclick="openEditServiceModal('<%= service.id %>', '<%= service.service_name %>', '<%= service.default_fee %>', `<%= service.description || '' %>`, '<%= service.is_active %>')"
                                                            class="btn-icon edit-icon" title="Edit Service">
                                                            <!-- Keep your existing SVG icon here -->
                                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                                fill="none" stroke="currentColor" stroke-width="2"
                                                                stroke-linecap="round" stroke-linejoin="round">
                                                                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                                                <path
                                                                    d="M7 7h-1a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2v-1" />
                                                                <path
                                                                    d="M20.385 6.585a2.1 2.1 0 0 0-2.97-2.97l-8.415 8.385v3h3l8.385-8.415" />
                                                                <path d="M16 5l3 3" />
                                                            </svg>
                                                        </button>

                                                        <!-- DELETE ICON -->
                                                        <form action="/services/<%= service.id %>?_method=DELETE"
                                                            method="POST" class="delete-form">
                                                            <button type="submit" class="btn-icon delete-icon"
                                                                title="Delete Service"
                                                                onclick="return confirm('Are you sure you want to delete this service?')">
                                                                <svg xmlns="http://www.w3.org/2000/svg"
                                                                    viewBox="0 0 24 24" fill="none"
                                                                    stroke="currentColor" stroke-width="2"
                                                                    stroke-linecap="round" stroke-linejoin="round">
                                                                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                                                    <path d="M4 7h16" />
                                                                    <path d="M10 11v6" />
                                                                    <path d="M14 11v6" />
                                                                    <path
                                                                        d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2l1-12" />
                                                                    <path d="M9 7v-3a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v3" />
                                                                </svg>
                                                            </button>
                                                        </form>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                    </div>
            </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            document.querySelectorAll(".status-toggle").forEach(toggle => {
                toggle.addEventListener("change", async (e) => {
                    const id = e.target.getAttribute("data-id");
                    const isChecked = e.target.checked;
                    const statusText = e.target.closest(".status-container").querySelector(".status-text");

                    try {
                        const response = await fetch(`/services/${id}/toggle-status`, {
                            method: "PATCH",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ is_active: isChecked })
                        });

                        // Check if HTTP response status is between 200-299
                        if (!response.ok) {
                            alert(`Error updating status: Server returned ${response.status}`);
                            e.target.checked = !isChecked;
                            return;
                        }

                        const result = await response.json();
                        if (!result.success) {
                            alert("Error updating status: " + result.error);
                            e.target.checked = !isChecked;
                        } else {
                            if (isChecked) {
                                statusText.textContent = "Active";
                                statusText.className = "status-text active";
                            } else {
                                statusText.textContent = "Inactive";
                                statusText.className = "status-text inactive";
                            }
                        }
                    } catch (error) {
                        console.error(error);
                        alert("Network error updating status.");
                        e.target.checked = !isChecked;
                    }
                });
            });

        });
    </script>

    <!-- Service Modal -->
    <div id="serviceModal"
        style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; overflow-y: auto; padding: 20px; box-sizing: border-box;">
        <div style="background:white; max-width:500px; margin: 5vh auto; padding: 20px; border-radius: 8px;">
            <h2 id="modalTitle">Add Service</h2>
            <form id="serviceForm" action="/services" method="POST">
                <!-- This hidden input is for method-override during Edit (PUT request) -->
                <input type="hidden" id="methodOverride" name="_method" value="PUT" disabled>

                <div class="form-group" style="margin-top: 15px;">
                    <label>Service Name *</label>
                    <input type="text" id="service_name" name="service_name" required>
                </div>

                <div class="form-group" style="margin-top: 15px;">
                    <label>Default Fee *</label>
                    <input type="number" id="default_fee" name="default_fee" required>
                </div>

                <div class="form-group" style="margin-top: 15px;">
                    <label>Description</label>
                    <textarea id="description" name="description" rows="3"></textarea>
                </div>
                <div style="margin-top: 20px; display: flex; gap: 10px; justify-content: flex-end;">
                    <button type="button" onclick="document.getElementById('serviceModal').style.display='none'"
                        class="btn btn-secondary">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Service</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function openAddServiceModal() {
            document.getElementById('serviceModal').style.display = 'block';
            document.getElementById('modalTitle').innerText = 'Add Service';
            document.getElementById('serviceForm').action = '/services';
            document.getElementById('methodOverride').disabled = true; // Use normal POST
            document.getElementById('serviceForm').reset();
        }

        function openEditServiceModal(id, name, fee, desc, isActive) {
            document.getElementById('serviceModal').style.display = 'block';
            document.getElementById('modalTitle').innerText = 'Edit Service';
            document.getElementById('serviceForm').action = '/services/' + id + '?_method=PUT';
            document.getElementById('methodOverride').disabled = false; // Enable method override for PUT

            document.getElementById('service_name').value = name;
            document.getElementById('default_fee').value = fee;
            document.getElementById('description').value = desc;
        }
    </script>

    <%- include("../partials/footer") %>