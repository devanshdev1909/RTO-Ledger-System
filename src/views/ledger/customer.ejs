<%- include("../partials/header") %>

<div class="container">
  <%- include("../partials/sidebar") %>
  <div class="main-content">
    <%- include("../partials/navbar") %>
    <div class="content">

      <div class="page-header">
        <h1>Ledger — <%= customer.name %>
        </h1>
        <a href="/ledger" class="btn btn-secondary" style="text-decoration: none;">← Back</a>
      </div>

      <!-- Summary Cards -->
      <div class="ledger-summary">
        <div class="card">
          <h4>Total Service Fee</h4>
          <p>₹<%= totals.totalFee.toLocaleString("en-IN") %>
          </p>
        </div>
        <div class="card">
          <h4>Total Paid</h4>
          <p>₹<%= totals.totalPaid.toLocaleString("en-IN") %>
          </p>
        </div>
        <div class="card card-warning">
          <h4>Total Due</h4>
          <p>₹<%= totals.totalDue.toLocaleString("en-IN") %>
          </p>
        </div>
      </div>

      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Vehicle</th>
              <th>Service</th>
              <th>Service Fee</th>
              <th>Amount Paid</th>
              <th>Due Amount</th>
              <th>Status</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% if (ledgers.length===0) { %>
            <tr>
              <td colspan="7" class="empty-state">No ledger entries for this customer.
              </td>
            </tr>
            <% } else { %>
            <% ledgers.forEach((l, i)=> { %>
            <tr>
              <td>
                <%= i + 1 %>
              </td>
              <td>
                <%= l.vehicle_number || "N/A" %>
              </td>
              <td>
                <%= l.service_name || "Manual Entry" %>
              </td>
              <td>₹<%= Number(l.service_fee).toLocaleString("en-IN") %>
              </td>
              <td>₹<%= Number(l.amount_paid).toLocaleString("en-IN") %>
              </td>
              <% const dueClass=l.due_amount> 0 ? 'amount-due' : 'amount-clear';
                                                        %>
              <td class="<%= dueClass %>">
                ₹<%= Number(l.due_amount).toLocaleString("en-IN") %>
              </td>
              <td>
                <% const badgeClass=l.status==='Paid' ? 'badge badge-paid'
                                                                : 'badge badge-unpaid' ; %>
                <span class="<%= badgeClass %>">
                  <%= l.status %>
                </span>
              </td>
              <td>
                <%= new Date(l.created_at).toLocaleDateString("en-IN") %>
              </td>
            </tr>
            <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

    </div>
  </div>
</div>

<%- include("../partials/footer") %>