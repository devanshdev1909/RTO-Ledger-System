<%- include('../partials/header') %>

<h1>Customer Ledger: <%= customer.full_name %></h1>

<div style="margin-top:16px; background:#e3f2fd; padding:16px; border-radius:8px; display:flex; gap:32px;">
    <div>
        <strong>Total Credit:</strong> ₹<%= balance.total_credit %>
    </div>
    <div>
        <strong>Total Debit:</strong> ₹<%= balance.total_debit %>
    </div>
    <div>
        <strong>Net Balance:</strong> ₹<%= balance.total_credit - balance.total_debit %>
    </div>
</div>

<table border="1" cellpadding="8" cellspacing="0" style="width:100%; margin-top:16px;">
    <thead>
        <tr>
            <th>#</th>
            <th>Date</th>
            <th>Service</th>
            <th>Type</th>
            <th>Amount</th>
            <th>Mode</th>
            <th>Notes</th>
        </tr>
    </thead>
    <tbody>
        <% entries.forEach((e, i) => { %>
        <tr>
            <td><%= i + 1 %></td>
            <td><%= new Date(e.created_at).toLocaleDateString('en-IN') %></td>
            <td><%= e.service_type || '-' %></td>
            <td style="color: <%= e.transaction_type === 'credit' ? '#2e7d32' : '#c62828' %>">
                <%= e.transaction_type %>
            </td>
            <td>₹<%= e.amount %></td>
            <td><%= e.payment_mode %></td>
            <td><%= e.notes || '-' %></td>
        </tr>
        <% }) %>
    </tbody>
</table>

<%- include('../partials/footer') %>
