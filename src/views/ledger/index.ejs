<%- include("../partials/header") %>

    <div class="container">
        <%- include("../partials/sidebar") %>
            <div class="main-content">
                <%- include("../partials/navbar") %>
                    <div class="content">

                        <div class="page-header">
                            <h1>Ledger</h1>
                            <% if (permissions.includes('ledger.create')) { %>
                                <a href="/ledger/new" class="btn btn-primary">+ New Entry</a>
                                <% } %>
                        </div>

                        <div class="table-container">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Customer</th>
                                        <th>Vehicle</th>
                                        <th>Service</th>
                                        <th>Service Fee</th>
                                        <th>Amount Paid</th>
                                        <th>Due Amount</th>
                                        <th>Status</th>
                                        <th>Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (ledgers.length===0) { %>
                                        <tr>
                                            <td colspan="9" class="empty-state">No ledger entries found.</td>
                                        </tr>
                                        <% } else { %>
                                            <% ledgers.forEach((l, i)=> { %>
                                                <tr>
                                                    <td>
                                                        <%= i + 1 %>
                                                    </td>
                                                    <td><strong>
                                                            <%= l.customer_name || "N/A" %>
                                                        </strong><br>
                                                        <small>
                                                            <%= l.customer_code || "" %>
                                                        </small>
                                                    </td>
                                                    <td>
                                                        <%= l.vehicle_number || "N/A" %>
                                                    </td>
                                                    <td>
                                                        <%= l.service_name || "Manual Entry" %>
                                                    </td>
                                                    <td>₹<%= Number(l.service_fee).toLocaleString("en-IN") %>
                                                    </td>
                                                    <td>₹<%= Number(l.amount_paid).toLocaleString("en-IN") %>
                                                    </td>
                                                    <% const dueColor=l.due_amount> 0 ? 'amount-due' : 'amount-clear';
                                                        %>
                                                        <td class="<%= dueColor %>">
                                                            ₹<%= Number(l.due_amount).toLocaleString("en-IN") %>
                                                        </td>
                                                        <td>
                                                            <% const badgeClass=l.status==='Paid' ? 'badge badge-paid'
                                                                : 'badge badge-unpaid' ; %>
                                                                <span class="<%= badgeClass %>">
                                                                    <%= l.status %>
                                                                </span>
                                                        </td>
                                                        <td>
                                                            <%= new Date(l.created_at).toLocaleDateString("en-IN") %>
                                                        </td>
                                                        <td>
                                                            <a href="/ledger/customer/<%= l.customer_id %>"
                                                                class="btn btn-edit">View</a>
                                                            <% if (permissions.includes('ledger.create')) { %>
                                                                <a href="/ledger/<%= l.id %>/edit"
                                                                    class="btn btn-edit">Edit</a>
                                                                <% } %>
                                                        </td>
                                                </tr>
                                                <% }) %>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                    </div>
            </div>
    </div>

    <%- include("../partials/footer") %>