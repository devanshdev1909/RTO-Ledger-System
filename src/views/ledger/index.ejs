<%- include("../partials/header") %>

<div class="container">
  <%- include("../partials/sidebar") %>
  <div class="main-content">
    <%- include("../partials/navbar") %>
    <div class="content">

      <div class="page-header">
        <h1>Ledger</h1>
        <% if (permissions.includes('ledger.create')) { %>
        <button type="button" class="btn btn-primary" onclick="openCreateModal()">+ New
          Entry</button>
        <% } %>
      </div>

      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">#</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Customer</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Vehicle</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Service</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Service Fee</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Amount Paid</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Due Amount</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Status</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Date</th>
              <th style="text-align: center; background-color:#203051; color:white; font-size:16px;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (ledgers.length===0) { %>
            <tr>
              <td colspan="9" class="empty-state">No ledger entries found.</td>
            </tr>
            <% } else { %>
            <% ledgers.forEach((l, i)=> { %>
            <tr>
              <td style="text-align: center;">
                <%= i + 1 %>
              </td>
              <td style="text-align: center;"><strong>
                  <%= l.customer_name || "N/A" %>
                </strong><br>
                <small>
                  <%= l.customer_code || "" %>
                </small>
              </td>
              <td style="text-align: center;">
                <%= l.vehicle_number || "N/A" %>
              </td>
              <td style="text-align: center;">
                <%= l.service_name || "Manual Entry" %>
              </td>
              <td style="text-align: center;">₹<%= Number(l.service_fee).toLocaleString("en-IN") %>
              </td>
              <td style="text-align: center;">₹<%= Number(l.amount_paid).toLocaleString("en-IN") %>
              </td>
              <% const dueColor=l.due_amount> 0 ? 'amount-due' : 'amount-clear';
                                                        %>
              <td class="<%= dueColor %>">
                ₹<%= Number(l.due_amount).toLocaleString("en-IN") %>
              </td>
              <td style="text-align: center;">
                <% const badgeClass=l.status==='Paid' ? 'badge badge-paid'
                                                                : 'badge badge-unpaid' ; %>
                <span class="<%= badgeClass %>">
                  <%= l.status %>
                </span>
              </td>
              <td style="text-align: center;">
                <%= new Date(l.created_at).toLocaleDateString("en-IN") %>
              </td>
              <td class="actions" style="text-align: center;">

                <!-- VIEW -->
                <a href="/ledger/customer/<%= l.customer_id %>" class="btn-icon view-icon" title="View">

                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z" />
                    <circle cx="12" cy="12" r="3" />
                  </svg>

                </a>

                <% if (permissions.includes('ledger.create')) { %>

                <!-- EDIT -->
                <button type="button" class="btn-icon edit-icon" title="Edit" onclick="openEditModal('<%= l.id %>', '<%= l.customer_name %>', '<%= l.vehicle_number %>', '<%= l.service_name %>', '<%= l.service_fee %>', '<%= l.amount_paid %>')">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M7 7h-1a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2v-1" />
                    <path d="M20.385 6.585a2.1 2.1 0 0 0-2.97-2.97l-8.415 8.385v3h3l8.385-8.415" />
                  </svg>
                </button>
                <% } %>

              </td>
            </tr>
            <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

    </div>
  </div>
</div>

<!-- The Modal Overlay -->
<div id="myCustomModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; overflow-y: auto;">

  <div style="background:white; max-width:600px; margin: 10vh auto; padding: 25px; border-radius: 8px; position: relative;">

    <h2 id="modalTitle" style="margin: 0 0 20px 0;">New Ledger Entry</h2>

    <form id="myForm" action="/ledger" method="POST">
      <input type="hidden" id="methodOverride" name="_method" value="PUT" disabled>

      <div id="sr_dropdown_container" class="form-group">
        <label for="service_request_id">Select Service Request <span style="color:red">*</span></label>
        <select name="service_request_id" id="service_request_id" onchange="onServiceRequestChange(this)">
          <option value="">-- Choose a Service Request --</option>
          <% requests.forEach(r=> { %>
          <option value="<%= r.id %>" data-customer-id="<%= r.customer_id %>" data-customer-name="<%= r.customer_name %>" data-vehicle-id="<%= r.vehicle_id %>" data-vehicle-number="<%= r.vehicle_number || 'No Vehicle' %>" data-amount="<%= r.amount %>" data-service-name="<%= r.service_name %>">
            <%= r.request_no %> - <%= r.customer_name %> (<%= r.service_name %>)
          </option>
          <% }) %>
        </select>
      </div>

      <input type="hidden" name="customer_id" id="customer_id">
      <input type="hidden" name="vehicle_id" id="vehicle_id">
      <input type="hidden" name="service_fee" id="service_fee">

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
        <div class="form-group">
          <label>Customer</label>
          <input type="text" id="customer_name_view" disabled style="background:#f3f4f6; color:#6b7280;">
        </div>

        <div class="form-group">
          <label>Vehicle</label>
          <input type="text" id="vehicle_number_view" disabled style="background:#f3f4f6; color:#6b7280;">
        </div>

        <div class="form-group">
          <label>Service</label>
          <input type="text" id="service_name_view" disabled style="background:#f3f4f6; color:#6b7280;">
        </div>

        <div class="form-group">
          <label>Service Fee</label>
          <input type="text" id="service_fee_view" disabled style="background:#f3f4f6; color:#6b7280;">
        </div>

        <div class="form-group">
          <label for="amount_paid">Amount Paid (₹) <span style="color:red">*</span></label>
          <input type="number" name="amount_paid" id="amount_paid" min="0" step="0.01" value="0" required oninput="calcDue()">
        </div>

        <div class="form-group">
          <label for="payment_mode">Payment Mode <span style="color:red">*</span></label>
          <select name="payment_mode" id="payment_mode" required>
            <option value="UPI" selected>UPI</option>
            <option value="Cash">Cash</option>
            <option value="Bank Transfer">Bank Transfer</option>
            <option value="Card">Card</option>
          </select>
        </div>

        <div class="form-group">
          <label>Due Amount (₹)</label>
          <input type="text" id="due_preview" disabled value="0" style="background:#f3f4f6; color:#6b7280;">
        </div>

        <div class="form-group">
          <label for="status">Status <span style="color:red">*</span></label>
          <select name="status" id="status" required style="pointer-events: none; background: #f3f4f6;" tabindex="-1">
            <option value="Unpaid">Unpaid</option>
            <option value="Partial">Partial</option>
            <option value="Paid">Paid</option>
          </select>
        </div>
      </div>

      <!-- Buttons -->
      <div style="margin-top: 20px; display: flex; gap: 10px; justify-content: flex-end;">
        <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</div>
<script>
  function onServiceRequestChange(selectElement) {
    const selectedOption = selectElement.options[selectElement.selectedIndex];
    if (selectElement.value) {
      document.getElementById("customer_id").value = selectedOption.dataset.customerId;
      document.getElementById("customer_name_view").value = selectedOption.dataset.customerName;
      document.getElementById("vehicle_id").value = selectedOption.dataset.vehicleId || "";
      document.getElementById("vehicle_number_view").value = selectedOption.dataset.vehicleNumber;
      document.getElementById("service_name_view").value = selectedOption.dataset.serviceName;
      const amount = parseFloat(selectedOption.dataset.amount) || 0;
      document.getElementById("service_fee").value = amount;
      document.getElementById("service_fee_view").value = "₹ " + amount.toLocaleString("en-IN");
    } else {
      document.getElementById("customer_id").value = "";
      document.getElementById("customer_name_view").value = "";
      document.getElementById("vehicle_id").value = "";
      document.getElementById("vehicle_number_view").value = "";
      document.getElementById("service_name_view").value = "";
      document.getElementById("service_fee").value = "";
      document.getElementById("service_fee_view").value = "";
    }
    calcDue();
  }

  function calcDue() {
    const fee = parseFloat(document.getElementById("service_fee").value) || 0;
    const paidInput = document.getElementById("amount_paid");
    paidInput.max = fee;
    let paid = parseFloat(paidInput.value) || 0;

    if (paid > fee) {
      paidInput.value = fee;
      paid = fee;
    }

    const due = fee - paid;
    document.getElementById("due_preview").value = "₹ " + Math.max(0, due).toFixed(2);

    const statusSelect = document.getElementById("status");
    if (fee > 0 && paid >= fee) {
      statusSelect.value = "Paid";
    } else if (paid > 0 && paid < fee) {
      statusSelect.value = "Partial";
    } else {
      statusSelect.value = "Unpaid";
    }
  }

  function openCreateModal() {
    document.getElementById('modalTitle').textContent = "New Ledger Entry";
    document.getElementById('myForm').action = "/ledger";
    document.getElementById('methodOverride').disabled = true;

    // Show dropdown for new entry
    document.getElementById('sr_dropdown_container').style.display = 'block';
    document.getElementById('service_request_id').required = true;
    document.getElementById('service_request_id').value = "";
    onServiceRequestChange(document.getElementById('service_request_id'));

    document.getElementById('payment_mode').value = "UPI";
    document.getElementById('myCustomModal').style.display = 'block';
  }

  function openEditModal(id, customer_name, vehicle_number, service_name, service_fee, amount_paid) {
    document.getElementById('modalTitle').textContent = "Update Ledger Entry";
    document.getElementById('myForm').action = "/ledger/" + id + "?_method=PUT";
    document.getElementById('methodOverride').disabled = false;

    // Hide dropdown for editing
    document.getElementById('sr_dropdown_container').style.display = 'none';
    document.getElementById('service_request_id').required = false;

    document.getElementById('customer_name_view').value = customer_name;
    document.getElementById('vehicle_number_view').value = vehicle_number || 'No Vehicle';
    document.getElementById('service_name_view').value = service_name || 'Manual Entry';

    document.getElementById('service_fee').value = service_fee;
    document.getElementById('service_fee_view').value = "₹ " + parseFloat(service_fee).toLocaleString("en-IN");

    document.getElementById('amount_paid').value = amount_paid;
    document.getElementById('payment_mode').value = "UPI";

    calcDue();
    document.getElementById('myCustomModal').style.display = 'block';
  }

  function closeModal() {
    document.getElementById('myCustomModal').style.display = 'none';
  }

  window.addEventListener('click', function(e) {
    const modal = document.getElementById('myCustomModal');

    if (e.target === modal) {
      modal.style.display = 'none';
    }
  });
</script>


<%- include("../partials/footer") %>