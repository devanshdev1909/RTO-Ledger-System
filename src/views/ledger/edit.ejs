<%- include("../partials/header") %>

    <div class="container">
        <%- include("../partials/sidebar") %>
            <div class="main-content">
                <%- include("../partials/navbar") %>
                    <div class="content">

                        <div class="page-header">
                            <h1>Edit Ledger Entry</h1>
                            <a href="/ledger" class="btn btn-secondary">← Back</a>
                        </div>

                        <div class="form-card">
                            <form action="/ledger/<%= ledger.id %>?_method=PUT" method="POST">

                                <!-- Customer (read-only) -->
                                <div class="form-group">
                                    <label>Customer</label>
                                    <input type="text" value="<%= ledger.customer_name %>" disabled
                                        style="background:#f3f4f6; color:#6b7280;">
                                </div>

                                <!-- Vehicle (read-only) -->
                                <div class="form-group">
                                    <label>Vehicle</label>
                                    <input type="text" value="<%= ledger.vehicle_number || 'No Vehicle' %>" disabled
                                        style="background:#f3f4f6; color:#6b7280;">
                                </div>

                                <!-- Service Fee (read-only) -->
                                <div class="form-group">
                                    <label for="service_fee">Service Fee (₹)</label>
                                    <input type="number" id="service_fee" min="0" step="0.01"
                                        value="<%= ledger.service_fee %>" readonly
                                        style="background:#f3f4f6; color:#6b7280;">
                                </div>

                                <!-- Amount Paid -->
                                <div class="form-group">
                                    <label for="amount_paid">Amount Paid (₹) <span style="color:red">*</span></label>
                                    <input type="number" name="amount_paid" id="amount_paid" min="0" step="0.01"
                                        value="<%= ledger.amount_paid %>" required oninput="calcDue()" autofocus>
                                </div>

                                <!-- Payment Mode -->
                                <div class="form-group">
                                    <label for="payment_mode">Payment Mode <span style="color:red">*</span></label>
                                    <select name="payment_mode" id="payment_mode" required>
                                        <option value="UPI" selected>UPI</option>
                                        <option value="Cash">Cash</option>
                                        <option value="Bank Transfer">Bank Transfer</option>
                                        <option value="Card">Card</option>
                                    </select>
                                </div>


                                <!-- Due Amount (read-only) -->
                                <div class="form-group">
                                    <label>Due Amount (₹)</label>
                                    <input type="text" id="due_preview" disabled
                                        value="₹<%= parseFloat(ledger.due_amount).toFixed(2) %>"
                                        style="background:#f3f4f6; color:#6b7280;">
                                </div>

                                <!-- Status (read-only, auto-calculated) -->
                                <div class="form-group">
                                    <label for="status">Status <span style="color:red">*</span></label>
                                    <select name="status" id="status" required
                                        style="pointer-events: none; background: #f3f4f6;" tabindex="-1">
                                        <option value="Unpaid" <%=ledger.status==='Unpaid' ? 'selected' : '' %>>Unpaid
                                        </option>
                                        <option value="Partial" <%=ledger.status==='Partial' ? 'selected' : '' %>
                                            >Partial</option>
                                        <option value="Paid" <%=ledger.status==='Paid' ? 'selected' : '' %>>Paid
                                        </option>
                                    </select>
                                </div>

                                <button type="submit" class="btn btn-primary">Update Ledger Entry</button>

                            </form>
                        </div>

                    </div>
            </div>
    </div>

    <script>
        function calcDue() {
            const fee = parseFloat(document.getElementById("service_fee").value) || 0;
            const paidInput = document.getElementById("amount_paid");
            paidInput.max = fee;
            let paid = parseFloat(paidInput.value) || 0;

            if (paid > fee) {
                paidInput.value = fee;
                paid = fee;
            }

            const due = fee - paid;
            document.getElementById("due_preview").value = "₹ " + Math.max(0, due).toFixed(2);

            // Auto-select status
            const statusSelect = document.getElementById("status");
            if (fee > 0 && paid >= fee) {
                statusSelect.value = "Paid";
            } else if (paid > 0 && paid < fee) {
                statusSelect.value = "Partial";
            } else {
                statusSelect.value = "Unpaid";
            }
        }

        // Initialize max attribute and status representation on page load
        window.addEventListener('DOMContentLoaded', calcDue);
    </script>

    <%- include("../partials/footer") %>