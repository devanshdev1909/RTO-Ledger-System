<%- include('../partials/header') %>

<h1>Add Ledger Entry</h1>

<form action="/ledger" method="POST" style="max-width:500px; margin-top:16px;">

    <label>Customer *</label><br>
    <select name="customerId" required style="width:100%; padding:8px; margin-bottom:12px;">
        <option value="">Select Customer</option>
        <% customers.forEach(c => { %>
        <option value="<%= c.id %>"><%= c.full_name %> (<%= c.mobile %>)</option>
        <% }) %>
    </select><br>

    <label>Job (optional)</label><br>
    <select name="jobId" style="width:100%; padding:8px; margin-bottom:12px;">
        <option value="">No Job Linked</option>
        <% jobs.forEach(j => { %>
        <option value="<%= j.id %>">#<%= j.id %> - <%= j.service_type %> (<%= j.customer_name %>)</option>
        <% }) %>
    </select><br>

    <label>Transaction Type *</label><br>
    <select name="transactionType" required style="width:100%; padding:8px; margin-bottom:12px;">
        <option value="credit">Credit (Money In)</option>
        <option value="debit">Debit (Money Out)</option>
    </select><br>

    <label>Amount *</label><br>
    <input type="number" name="amount" step="0.01" required style="width:100%; padding:8px; margin-bottom:12px;"><br>

    <label>Payment Mode *</label><br>
    <select name="paymentMode" required style="width:100%; padding:8px; margin-bottom:12px;">
        <option value="cash">Cash</option>
        <option value="upi">UPI</option>
        <option value="bank-transfer">Bank Transfer</option>
        <option value="cheque">Cheque</option>
        <option value="other">Other</option>
    </select><br>

    <label>Notes</label><br>
    <textarea name="notes" rows="3" style="width:100%; padding:8px; margin-bottom:12px;"></textarea><br>

    <button type="submit" style="padding:10px 24px; background:#1a237e; color:#fff; border:none; border-radius:4px; cursor:pointer;">
        Add Entry
    </button>
</form>

<%- include('../partials/footer') %>
