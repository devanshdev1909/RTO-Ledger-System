<%- include('../partials/header') %>

<h1>Add Job</h1>

<form action="/jobs" method="POST" style="max-width:500px; margin-top:16px;">

    <label>Customer *</label><br>
    <select name="customerId" id="customerSelect" required style="width:100%; padding:8px; margin-bottom:12px;">
        <option value="">Select Customer</option>
        <% customers.forEach(c => { %>
        <option value="<%= c.id %>"><%= c.full_name %> (<%= c.mobile %>)</option>
        <% }) %>
    </select><br>

    <label>Vehicle *</label><br>
    <select name="vehicleId" id="vehicleSelect" required style="width:100%; padding:8px; margin-bottom:12px;">
        <option value="">Select Customer first</option>
    </select><br>

    <label>Service Type *</label><br>
    <select name="serviceType" required style="width:100%; padding:8px; margin-bottom:12px;">
        <option value="">Select Service</option>
        <option value="RC Transfer">RC Transfer</option>
        <option value="Insurance">Insurance</option>
        <option value="Fitness">Fitness</option>
        <option value="Permit">Permit</option>
        <option value="Tax">Tax</option>
        <option value="NOC">NOC</option>
        <option value="HP Addition">HP Addition</option>
        <option value="HP Removal">HP Removal</option>
        <option value="Address Change">Address Change</option>
        <option value="Duplicate RC">Duplicate RC</option>
        <option value="Other">Other</option>
    </select><br>

    <label>Description</label><br>
    <textarea name="description" rows="3" style="width:100%; padding:8px; margin-bottom:12px;"></textarea><br>

    <label>Total Amount *</label><br>
    <input type="number" name="totalAmount" step="0.01" required style="width:100%; padding:8px; margin-bottom:12px;"><br>

    <label>Paid Amount</label><br>
    <input type="number" name="paidAmount" step="0.01" value="0" style="width:100%; padding:8px; margin-bottom:12px;"><br>

    <button type="submit" style="padding:10px 24px; background:#1a237e; color:#fff; border:none; border-radius:4px; cursor:pointer;">
        Create Job
    </button>
</form>

<script>
    // Dynamic vehicle loading based on customer selection
    document.getElementById('customerSelect').addEventListener('change', async function() {
        const customerId = this.value;
        const vehicleSelect = document.getElementById('vehicleSelect');
        vehicleSelect.innerHTML = '<option value="">Loading...</option>';

        if (!customerId) {
            vehicleSelect.innerHTML = '<option value="">Select Customer first</option>';
            return;
        }

        try {
            const res = await fetch(`/vehicles/by-customer/${customerId}`);
            const vehicles = await res.json();

            vehicleSelect.innerHTML = '<option value="">Select Vehicle</option>';
            vehicles.forEach(v => {
                vehicleSelect.innerHTML += `<option value="${v.id}">${v.vehicle_number} (${v.make} ${v.model})</option>`;
            });
        } catch (err) {
            vehicleSelect.innerHTML = '<option value="">Error loading vehicles</option>';
        }
    });
</script>

<%- include('../partials/footer') %>
